# Public - exposed to client
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# GA4 Measurement ID (replace G-XXXXXXXXXX in BaseLayout)
PUBLIC_GA4_ID=G-XXXXXXXXXX

# Server-only - n8n workflow webhook
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/erdosdx

# Server-only - Hermes private backend (W6 task)
HERMES_API_URL=https://your-hermes-instance/api/inbound

# Server-only - AI 24h 智能客服 (api/chat.ts)
# 推荐 OpenRouter（一个 key 通吃多家模型）或 Gemini Flash（便宜）
# 不填则 /api/chat 返回 503 + 客户端降级到 WhatsApp
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=openrouter/free
# 站点标识（用于 OpenRouter attribution，可不改）
SITE_NAME=DONGXIAO Cashmere
SITE_DOMAIN=erdosdx.com

# Supabase（api/chat.ts 老客户识别用，必须配才生效）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Astro
ASTRO_TELEMETRY_DISABLED=1
