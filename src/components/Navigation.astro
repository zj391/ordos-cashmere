---
/**
 * 顶部导航（响应式 + 多语言切换器）
 * 含产品分类下拉菜单
 */
import { LOCALES, LOCALE_NAMES, LOCALE_FLAGS, type Locale } from '@/lib/i18n';
import { localePath } from '@/lib/i18n';
import submenusData from '@/data/nav-submenus.json';

interface Props {
  locale: Locale;
  currentPath?: string;
}

const { locale, currentPath = '/' } = Astro.props;

// 主导航
// Pura-style: 5 product category tabs each with own submenu
// Plus 5 informational pages (no submenu)
// menuPos: 'left' | 'center' | 'right' - controls mega menu alignment
// 把 URL 直接指向 /products 列表页（不是 /products/[slug] 详情页）
// 子分类链接带 ?cat=hats&byStyle=beanies 等参数，由 products.astro 的 JS 读 URL 应用 filter。
// 历史原因：[category].astro 把 hats 和 accessories 合并到 hats-accessories 单 hub，
// mega menu 子项要独立 filter 所以走总列表页更直接。
const productListHref = localePath(locale, '/products');

const navItems = [
  { href: `${productListHref}?cat=hats`, labelKey: 'nav.hats', hasSubmenu: 'hats', menuPos: 'left' },
  { href: `${productListHref}?cat=sweaters`, labelKey: 'nav.sweaters', hasSubmenu: 'sweaters', menuPos: 'center' },
  { href: `${productListHref}?cat=scarves`, labelKey: 'nav.scarves', hasSubmenu: 'scarves', menuPos: 'center' },
  { href: `${productListHref}?cat=accessories`, labelKey: 'nav.accessories', hasSubmenu: 'accessories', menuPos: 'right' },
  { href: `${productListHref}?cat=yarn`, labelKey: 'nav.yarn', hasSubmenu: 'yarn', menuPos: 'right' },
  { href: localePath(locale, '/raw-material'), labelKey: 'nav.rawMaterial' },
  { href: localePath(locale, '/ordos-origin'), labelKey: 'nav.ordosOrigin' },
  { href: localePath(locale, '/factory'), labelKey: 'nav.factory' },
  { href: localePath(locale, '/blog'), labelKey: 'nav.blog' },
  { href: localePath(locale, '/contact'), labelKey: 'nav.contact' },
];

// 5 个产品分类的 tab 配置 (跟 products.astro 一致)
const productTabs = [
  { key: 'hats', href: localePath(locale, '/products/hats'), en: 'Cashmere Hats', cn: '羊绒帽子' },
  { key: 'sweaters', href: localePath(locale, '/products/sweaters'), en: 'Sweaters', cn: '羊绒衫' },
  { key: 'scarves', href: localePath(locale, '/products/scarves'), en: 'Scarves & Wraps', cn: '围巾披肩' },
  { key: 'accessories', href: localePath(locale, '/products/accessories'), en: 'Accessories', cn: '配饰' },
  { key: 'yarn', href: localePath(locale, '/products/yarn'), en: 'Yarn & Fiber', cn: '纱线' },
];

// 翻译文本
const labels: Record<string, Record<string, string>> = {
  en: {
    'nav.home': 'Home',
    'nav.hats': 'Hats',
    'nav.sweaters': 'Sweaters',
    'nav.scarves': 'Scarves',
    'nav.accessories': 'Accessories',
    'nav.yarn': 'Yarn', 'nav.products': 'Products', 'nav.rawMaterial': 'Raw Material',
    'nav.yarnFabric': 'Yarn & Fabric', 'nav.garmentOem': 'Garment OEM',
    'nav.ordosOrigin': 'Ordos Origin', 'nav.factory': 'Factory', 'nav.blog': 'Blog',
    'nav.contact': 'Contact', 'nav.menuToggle': 'Menu',
    'nav.viewAll': 'View All →', 'nav.byCategory': 'By Category',
  },
  de: {
    'nav.home': 'Start',
    'nav.hats': 'Hüte',
    'nav.sweaters': 'Pullover',
    'nav.scarves': 'Schals',
    'nav.accessories': 'Accessoires',
    'nav.yarn': 'Garn', 'nav.products': 'Produkte', 'nav.rawMaterial': 'Rohmaterial',
    'nav.yarnFabric': 'Garn & Stoff', 'nav.garmentOem': 'Bekleidung OEM',
    'nav.ordosOrigin': 'Ordos Herkunft', 'nav.factory': 'Fabrik', 'nav.blog': 'Blog',
    'nav.contact': 'Kontakt', 'nav.menuToggle': 'Menü',
    'nav.viewAll': 'Alle anzeigen →', 'nav.byCategory': 'Nach Kategorie',
  },
  fr: {
    'nav.home': 'Accueil',
    'nav.hats': 'Bonnets',
    'nav.sweaters': 'Pulls',
    'nav.scarves': 'Écharpes',
    'nav.accessories': 'Accessoires',
    'nav.yarn': 'Fil', 'nav.products': 'Produits', 'nav.rawMaterial': 'Matière Première',
    'nav.yarnFabric': 'Fil & Tissu', 'nav.garmentOem': 'Vêtement OEM',
    'nav.ordosOrigin': 'Origine Ordos', 'nav.factory': 'Usine', 'nav.blog': 'Blog',
    'nav.contact': 'Contact', 'nav.menuToggle': 'Menu',
    'nav.viewAll': 'Voir tout →', 'nav.byCategory': 'Par catégorie',
  },
  ja: {
    'nav.home': 'ホーム',
    'nav.hats': '帽子',
    'nav.sweaters': 'セーター',
    'nav.scarves': 'スカーフ',
    'nav.accessories': 'アクセサリー',
    'nav.yarn': '糸', 'nav.products': '製品', 'nav.rawMaterial': '原料',
    'nav.yarnFabric': '糸・生地', 'nav.garmentOem': '衣料OEM',
    'nav.ordosOrigin': 'オルドス起源', 'nav.factory': '工場', 'nav.blog': 'ブログ',
    'nav.contact': 'お問い合わせ', 'nav.menuToggle': 'メニュー',
    'nav.viewAll': 'すべて見る →', 'nav.byCategory': 'カテゴリ別',
  },
  kr: {
    'nav.home': '홈',
    'nav.hats': '모자',
    'nav.sweaters': '스웨터',
    'nav.scarves': '스카프',
    'nav.accessories': '액세서리',
    'nav.yarn': '실', 'nav.products': '제품', 'nav.rawMaterial': '원료',
    'nav.yarnFabric': '원사·직물', 'nav.garmentOem': '의류 OEM',
    'nav.ordosOrigin': '오르도스 원산지', 'nav.factory': '공장', 'nav.blog': '블로그',
    'nav.contact': '문의', 'nav.menuToggle': '메뉴',
    'nav.viewAll': '전체 보기 →', 'nav.byCategory': '카테고리별',
  },
  cn: {
    'nav.home': '首页',
    'nav.hats': '帽子',
    'nav.sweaters': '羊绒衫',
    'nav.scarves': '围巾披肩',
    'nav.accessories': '配饰',
    'nav.yarn': '纱线', 'nav.products': '产品', 'nav.rawMaterial': '羊绒原料',
    'nav.yarnFabric': '纱线/面料', 'nav.garmentOem': '成衣代工',
    'nav.ordosOrigin': '鄂尔多斯产地', 'nav.factory': '工厂实力', 'nav.blog': '博客',
    'nav.contact': '联系我们', 'nav.menuToggle': '菜单',
    'nav.viewAll': '查看全部 →', 'nav.byCategory': '按分类',
  },
};

const t = (key: string) => labels[locale]?.[key] || labels.en[key] || key;

// submenu helpers
const subLabel = (sub: any) => sub[locale] || sub.en || sub.cn;
const groupLabel = (groupKey: string, group: any) => {
  return group?.label?.[locale] || group?.label?.en || groupKey;
};
---

<header class="sticky top-0 z-40 w-full border-b border-border bg-background shadow-sm relative">
  <div class="container-narrow flex h-16 items-center justify-between">
    <!-- Logo -->
    <a href={localePath(locale, '/')} class="flex items-center gap-2 group">
      <span class="font-display text-2xl font-medium tracking-tight text-primary">
        DONGXIAO<sup class="text-xs">®</sup>
      </span>
      <span class="hidden md:inline text-xs text-muted-foreground tracking-wider uppercase">
        Cashmere · Ordos
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-1 text-sm" id="desktop-nav">
      {navItems.map((item) => (
        <div class="relative group/item" data-mega-trigger={item.hasSubmenu || ''}>
          <a
            href={item.href}
            class:list={[
              'inline-flex items-center gap-1 px-3 py-2 transition-colors hover:text-primary',
              currentPath === item.href ? 'text-primary font-medium' : 'text-muted-foreground',
            ]}
          >
            {t(item.labelKey)}
            {item.hasSubmenu && (
              <svg class="w-3 h-3 transition-transform group-hover/item:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>
        </div>
      ))}
    </nav>

    <!-- Mega Menu container (rendered once, content swapped by JS based on hovered nav item) -->
    {navItems.filter((i) => i.hasSubmenu).map((item) => (
      <div
        data-mega-panel={item.hasSubmenu}
        class="absolute left-0 right-0 top-full w-full bg-white border-t border-border shadow-[0_24px_48px_-12px_rgba(0,0,0,0.15)] opacity-0 invisible pointer-events-none transition-all duration-300 ease-out z-50"
      >
        <div class="container-narrow py-10 grid grid-cols-[1fr_320px] gap-12">
          <!-- Left: 4 category groups -->
          <div class="grid grid-cols-4 gap-8">
            {Object.entries((submenusData as any)[item.hasSubmenu] || {})
              .filter(([k]) => k !== 'feature')
              .map(([groupKey, group]: [string, any]) => (
              <div class="space-y-4">
                <h3 class="text-xs font-bold uppercase tracking-[0.12em] text-primary border-b border-border pb-2 mb-3">
                  {groupLabel(groupKey, group)}
                </h3>
                <ul class="space-y-2">
                  {group.items?.map((sub: any) => (
                    <li>
                      <a
                        href={`${item.href}&${groupKey}=${sub.key}`}
                        class="block text-sm text-muted-foreground hover:text-primary hover:translate-x-1 transition-all duration-150 py-0.5"
                      >
                        {subLabel(sub)}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

          <!-- Right: featured card (Pura-style) -->
          {(() => {
            const feature = (submenusData as any)[item.hasSubmenu]?.feature;
            if (!feature) return null;
            return (
              <a href={feature.href?.[locale] || feature.href?.en || '#'} class="group/feature block relative overflow-hidden rounded-md bg-stone-50">
                <div class="aspect-[4/3] overflow-hidden">
                  <img
                    src={feature.image}
                    alt=""
                    loading="lazy"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover/feature:scale-105"
                  />
                </div>
                <div class="p-5 space-y-2">
                  <div class="text-[10px] uppercase tracking-[0.15em] text-muted-foreground font-medium">
                    {feature.eyebrow?.[locale] || feature.eyebrow?.en || ''}
                  </div>
                  <div class="font-display text-base text-foreground leading-snug">
                    {feature.title?.[locale] || feature.title?.en || ''}
                  </div>
                  <div class="text-sm text-primary font-medium inline-flex items-center gap-1.5 pt-1">
                    {feature.cta?.[locale] || feature.cta?.en || ''}
                  </div>
                </div>
              </a>
            );
          })()}
        </div>
      </div>
    ))}

    <!-- Right side -->
    <div class="flex items-center gap-3">
      <!-- Language Switcher -->
      <div class="relative group">
        <button
          type="button"
          class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-primary transition-colors"
          aria-label="Change language"
        >
          <span>{LOCALE_FLAGS[locale]}</span>
          <span class="uppercase">{locale}</span>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute right-0 top-full mt-2 w-48 rounded-md border border-border bg-popover shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
          {LOCALES.map((loc) => (
            <a
              href={localePath(loc, currentPath.replace(`/${locale}`, '') || '/')}
              class:list={[
                'flex items-center gap-2 px-4 py-2 text-sm hover:bg-accent transition-colors',
                loc === locale ? 'bg-accent font-medium' : '',
              ]}
            >
              <span>{LOCALE_FLAGS[loc]}</span>
              <span>{LOCALE_NAMES[loc]}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Inquiry Cart (B2B RFQ list) -->
      <a
        href={localePath(locale, '/cart')}
        data-cart-link
        aria-label={({ cn: '询价清单', en: 'Inquiry List', de: 'Anfrageliste', fr: 'Liste de demandes', ja: '見積りリスト', kr: '문의 목록' } as Record<string, string>)[locale] || 'Inquiry List'}
        class="relative inline-flex items-center justify-center p-2 text-muted-foreground hover:text-primary transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
        <span
          data-cart-badge
          class="absolute -top-0.5 -right-0.5 min-w-[18px] h-[18px] px-1 rounded-full bg-primary text-primary-foreground text-[10px] font-bold items-center justify-center hidden"
        >0</span>
      </a>

      <!-- CTA: Contact -->
      <a
        href={localePath(locale, '/contact')}
        class="hidden sm:inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        {locale === 'cn' ? '立即询盘' : 'Get Quote'}
      </a>

      <!-- Mobile Menu Toggle -->
      <button
        type="button"
        class="lg:hidden p-2"
        aria-label={t('nav.menuToggle')}
        id="mobile-menu-toggle"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <nav id="mobile-menu" class="lg:hidden hidden border-t border-border bg-background">
    <div class="container-narrow py-4 space-y-1">
      {navItems.map((item) => (
        <div>
          <a
            href={item.href}
            class="block py-2 text-sm font-medium text-foreground hover:text-primary transition-colors"
          >
            {t(item.labelKey)}
          </a>
          {item.hasSubmenu === 'all' && (
            <div class="pl-4 space-y-1 mt-1 mb-2 border-l-2 border-border ml-2">
              {productTabs.map((tab) => (
                <div class="space-y-1">
                  <a
                    href={tab.href}
                    class="block text-xs font-medium text-muted-foreground hover:text-primary transition-colors py-1"
                  >
                    {locale === 'cn' ? tab.cn : tab.en}
                  </a>
                  {(submenusData as any)[tab.key]?.slice(0, 4).map((sub: any) => (
                    <a
                      href={`${tab.href}?submenu=${sub.key}`}
                      class="block text-xs text-muted-foreground/80 hover:text-primary transition-colors py-0.5 pl-3"
                    >
                      · {subLabel(sub)}
                    </a>
                  ))}
                </div>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </nav>
</header>

<script is:inline>
  // 移动端菜单
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => menu.classList.add('hidden'));
  });

  // Pura-style mega menu: show panel matching the hovered nav item.
  // Single shared overlay prevents z-index/overflow pain from per-item positioning.
  (function () {
    const triggers = document.querySelectorAll('[data-mega-trigger]');
    const panels = document.querySelectorAll('[data-mega-panel]');
    if (!triggers.length || !panels.length) return;

    let activeKey = null;
    let hideTimer = null;

    function show(key) {
      if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
      if (key === activeKey) return;
      activeKey = key;
      panels.forEach((p) => {
        if (p.getAttribute('data-mega-panel') === key) {
          p.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
          p.classList.add('opacity-100', 'visible', 'pointer-events-auto');
        } else {
          p.classList.add('opacity-0', 'invisible', 'pointer-events-none');
          p.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
        }
      });
    }

    function scheduleHide() {
      if (hideTimer) clearTimeout(hideTimer);
      hideTimer = setTimeout(() => {
        activeKey = null;
        panels.forEach((p) => {
          p.classList.add('opacity-0', 'invisible', 'pointer-events-none');
          p.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
        });
      }, 120); // small grace period so cursor can move from trigger to panel
    }

    triggers.forEach((t) => {
      const key = t.getAttribute('data-mega-trigger');
      if (!key) return;
      t.addEventListener('mouseenter', () => show(key));
      t.addEventListener('mouseleave', scheduleHide);
    });

    panels.forEach((p) => {
      p.addEventListener('mouseenter', () => {
        if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
      });
      p.addEventListener('mouseleave', scheduleHide);
    });

    // Touch / keyboard: tap-to-toggle for accessibility
    triggers.forEach((t) => {
      const a = t.querySelector('a');
      if (!a) return;
      a.addEventListener('click', (e) => {
        const key = t.getAttribute('data-mega-trigger');
        if (!key) return;
        // If panel for this key is hidden, prevent navigation and show it
        if (activeKey !== key) {
          e.preventDefault();
          show(key);
        }
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && activeKey) scheduleHide();
    });
  })();

  // Inquiry cart badge — listens to dx-cart-change events from the React island
  (function () {
    var badge = document.querySelector('[data-cart-badge]');
    if (!badge || !window.dxCart) return;
    function render() {
      var n = window.dxCart.count();
      if (n > 0) {
        badge.textContent = n > 99 ? '99+' : String(n);
        badge.classList.remove('hidden');
        badge.classList.add('inline-flex');
      } else {
        badge.classList.add('hidden');
        badge.classList.remove('inline-flex');
      }
    }
    render();
    window.addEventListener('dx-cart-change', render);
    window.addEventListener('storage', function (e) {
      if (e.key === 'dx-inquiry-cart-v1') render();
    });
  })();
</script>
