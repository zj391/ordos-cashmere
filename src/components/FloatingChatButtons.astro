---
/**
 * 双悬浮按钮（WhatsApp + WeChat 1:1 并列）
 * 全站最高优先级：永远同时显示，IP 识别决定轻微高亮
 */
import { SITE_INFO } from '@/lib/seo';

interface Props {
  locale: string;
}

const { locale } = Astro.props;

const isChinaLocale = locale === 'cn';

const waMessage = locale === 'cn'
  ? '您好，我对贵司的羊绒产品感兴趣，可以给我发一份详细资料和报价吗？'
  : 'Hello! I am interested in your cashmere products. Could you please share catalog and quotation?';

// WeChat 二维码图（占位 - 需要时换成你的实际二维码）
const wechatQrUrl = '/images/wechat-qr.png';
---

<!--
  双按钮布局说明：
  - 桌面：右下角垂直堆叠两个按钮（间距 12px），等大等亮
  - 移动：右下角浮动
  - IP 识别后高亮其中一个（永远同时可见，仅 opacity 区分）
-->
<div
  id="floating-chat-buttons"
  class="fixed right-4 bottom-4 md:right-6 md:bottom-6 z-50 flex flex-col gap-3"
  data-region={isChinaLocale ? 'CN' : 'GLOBAL'}
>
  <!-- AI 客服入口按钮（点击触发 /api/chat 弹窗） -->
  <button
    id="btn-ai-chat"
    type="button"
    class="group flex items-center justify-center w-14 h-14 md:w-16 md:h-16 rounded-full bg-primary text-primary-foreground shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-200"
    aria-label="AI Chat"
    data-channel="ai_chat"
    onclick={`window.gtag?.('event', 'ai_chat_open', { locale: '${locale}', channel: 'ai_chat' }); window.dispatchEvent(new CustomEvent('hermes:open-ai-chat'));`}
  >
    <svg class="w-7 h-7 md:w-8 md:h-8" fill="none" stroke="currentColor" strokeWidth="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"/>
    </svg>
    <span class="sr-only">Open AI Chat</span>
  </button>

  <!-- WhatsApp 按钮 -->
  <a
    id="btn-whatsapp"
    href={`https://wa.me/${SITE_INFO.whatsapp.replace(/[^\d]/g, '')}?text=${encodeURIComponent(waMessage)}`}
    target="_blank"
    rel="noopener noreferrer"
    class="group flex items-center justify-center w-14 h-14 md:w-16 md:h-16 rounded-full bg-[#25D366] text-white shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-200"
    aria-label="WhatsApp"
    data-channel="whatsapp"
    onclick={`window.gtag?.('event', 'whatsapp_click', { locale: '${locale}', channel: 'whatsapp' });`}
  >
    <svg class="w-7 h-7 md:w-8 md:h-8" fill="currentColor" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
    </svg>
    <span class="sr-only">Contact via WhatsApp</span>
  </a>

  <!-- WeChat 按钮 -->
  <button
    id="btn-wechat"
    type="button"
    class="group relative flex items-center justify-center w-14 h-14 md:w-16 md:h-16 rounded-full bg-[#07C160] text-white shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-200"
    aria-label="WeChat"
    data-channel="wechat"
    onclick={`window.gtag?.('event', 'wechat_click', { locale: '${locale}', channel: 'wechat' });`}
  >
    <svg class="w-7 h-7 md:w-8 md:h-8" fill="currentColor" viewBox="0 0 24 24">
      <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.327.327 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 015.785 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 0111.598 7.17c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 01-.023-.156.49.49 0 01.201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-6.656-6.088V8.89c-.135-.01-.27-.027-.407-.032zm-2.328 3.158c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983.976.976 0 01.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983.976.976 0 01.969-.982z"/>
    </svg>
    <span class="sr-only">Contact via WeChat</span>
  </button>
</div>

<!-- WeChat 二维码弹窗（PC 端） -->
<div
  id="wechat-modal"
  class="hidden fixed inset-0 z-[60] bg-black/60 items-center justify-center p-4"
  onclick="if(event.target.id==='wechat-modal') document.getElementById('wechat-modal').classList.add('hidden'); document.getElementById('wechat-modal').classList.remove('flex');"
>
  <div class="bg-white rounded-lg shadow-2xl p-8 max-w-sm w-full relative">
    <button
      type="button"
      class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center text-gray-500 hover:text-gray-900"
      onclick="document.getElementById('wechat-modal').classList.add('hidden'); document.getElementById('wechat-modal').classList.remove('flex');"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <div class="text-center">
      <h3 class="font-display text-2xl mb-2">WeChat</h3>
      <p class="text-sm text-gray-600 mb-4">
        {locale === 'cn' ? '扫描二维码添加微信' : 'Scan QR code to add WeChat'}
      </p>
      <div class="bg-gray-100 rounded-lg p-4 mb-4">
        <img
          src={wechatQrUrl}
          alt="WeChat QR Code"
          class="w-full max-w-[240px] mx-auto aspect-square object-contain"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
        />
        <div style="display:none;" class="text-sm text-gray-500 p-8">
          WeChat ID: <strong>{SITE_INFO.wechatId}</strong>
        </div>
      </div>
      <p class="text-xs text-gray-500">
        WeChat ID: <span class="font-mono font-medium">{SITE_INFO.wechatId}</span>
      </p>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const wechatBtn = document.getElementById('btn-wechat');
    const modal = document.getElementById('wechat-modal');
    if (wechatBtn && modal) {
      wechatBtn.addEventListener('click', function() {
        // 移动端尝试唤起 WeChat app
        if (/Android|iPhone|iPad/i.test(navigator.userAgent)) {
          // 移动端：用 weixin:// 协议尝试唤起
          const weixinScheme = 'weixin://';
          window.location.href = weixinScheme;
          // 兜底：弹出二维码 modal
          setTimeout(function() {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
          }, 300);
        } else {
          // PC 端：弹二维码
          modal.classList.remove('hidden');
          modal.classList.add('flex');
        }
      });
    }

    // IP 识别高亮（基于 BaseLayout 注入的 __HERMES_REGION__）
    const region = window.__HERMES_REGION__ || 'GLOBAL';
    const waBtn = document.getElementById('btn-whatsapp');
    if (waBtn) {
      if (region === 'CN') {
        waBtn.style.opacity = '0.7';
        waBtn.style.transform = 'scale(0.95)';
      } else {
        waBtn.style.opacity = '1';
        waBtn.style.transform = 'scale(1)';
      }
    }
    const wechatBtnEl = document.getElementById('btn-wechat');
    if (wechatBtnEl) {
      if (region === 'CN') {
        wechatBtnEl.style.opacity = '1';
        wechatBtnEl.style.transform = 'scale(1)';
      } else {
        wechatBtnEl.style.opacity = '0.7';
        wechatBtnEl.style.transform = 'scale(0.95)';
      }
    }
  })();
</script>
