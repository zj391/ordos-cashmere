---
/**
 * 页面底部 SEO FAQ - 增加长尾关键词覆盖
 * 不影响页面主 FAQ 区块，作为额外的 SEO 内容补充
 * 2026-07-23: 现在也 emit FAQPage JSON-LD schema 让 Google 拿到
 *   rich-result eligibility (FAQ dropdown in SERPs). 任何调用
 *   <SEOFaq faqs={...}/> 的页面都会自动受益。
 */
import { faqPageSchema } from '@/lib/schema';
import { pickLocale } from '@/lib/i18n';

interface FAQ {
  q: string;
  a: string;
}

interface Props {
  faqs: FAQ[];
  title?: string;
}

const { faqs, title } = Astro.props;
const locale = pickLocale(Astro.params?.locale);
const faqJsonLd = faqs.length > 0 ? faqPageSchema(faqs) : null;
---

{faqs.length > 0 && (
  <section class="py-16 bg-secondary/20 border-t border-border">
    <div class="container-narrow">
      <div class="max-w-3xl">
        {title && <h2 class="font-display text-3xl font-light mb-8">{title}</h2>}
        <div class="space-y-4">
          {faqs.map((f) => (
            <details class="group border border-border rounded-lg p-5 bg-card">
              <summary class="flex justify-between items-center font-medium cursor-pointer list-none">
                <span class="text-base">{f.q}</span>
                <svg class="w-5 h-5 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-3 text-sm text-muted-foreground leading-relaxed">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>
)}
{faqJsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} is:inline />
)}
