  <!-- Lightbox open/close logic + arrow keys -->
  <script is:inline>
    (function() {
      function lbOpen(src, imgs, idx) {
        var lb = document.getElementById('image-lightbox');
        if (!lb) return;
        lb.classList.remove('hidden');
        lb.classList.add('flex');
        lb.dataset.imgs = imgs.join('|');
        lb.dataset.total = imgs.length;
        lb.dataset.idx = idx;
        document.getElementById('lightbox-img').src = src;
        var c = document.getElementById('lightbox-counter');
        if (c) c.textContent = (idx + 1) + ' / ' + imgs.length;
        document.body.style.overflow = 'hidden';
      }
      function lbClose() {
        var lb = document.getElementById('image-lightbox');
        if (!lb) return;
        lb.classList.add('hidden');
        lb.classList.remove('flex');
        document.body.style.overflow = '';
      }
      window.__lbOpen = lbOpen;
      window.__lbClose = lbClose;

      function initLightbox() {
        var trigger = document.querySelector('[data-lightbox-trigger]');
        var thumbs = document.querySelectorAll('[data-gallery-thumb]');
        var imgs = [];
        thumbs.forEach(function(t) {
          imgs.push(t.dataset.galleryThumb);
        });
        var mainSrc = trigger ? (trigger.dataset.lightboxSrc || '') : '';
        if (mainSrc && imgs.indexOf(mainSrc) === -1) imgs.unshift(mainSrc);

        function openAt(src) {
          var idx = imgs.indexOf(src);
          lbOpen(src, imgs, idx >= 0 ? idx : 0);
        }

        if (trigger) {
          trigger.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            openAt(trigger.dataset.lightboxSrc || mainSrc);
          });
        }
        // Thumbnails: open lightbox at the thumbnail's index
        thumbs.forEach(function(t) {
          t.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            // First swap the main image, then open lightbox
            var mainImg = document.getElementById('main-product-img');
            if (mainImg && t.dataset.galleryThumb) {
              mainImg.src = t.dataset.galleryThumb;
            }
            if (trigger && t.dataset.galleryThumb) {
              trigger.dataset.lightboxSrc = t.dataset.galleryThumb;
            }
            openAt(t.dataset.galleryThumb);
          });
        });
        // Keyboard navigation
        document.addEventListener('keydown', function(e) {
          var lb = document.getElementById('image-lightbox');
          if (!lb || lb.classList.contains('hidden')) return;
          if (e.key === 'Escape') lbClose();
          else if (e.key === 'ArrowLeft') document.getElementById('lightbox-prev').click();
          else if (e.key === 'ArrowRight') document.getElementById('lightbox-next').click();
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initLightbox);
      } else {
        initLightbox();
      }
    })();
  </script>

