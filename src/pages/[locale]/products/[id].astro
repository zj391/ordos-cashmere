---
/**
 * 产品详情页 - 591 个 SEO URL
 * 路由: /[locale]/products/[id]
 *
 * 每个产品有独立 URL、TDK（title/description/keywords）、JSON-LD Product schema。
 * 591 SKU × 6 国 = 3,546 个 URL。
 *
 * 设计原则：
 * - 极轻量 page（不用 React island，纯 Astro）
 * - hreflang 到 5 个其他语言版本
 * - JSON-LD Product + Offer + AggregateRating 占位
 * - 内部链接到 hub 页 + 其他产品
 */
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import FloatingChatButtons from '@/components/FloatingChatButtons.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import { LOCALES, isLocale, pickLocale } from '@/lib/i18n';
import { SEO, SITE_INFO } from '@/lib/seo';
import { getProductById, getAllProducts, getCategoryById } from '@/data/products';

// 类别 id 映射到产品图目录
const CATEGORY_IMAGE_DIR = {
  hats: 'hats',
  scarves: 'scarves',
  sweaters: 'sweaters',
  accessories: 'hats', // accessories 用 hats 目录（同子目录）
  yarn: 'scarves', // yarn 用 scarves 目录（视觉上接近）
};

export function getStaticPaths() {
  const allProducts = getAllProducts();
  const paths = [];
  for (const locale of LOCALES) {
    for (const p of allProducts) {
      paths.push({
        params: { locale, id: p.id },
        props: { product: p },
      });
    }
  }
  return paths;
}

const { locale: rawLocale, id } = Astro.params;
if (!isLocale(rawLocale)) { return Astro.redirect('/en/'); }
const locale = pickLocale(rawLocale);

const { product } = Astro.props;
if (!product || !id) { return Astro.redirect('/' + locale + '/products'); }

// Resolved detail data (per-product overrides or per-category fallback)
const detail = (product as any).detail || null;

const category = getCategoryById(product.categoryId);
if (!category) { return Astro.redirect('/' + locale + '/products'); }

// 推荐相关产品（同类别，排除自己，最多 6 个）
const allProducts = getAllProducts();
const related = allProducts
  .filter((p) => p.categoryId === product.categoryId && p.id !== product.id)
  .slice(0, 6);

const imageDir = CATEGORY_IMAGE_DIR[product.categoryId] || product.categoryId;
const primaryImage = `/products/${imageDir}/${product.images[0]}`;
const galleryImages = product.images.map((img) => `/products/${imageDir}/${img}`);

// Per-locale TDK
const tdk = {
  en: (p, c) => ({
    title: `${p.name} | Wholesale Cashmere ${c} | DONGXIAO®`,
    description: `${p.name}. ${p.material}, ${p.micron}. Wholesale from Ordos factory. MOQ ${p.moq} pcs. Lead time ${p.lead}. Sample ${p.sample_time}. Factory pricing for global B2B buyers.`,
    keywords: [`${p.name}`, `wholesale cashmere ${c.toLowerCase()}`, `${p.material} ${c.toLowerCase()}`, `cashmere manufacturer ${p.id}`, `OEM ${c.toLowerCase()}`, 'cashmere wholesale', 'Ordos cashmere factory'],
    buyCta: 'Request Quote',
  }),
  cn: (p, c) => ({
    title: `${p.name} | 羊绒${c}批发 | DONGXIAO® 鄂尔多斯源头工厂`,
    description: `${p.name}。${p.material}，${p.micron}。源头工厂批发。MOQ ${p.moq} 件。交期 ${p.lead}。打样 ${p.sample_time}。全球 B2B 采购商工厂价。`,
    keywords: [p.name, `羊绒${c}批发`, `${p.material}${c}`, `羊绒代工 ${p.id}`, `OEM ${c}`, '羊绒厂家', '鄂尔多斯羊绒'],
    buyCta: '询盘',
  }),
  de: (p, c) => ({
    title: `${p.name} | Kaschmir ${c} Großhandel | DONGXIAO®`,
    description: `${p.name}. ${p.material}, ${p.micron}. Großhandel ab Ordos-Fabrik. MOQ ${p.moq} Stk. Lieferzeit ${p.lead}.`,
    keywords: [p.name, `Kaschmir ${c} Großhandel`, `OEM ${c}`],
    buyCta: 'Anfrage',
  }),
  fr: (p, c) => ({
    title: `${p.name} | Cachemire ${c} en gros | DONGXIAO®`,
    description: `${p.name}. ${p.material}, ${p.micron}. Vente en gros depuis l'usine d'Ordos. MOQ ${p.moq} pièces.`,
    keywords: [p.name, `cachemire ${c} gros`, `OEM ${c}`],
    buyCta: 'Demande',
  }),
  ja: (p, c) => ({
    title: `${p.name} | カシミア${c}卸売 | DONGXIAO®`,
    description: `${p.name}。${p.material}、${p.micron}。オルドス工場から卸売。MOQ ${p.moq}枚。`,
    keywords: [p.name, `カシミア${c}卸売`, `OEM ${c}`],
    buyCta: '問い合わせ',
  }),
  kr: (p, c) => ({
    title: `${p.name} | 캐시미어 ${c} 도매 | DONGXIAO®`,
    description: `${p.name}. ${p.material}, ${p.micron}. 오르도스 공장 도매. MOQ ${p.moq}pcs.`,
    keywords: [p.name, `캐시미어 ${c} 도매`, `OEM ${c}`],
    buyCta: '문의',
  }),
};

const t = (tdk[locale] || tdk.en)(product, category.name);

// JSON-LD Product schema
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: t.description,
  image: galleryImages.map((img) => `${SITE_INFO.url}${img}`),
  sku: product.id,
  mpn: product.id,
  brand: { '@type': 'Brand', name: 'DONGXIAO' },
  manufacturer: { '@type': 'Organization', name: 'DONGXIAO Cashmere', url: SITE_INFO.url },
  category: category.name,
  material: product.material,
  offers: {
    '@type': 'Offer',
    priceCurrency: product.currency,
    price: product.price.split('-')[0],
    priceValidUntil: '2027-12-31',
    availability: 'https://schema.org/InStock',
    itemCondition: 'https://schema.org/NewCondition',
    businessFunction: 'https://schema.org/Sell',
    seller: { '@type': 'Organization', name: 'DONGXIAO Cashmere' },
  },
};

// Breadcrumb
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_INFO.url}/${locale}/` },
    { '@type': 'ListItem', position: 2, name: 'Products', item: `${SITE_INFO.url}/${locale}/products` },
    { '@type': 'ListItem', position: 3, name: category.name, item: `${SITE_INFO.url}/${locale}/products/${product.categoryId === 'hats' || product.categoryId === 'accessories' ? 'hats-accessories' : product.categoryId === 'sweaters' ? 'garment-oem' : product.categoryId}` },
    { '@type': 'ListItem', position: 4, name: product.name, item: `${SITE_INFO.url}/${locale}/products/${product.id}` },
  ],
};
---

<BaseLayout
  locale={locale}
  pageKey="products"
  path={`/${locale}/products/${product.id}`}
  title={t.title}
  description={t.description}
  keywords={t.keywords}
  schema="general"
  customSchemas={[productSchema, breadcrumbSchema]}
>
  <Navigation slot="header" locale={locale} currentPath={`/${locale}/products/${product.id}`} />

  <section class="py-12 md:py-16 bg-background">
    <div class="container-narrow">
      <!-- Breadcrumb -->
      <nav class="text-xs text-muted-foreground mb-6">
        <a href={`/${locale}/`} class="hover:text-foreground">Home</a>
        <span class="mx-2">/</span>
        <a href={`/${locale}/products`} class="hover:text-foreground">Products</a>
        <span class="mx-2">/</span>
        <a href={`/${locale}/products/${product.categoryId === 'hats' || product.categoryId === 'accessories' ? 'hats-accessories' : product.categoryId === 'sweaters' ? 'garment-oem' : product.categoryId}`} class="hover:text-foreground">{category.name}</a>
        <span class="mx-2">/</span>
        <span class="text-foreground">{product.name}</span>
      </nav>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
        <!-- Image gallery -->
        <div>
          <div class="aspect-square bg-secondary/30 rounded-lg overflow-hidden mb-4">
            <img src={primaryImage} alt={product.name} class="w-full h-full object-cover" loading="eager" />
          </div>
          {galleryImages.length > 1 && (
            <div class="grid grid-cols-4 gap-2">
              {galleryImages.map((img, i) => (
                <div class="aspect-square bg-secondary/30 rounded overflow-hidden">
                  <img src={img} alt={`${product.name} view ${i + 1}`} class="w-full h-full object-cover" loading="lazy" />
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Product info -->
        <div>
          <span class="text-xs tracking-widest text-muted-foreground uppercase">{category.name}</span>
          <h1 class="font-display text-3xl md:text-4xl font-light mt-2 mb-4">{product.name}</h1>

          <div class="flex items-baseline gap-3 mb-6">
            <span class="text-2xl font-medium">USD {product.price}</span>
            <span class="text-sm text-muted-foreground">/ piece</span>
          </div>

          <p class="text-base text-foreground/80 mb-6">{product.description}</p>

          <!-- Spec table -->
          <div class="border border-border rounded-lg overflow-hidden mb-6">
            <table class="w-full text-sm">
              <tbody>
                <tr class="border-b border-border">
                  <td class="px-4 py-3 bg-secondary/30 font-medium w-1/3">Material</td>
                  <td class="px-4 py-3">{product.material}</td>
                </tr>
                <tr class="border-b border-border">
                  <td class="px-4 py-3 bg-secondary/30 font-medium">Fiber fineness</td>
                  <td class="px-4 py-3">{product.micron}</td>
                </tr>
                <tr class="border-b border-border">
                  <td class="px-4 py-3 bg-secondary/30 font-medium">MOQ</td>
                  <td class="px-4 py-3">{product.moq} pieces per style</td>
                </tr>
                <tr class="border-b border-border">
                  <td class="px-4 py-3 bg-secondary/30 font-medium">Lead time</td>
                  <td class="px-4 py-3">{product.lead}</td>
                </tr>
                <tr class="border-b border-border">
                  <td class="px-4 py-3 bg-secondary/30 font-medium">Sample time</td>
                  <td class="px-4 py-3">{product.sample_time}</td>
                </tr>
                {product.weight && (
                  <tr class="border-b border-border">
                    <td class="px-4 py-3 bg-secondary/30 font-medium">Weight</td>
                    <td class="px-4 py-3">{product.weight}</td>
                  </tr>
                )}
                {product.colors && product.colors.length > 0 && (
                  <tr>
                    <td class="px-4 py-3 bg-secondary/30 font-medium">Colors</td>
                    <td class="px-4 py-3">{product.colors.join(', ')}</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>

          <!-- Tags -->
          {product.tags && product.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-6">
              {product.tags.map((tag) => (
                <span class="text-xs px-2 py-1 border border-border rounded-full">{tag}</span>
              ))}
            </div>
          )}

          <!-- CTA -->
          <div class="flex flex-wrap gap-3">
            <a href={`/${locale}/contact?product=${product.id}`} class="inline-block px-6 py-3 bg-primary text-primary-foreground rounded-sm font-medium hover:bg-primary/90">{t.buyCta}</a>
            <a href={`/${locale}/factory`} class="inline-block px-6 py-3 border border-border rounded-sm hover:bg-secondary">Factory Tour</a>
          </div>

          <p class="text-xs text-muted-foreground mt-4">Direct factory pricing. FOB Tianjin/Shanghai, CIF, DDP. OEM/ODM supported. ISO 9001 + OEKO-TEX certified.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7-9 expanded: imfieldcashmere-style 13-section product page -->

  {detail && (
    <>

  <!-- Section 1: Material Story -->
  {detail.materialStory && (
    <section class="py-12 bg-secondary/20">
      <div class="container-narrow max-w-3xl">
        <h2 class="font-display text-2xl font-light mb-4">Material & Craftsmanship</h2>
        <p class="text-base leading-relaxed text-foreground/80">{detail.materialStory[locale]}</p>
      </div>
    </section>
  )}

  <!-- Section 2: Manufacturing Process -->
  {detail.process && (
    <section class="py-12 bg-background">
      <div class="container-narrow max-w-3xl">
        <h2 class="font-display text-2xl font-light mb-4">Manufacturing Process</h2>
        <p class="text-base leading-relaxed text-foreground/80 mb-6">{detail.process[locale]}</p>
        {detail.processSteps && (
          <ol class="space-y-3">
            {detail.processSteps.map((step, i) => (
              <li class="flex gap-4">
                <span class="flex-shrink-0 w-8 h-8 bg-primary text-primary-foreground rounded-full flex items-center justify-center font-display text-sm">{i + 1}</span>
                <span class="text-sm leading-relaxed pt-1">{step[locale]}</span>
              </li>
            ))}
          </ol>
        )}
      </div>
    </section>
  )}

  <!-- Section 3: Custom Service (6 bullets) -->
  {detail.customServiceBullets && (
    <section class="py-12 bg-secondary/20">
      <div class="container-narrow">
        <h2 class="font-display text-2xl font-light mb-6 text-center">{detail.customServiceTitle?.[locale] || 'Custom Manufacturing Service'}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {detail.customServiceBullets.map((b) => (
            <div class="bg-card border border-border rounded-lg p-5">
              <div class="flex items-start gap-3">
                <span class="text-brand-gold text-lg">✓</span>
                <span class="text-sm leading-relaxed">{b[locale]}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Section 4: Why Choose Us (6 USPs) -->
  {detail.whyChooseBullets && (
    <section class="py-12 bg-background">
      <div class="container-narrow">
        <h2 class="font-display text-2xl font-light mb-8 text-center">{detail.whyChooseTitle?.[locale] || 'Why Choose Our Factory'}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {detail.whyChooseBullets.map((b, i) => (
            <div class="text-center">
              <div class="w-12 h-12 bg-brand-gold/20 rounded-full flex items-center justify-center mx-auto mb-3">
                <span class="text-brand-gold font-display text-lg">{i + 1}</span>
              </div>
              <p class="text-sm leading-relaxed">{b[locale]}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Section 5: Comparison Table (e.g. Cashmere vs Pashmina) -->
  {detail.comparisonPoints && detail.comparisonTitle && (
    <section class="py-12 bg-secondary/20">
      <div class="container-narrow">
        <h2 class="font-display text-2xl font-light mb-6 text-center">{detail.comparisonTitle[locale]}</h2>
        <div class="overflow-x-auto">
          <table class="w-full bg-card border border-border rounded-lg overflow-hidden">
            <thead class="bg-primary text-primary-foreground">
              <tr>
                <th class="text-left p-3 font-medium text-sm">Feature</th>
                <th class="text-left p-3 font-medium text-sm">Cashmere</th>
                <th class="text-left p-3 font-medium text-sm">{detail.comparisonOther}</th>
              </tr>
            </thead>
            <tbody>
              {detail.comparisonPoints.map((p, i) => (
                <tr class={i % 2 === 0 ? 'bg-background' : 'bg-secondary/10'}>
                  <td class="p-3 text-sm font-medium">{p.label?.[locale] || ''}</td>
                  <td class="p-3 text-sm">{p.cashmere?.[locale] || ''}</td>
                  <td class="p-3 text-sm">{p.other?.[locale] || ''}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <!-- Section 6: Applications / Use Cases -->
  {detail.applicationScenarios && (
    <section class="py-12 bg-background">
      <div class="container-narrow">
        <h2 class="font-display text-2xl font-light mb-6 text-center">{detail.applicationsTitle?.[locale] || 'Applications'}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
          {detail.applicationScenarios.map((s) => (
            <div class="border border-border rounded-lg p-4 bg-card">
              <p class="text-sm leading-relaxed">{s[locale]}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Section 7: OEM Workflow (3-5 steps) -->
  {detail.oemWorkflow && detail.oemWorkflow.length > 0 && (
    <section class="py-12 bg-secondary/20">
      <div class="container-narrow">
        <h2 class="font-display text-2xl font-light mb-6 text-center">OEM/ODM Workflow</h2>
        <div class="grid grid-cols-1 md:grid-cols-5 gap-4 max-w-5xl mx-auto">
          {detail.oemWorkflow.map((step, i) => (
            <div class="bg-card border border-border rounded-lg p-4 text-center">
              <div class="w-10 h-10 bg-primary text-primary-foreground rounded-full flex items-center justify-center mx-auto mb-3 font-display">{i + 1}</div>
              <p class="text-xs text-foreground/80 leading-relaxed">{typeof step === 'string' ? step : step[locale]}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Section 8: Care Instructions -->
  {detail.careInstructions && (
    <section class="py-12 bg-background">
      <div class="container-narrow max-w-3xl">
        <h2 class="font-display text-2xl font-light mb-4">Care Instructions</h2>
        <p class="text-base leading-relaxed text-foreground/80">{detail.careInstructions[locale]}</p>
      </div>
    </section>
  )}

  <!-- Section 9: Sample Policy -->
  {detail.samplePolicy && (
    <section class="py-12 bg-secondary/20">
      <div class="container-narrow max-w-3xl">
        <h2 class="font-display text-2xl font-light mb-4">Sample Policy</h2>
        <p class="text-base leading-relaxed text-foreground/80">{detail.samplePolicy[locale]}</p>
      </div>
    </section>
  )}

  <!-- Section 10: Certifications -->
  {detail.certifications && (
    <section class="py-12 bg-background">
      <div class="container-narrow max-w-3xl">
        <h2 class="font-display text-2xl font-light mb-4">Certifications</h2>
        <div class="flex flex-wrap gap-2">
          {detail.certifications.map((c) => (
            <span class="text-sm px-3 py-1.5 border border-border rounded-full bg-card">{c}</span>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Section 11: Product-specific FAQ (4-6 Q&A) -->
  {detail.faq && detail.faq.length > 0 && (
    <section class="py-12 bg-secondary/20">
      <div class="container-narrow max-w-3xl">
        <h2 class="font-display text-2xl font-light mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {detail.faq.map((f) => (
            <details class="bg-card border border-border rounded-lg p-4 group">
              <summary class="font-medium text-base cursor-pointer flex items-center justify-between">
                <span>{f.q[locale]}</span>
                <span class="text-brand-gold text-xl group-open:rotate-45 transition-transform">+</span>
              </summary>
              <p class="text-sm leading-relaxed text-foreground/80 mt-3">{f.a[locale]}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

    </>
  )}

  <!-- Section 12: Inquiry CTA -->
  <section class="py-16 bg-brand-ink text-white">
    <div class="container-narrow text-center">
      <h2 class="font-display text-3xl font-light mb-4">Request a Quotation</h2>
      <p class="opacity-90 mb-8 max-w-2xl mx-auto">Send your target specs (quantity, gauge, color, customization). Our specialists respond within 24 hours with sample, pricing, and lead time.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`/${locale}/contact?product=${product.id}`} class="inline-block px-8 py-3 bg-brand-gold text-brand-ink rounded-sm font-medium hover:bg-brand-gold/90">{t.buyCta}</a>
        <a href={`/${locale}/factory`} class="inline-block px-8 py-3 border border-white/30 rounded-sm hover:bg-white/10">Factory Tour</a>
      </div>
    </div>
  </section>

  <!-- Section 13: Related products -->
  {related.length > 0 && (
    <section class="py-16 bg-background">
      <div class="container-narrow">
        <h2 class="font-display text-2xl font-light mb-6">Related {category.name}</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {related.map((rp) => (
            <a
              href={`/${locale}/products/${rp.id}`}
              class="group block border border-border rounded-lg overflow-hidden hover:border-primary transition-colors"
            >
              <div class="aspect-square bg-secondary/30 overflow-hidden">
                <img
                  src={`/products/${CATEGORY_IMAGE_DIR[rp.categoryId] || rp.categoryId}/${rp.images[0]}`}
                  alt={rp.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                  loading="lazy"
                />
              </div>
              <div class="p-3">
                <h3 class="text-xs font-medium leading-snug line-clamp-2 mb-1">{rp.name}</h3>
                <p class="text-[10px] text-muted-foreground">USD {rp.price}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer slot="footer" locale={locale} />
  <FloatingChatButtons slot="footer" locale={locale} />
  <CookieConsent slot="footer" locale={locale} />
</BaseLayout>