  <!-- Client-side interactivity (7-9): image gallery + inquiry form toggle -->
  <script is:inline>
    (function() {
      function init() {
        // Image gallery: click thumbnail swaps main image
        var mainImg = document.getElementById('main-product-img');
        var thumbs = document.querySelectorAll('[data-gallery-thumb]');
        for (var i = 0; i < thumbs.length; i++) {
          thumbs[i].addEventListener('click', (function(thumb) {
            return function() {
              if (mainImg && thumb.dataset.galleryThumb) {
                mainImg.src = thumb.dataset.galleryThumb;
              }
            };
          })(thumbs[i]));
        }

        // Inquiry form toggle
        var btn = document.querySelector('[data-inquiry-toggle]');
        var form = document.getElementById('inquiry-form');
        if (btn && form) {
          var showText = btn.textContent.trim();
          // Extract hide text by removing trailing ▼ (show) → ▲ (hide)
          var hideText = showText.replace(/[\u25BC\u2193]\s*$/, '\u25B2').replace(/$/, ' \u25B2');
          btn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            form.classList.toggle('hidden');
            var isHidden = form.classList.contains('hidden');
            btn.textContent = isHidden ? showText : hideText;
          });
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>

  <!-- Image Lightbox Modal (7-9): click main image or thumbnail to open -->
  <div
    id="image-lightbox"
