---
/**
 * 产品详情页 - 591 个 SEO URL
 * 路由: /[locale]/products/[id]
 *
 * 每个产品有独立 URL、TDK（title/description/keywords）、JSON-LD Product schema。
 * 591 SKU × 6 国 = 3,546 个 URL。
 *
 * 设计原则：
 * - 极轻量 page（不用 React island，纯 Astro）
 * - hreflang 到 5 个其他语言版本
 * - JSON-LD Product + Offer + AggregateRating 占位
 * - 内部链接到 hub 页 + 其他产品
 */
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import FloatingChatButtons from '@/components/FloatingChatButtons.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import { LOCALES, isLocale, pickLocale } from '@/lib/i18n';
import { SEO, SITE_INFO } from '@/lib/seo';
import { getProductById, getAllProducts, getCategoryById } from '@/data/products';

// 类别 id 映射到产品图目录
// 2026-07-13 修复: 实际图片在 /products/mic/ 目录下 (curl /products/mic/prod_025_00.webp = 200),
// 而不是 /products/scarves/ 或 /products/hats/ 等 (curl /products/scarves/prod_025_00.webp = 404).
// 之前映射到 scarves/hats 等导致所有产品图 404 不可见.
const CATEGORY_IMAGE_DIR = {
  hats: 'mic',
  scarves: 'mic',
  sweaters: 'mic',
  accessories: 'mic',
  yarn: 'mic',
};

export function getStaticPaths() {
  const allProducts = getAllProducts();
  const paths = [];
  for (const locale of LOCALES) {
    for (const p of allProducts) {
      paths.push({
        params: { locale, id: p.id },
        props: { product: p },
      });
    }
  }
  return paths;
}

const { locale: rawLocale, id } = Astro.params;
if (!isLocale(rawLocale)) { return Astro.redirect('/en/'); }
const locale = pickLocale(rawLocale);

const { product } = Astro.props;
if (!product || !id) { return Astro.redirect('/' + locale + '/products'); }

// Resolved detail data (per-product overrides or per-category fallback)
const detail = (product as any).detail || null;

const category = getCategoryById(product.categoryId);
if (!category) { return Astro.redirect('/' + locale + '/products'); }

// 推荐相关产品（同类别，排除自己，最多 6 个）
const allProducts = getAllProducts();
const related = allProducts
  .filter((p) => p.categoryId === product.categoryId && p.id !== product.id)
  .slice(0, 6);

const imageDir = CATEGORY_IMAGE_DIR[product.categoryId] || product.categoryId;
const primaryImage = `/products/${imageDir}/${product.images[0]}`;
const galleryImages = product.images.map((img) => `/products/${imageDir}/${img}`);

// Per-locale TDK
const tdk = {
  en: (p, c) => ({
    title: `${p.name} | Wholesale Cashmere ${c} | DONGXIAO®`,
    description: `${p.name}. ${p.material}, ${p.micron}. Wholesale from Ordos factory. MOQ ${p.moq} pcs. Lead time ${p.lead}. Sample ${p.sample_time}. Factory pricing for global B2B buyers.`,
    keywords: [`${p.name}`, `wholesale cashmere ${c.toLowerCase()}`, `${p.material} ${c.toLowerCase()}`, `cashmere manufacturer ${p.id}`, `OEM ${c.toLowerCase()}`, 'cashmere wholesale', 'Ordos cashmere factory'],
    buyCta: 'Request Quote',
    hideFormCta: 'Hide Form',
  }),
  cn: (p, c) => ({
    title: `${p.name} | 羊绒${c}批发 | DONGXIAO® 鄂尔多斯源头工厂`,
    description: `${p.name}。${p.material}，${p.micron}。源头工厂批发。MOQ ${p.moq} 件。交期 ${p.lead}。打样 ${p.sample_time}。全球 B2B 采购商工厂价。`,
    keywords: [p.name, `羊绒${c}批发`, `${p.material}${c}`, `羊绒代工 ${p.id}`, `OEM ${c}`, '羊绒厂家', '鄂尔多斯羊绒'],
    buyCta: '立即询盘',
    hideFormCta: '收起表单',
  }),
  de: (p, c) => ({
    title: `${p.name} | Kaschmir ${c} Großhandel | DONGXIAO®`,
    description: `${p.name}. ${p.material}, ${p.micron}. Großhandel ab Ordos-Fabrik. MOQ ${p.moq} Stk. Lieferzeit ${p.lead}.`,
    keywords: [p.name, `Kaschmir ${c} Großhandel`, `OEM ${c}`],
    buyCta: 'Anfrage',
    hideFormCta: 'Formular schließen',
  }),
  fr: (p, c) => ({
    title: `${p.name} | Cachemire ${c} en gros | DONGXIAO®`,
    description: `${p.name}. ${p.material}, ${p.micron}. Vente en gros depuis l'usine d'Ordos. MOQ ${p.moq} pièces.`,
    keywords: [p.name, `cachemire ${c} gros`, `OEM ${c}`],
    buyCta: 'Demande',
    hideFormCta: 'Masquer',
  }),
  ja: (p, c) => ({
    title: `${p.name} | カシミア${c}卸売 | DONGXIAO®`,
    description: `${p.name}。${p.material}、${p.micron}。オルドス工場から卸売。MOQ ${p.moq}枚。`,
    keywords: [p.name, `カシミア${c}卸売`, `OEM ${c}`],
    buyCta: '問い合わせ',
    hideFormCta: '閉じる',
  }),
  kr: (p, c) => ({
    title: `${p.name} | 캐시미어 ${c} 도매 | DONGXIAO®`,
    description: `${p.name}. ${p.material}, ${p.micron}. 오르도스 공장 도매. MOQ ${p.moq}pcs.`,
    keywords: [p.name, `캐시미어 ${c} 도매`, `OEM ${c}`],
    buyCta: '문의',
    hideFormCta: '닫기',
  }),
};

const t = (tdk[locale] || tdk.en)(product, category.name);

// JSON-LD Product schema
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: t.description,
  image: galleryImages.map((img) => `${SITE_INFO.url}${img}`),
  sku: product.id,
  mpn: product.id,
  brand: { '@type': 'Brand', name: 'DONGXIAO' },
  manufacturer: { '@type': 'Organization', name: 'DONGXIAO Cashmere', url: SITE_INFO.url },
  category: category.name,
  material: product.material,
  offers: {
    '@type': 'Offer',
    priceCurrency: product.currency,
    price: product.price.split('-')[0],
    priceValidUntil: '2027-12-31',
    availability: 'https://schema.org/InStock',
    itemCondition: 'https://schema.org/NewCondition',
    businessFunction: 'https://schema.org/Sell',
    seller: { '@type': 'Organization', name: 'DONGXIAO Cashmere' },
  },
};

// Breadcrumb
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_INFO.url}/${locale}/` },
    { '@type': 'ListItem', position: 2, name: 'Products', item: `${SITE_INFO.url}/${locale}/products` },
    { '@type': 'ListItem', position: 3, name: category.name, item: `${SITE_INFO.url}/${locale}/products/${product.categoryId === 'hats' || product.categoryId === 'accessories' ? 'hats-accessories' : product.categoryId === 'sweaters' ? 'garment-oem' : product.categoryId}` },
    { '@type': 'ListItem', position: 4, name: product.name, item: `${SITE_INFO.url}/${locale}/products/${product.id}` },
  ],
};
---

<BaseLayout
  locale={locale}
  pageKey="products"
  path={`/${locale}/products/${product.id}`}
  title={t.title}
  description={t.description}
  keywords={t.keywords}
  schema="general"
  customSchemas={[productSchema, breadcrumbSchema]}
>
  <Navigation slot="header" locale={locale} currentPath={`/${locale}/products/${product.id}`} />

  <section class="py-12 md:py-16 bg-background">
    <div class="container-narrow">
      <!-- Breadcrumb -->
      <nav class="text-xs text-muted-foreground mb-6">
        <a href={`/${locale}/`} class="hover:text-foreground">Home</a>
        <span class="mx-2">/</span>
        <a href={`/${locale}/products`} class="hover:text-foreground">Products</a>
        <span class="mx-2">/</span>
        <a href={`/${locale}/products/${product.categoryId === 'hats' || product.categoryId === 'accessories' ? 'hats-accessories' : product.categoryId === 'sweaters' ? 'garment-oem' : product.categoryId}`} class="hover:text-foreground">{category.name}</a>
        <span class="mx-2">/</span>
        <span class="text-foreground">{product.name}</span>
      </nav>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 mb-12">
        <!-- Image gallery: 1 large + 4 thumbnails (imfieldcashmere style) -->
        <div>
          <button
            type="button"
            data-lightbox-trigger
            data-lightbox-src={primaryImage}
            aria-label="Open image viewer"
            class="aspect-square bg-secondary/30 rounded-lg overflow-hidden mb-4 ring-1 ring-border w-full block hover:ring-2 hover:ring-primary transition-all cursor-zoom-in"
          >
            <img id="main-product-img" src={primaryImage} alt={product.name} class="w-full h-full object-cover transition-opacity" loading="eager" />
          </button>
          {galleryImages.length > 1 && (
            <div class="grid grid-cols-4 gap-2">
              {galleryImages.map((img, i) => (
                <button
                  type="button"
                  data-gallery-thumb={img}
                  class="aspect-square bg-secondary/30 rounded overflow-hidden ring-1 ring-border hover:ring-2 hover:ring-primary transition-all"
                  aria-label={`View image ${i + 1}`}
                >
                  <img src={img} alt={`${product.name} view ${i + 1}`} class="w-full h-full object-cover" loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Product info -->
        <div>
          <span class="text-xs tracking-widest text-muted-foreground uppercase">{category.name}</span>
          <h1 class="font-display text-3xl md:text-4xl font-light mt-2 mb-3">{product.name}</h1>

          <div class="flex items-baseline gap-3 mb-4">
            <span class="text-2xl font-medium">USD {product.price}</span>
            <span class="text-sm text-muted-foreground">/ piece</span>
          </div>

          <!-- Quick info badges (imf style) -->
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="text-xs px-2.5 py-1 border border-border rounded-full bg-secondary/20">{product.material}</span>
            <span class="text-xs px-2.5 py-1 border border-border rounded-full bg-secondary/20">{product.micron}</span>
            <span class="text-xs px-2.5 py-1 border border-border rounded-full bg-secondary/20">MOQ {product.moq} pcs</span>
            <span class="text-xs px-2.5 py-1 border border-border rounded-full bg-secondary/20">Lead {product.lead}</span>
          </div>

          <p class="text-base text-foreground/80 mb-6">{product.description}</p>

          <!-- Detailed Description (imf-derived, 7-10) -->
{product.detailedDescription && (
          <div class="mb-6 pb-5 border-b border-border">
            <p class="text-base text-foreground/80 leading-relaxed">{product.detailedDescription}</p>
          </div>
)}

                    <!-- Spec table (imf 2-column style) -->
          <div class="border border-border rounded-lg overflow-hidden mb-6">
            <table class="w-full text-sm">
              <tbody>
                <tr class="border-b border-border">
                  <td class="px-4 py-3 bg-secondary/40 font-medium w-2/5">Material</td>
                  <td class="px-4 py-3">{product.material}</td>
                </tr>
                <tr class="border-b border-border">
                  <td class="px-4 py-3 bg-secondary/40 font-medium">Fiber fineness</td>
                  <td class="px-4 py-3">{product.micron}</td>
                </tr>
                <tr class="border-b border-border">
                  <td class="px-4 py-3 bg-secondary/40 font-medium">MOQ</td>
                  <td class="px-4 py-3">{product.moq} pieces per style</td>
                </tr>
                <tr class="border-b border-border">
                  <td class="px-4 py-3 bg-secondary/40 font-medium">Lead time</td>
                  <td class="px-4 py-3">{product.lead}</td>
                </tr>
                <tr class="border-b border-border">
                  <td class="px-4 py-3 bg-secondary/40 font-medium">Sample time</td>
                  <td class="px-4 py-3">{product.sample_time}</td>
                </tr>
                {product.weight && (
                  <tr class="border-b border-border">
                    <td class="px-4 py-3 bg-secondary/40 font-medium">Weight</td>
                    <td class="px-4 py-3">{product.weight}</td>
                  </tr>
                )}
                {product.colors && product.colors.length > 0 && (
                  <tr>
                    <td class="px-4 py-3 bg-secondary/40 font-medium">Colors</td>
                    <td class="px-4 py-3">{product.colors.join(', ')}</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>

          <!-- Technical Specifications (imf-derived 15-field spec, 7-9) -->
          {detail?.technicalSpecs && (
            <details class="border border-border rounded-lg mb-6 group">
              <summary class="px-4 py-3 bg-secondary/30 font-medium cursor-pointer flex items-center justify-between text-sm">
                <span>Technical Specifications <span class="text-xs text-muted-foreground ml-2">(15 fields per imfieldcashmere model)</span></span>
                <span class="text-brand-gold text-xl group-open:rotate-45 transition-transform">+</span>
              </summary>
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <tbody>
                    {product.collar && (
                      <tr class="border-t border-border">
                        <td class="px-4 py-2 bg-secondary/20 font-medium">Collar</td>
                        <td class="px-4 py-2">{product.collar}</td>
                      </tr>
                    )}
                    {product.sampleCost && (
                      <tr class="border-t border-border">
                        <td class="px-4 py-2 bg-secondary/20 font-medium">Sample Cost</td>
                        <td class="px-4 py-2">{product.sampleCost}</td>
                      </tr>
                    )}
                    {product.packaging && (
                      <tr class="border-t border-border">
                        <td class="px-4 py-2 bg-secondary/20 font-medium">Packaging</td>
                        <td class="px-4 py-2">{product.packaging}</td>
                      </tr>
                    )}
                    {detail.technicalSpecs.material && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium w-2/5">Material</td><td class="px-4 py-2">{detail.technicalSpecs.material[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.knitting && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">Knitting Technology</td><td class="px-4 py-2">{detail.technicalSpecs.knitting[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.pattern && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">Pattern</td><td class="px-4 py-2">{detail.technicalSpecs.pattern[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.weight && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">Weight</td><td class="px-4 py-2">{detail.technicalSpecs.weight[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.sizes && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">Sizes</td><td class="px-4 py-2">{detail.technicalSpecs.sizes[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.colors && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">Color Options</td><td class="px-4 py-2">{detail.technicalSpecs.colors[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.season && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">Season</td><td class="px-4 py-2">{detail.technicalSpecs.season[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.function && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">Function</td><td class="px-4 py-2">{detail.technicalSpecs.function[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.gender && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">Gender</td><td class="px-4 py-2">{detail.technicalSpecs.gender[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.technology && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">Technology</td><td class="px-4 py-2">{detail.technicalSpecs.technology[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.elasticity && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">Elasticity</td><td class="px-4 py-2">{detail.technicalSpecs.elasticity[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.origin && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">Origin</td><td class="px-4 py-2">{detail.technicalSpecs.origin[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.careMethod && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">Care</td><td class="px-4 py-2">{detail.technicalSpecs.careMethod[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.customization && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">Customization</td><td class="px-4 py-2">{detail.technicalSpecs.customization[locale]}</td></tr>
                    )}
                    {detail.technicalSpecs.moq && (
                      <tr class="border-t border-border"><td class="px-4 py-2 bg-secondary/20 font-medium">MOQ</td><td class="px-4 py-2">{detail.technicalSpecs.moq[locale]}</td></tr>
                    )}
                  </tbody>
                </table>
              </div>
            </details>
          )}

          <!-- Tags -->
          {product.tags && product.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-6">
              {product.tags.map((tag) => (
                <span class="text-xs px-2 py-1 border border-border rounded-full">{tag}</span>
              ))}
            </div>
          )}

          <!-- CTA + same-page inquiry form toggle (imf style) -->
          <div class="flex flex-wrap gap-3 mb-3">
            <button
              type="button"
              data-inquiry-toggle
              class="inline-block px-6 py-3 bg-primary text-primary-foreground rounded-sm font-medium hover:bg-primary/90"
            >
              {t.buyCta} ▼
            </button>
            <a href={`/${locale}/factory`} class="inline-block px-6 py-3 border border-border rounded-sm hover:bg-secondary">Factory Tour</a>
            <a href={`/${locale}/contact?product=${product.id}`} class="inline-block px-6 py-3 border border-border rounded-sm hover:bg-secondary">Contact Page</a>
          </div>

          <!-- Same-page inquiry form (hidden by default) -->
          <div id="inquiry-form" class="hidden mt-6 p-6 border-2 border-primary rounded-lg bg-card">
            <h3 class="font-display text-xl mb-4">Quick Inquiry for {product.name}</h3>
            <form
              method="POST"
              action="/api/inquiry"
              class="space-y-3"
            >
              <input type="hidden" name="type" value="raw" />
              <input type="hidden" name="inquiry_type" value="raw" />
              <input type="hidden" name="product" value={product.id} />
              <input type="hidden" name="locale" value={locale} />
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <input type="text" name="name" required placeholder="Your name *" class="px-3 py-2 border border-border rounded text-sm" />
                <input type="email" name="email" required placeholder="Email *" class="px-3 py-2 border border-border rounded text-sm" />
                <input type="text" name="company" placeholder="Company" class="px-3 py-2 border border-border rounded text-sm" />
                <input type="text" name="country" placeholder="Country (US/DE/JP/...)" class="px-3 py-2 border border-border rounded text-sm" />
                <input type="tel" name="phone" placeholder="Phone / WhatsApp" class="px-3 py-2 border border-border rounded text-sm" />
                <input type="text" name="quantity" placeholder={product.moq ? `Quantity (MOQ ${product.moq})` : 'Quantity'} class="px-3 py-2 border border-border rounded text-sm" />
              </div>
              <textarea
                name="message"
                rows={3}
                placeholder={`Inquiry details for ${product.name}...`}
                class="w-full px-3 py-2 border border-border rounded text-sm"
              ></textarea>
              <div class="flex items-center gap-3">
                <button type="submit" class="px-5 py-2.5 bg-primary text-primary-foreground rounded-sm font-medium hover:bg-primary/90 text-sm">
                  Send Inquiry
                </button>
                <span class="text-xs text-muted-foreground">Reply within 24 hours · ISO 9001 + OEKO-TEX</span>
              </div>
            </form>
          </div>

          <p class="text-xs text-muted-foreground mt-4">Direct factory pricing. FOB Tianjin/Shanghai, CIF, DDP. OEM/ODM supported. ISO 9001 + OEKO-TEX certified.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7-9 expanded: imfieldcashmere-style 13-section product page -->

  {detail && (
    <>

  <!-- Section 1: Material Story -->
  {detail.materialStory && (
    <section class="py-12 bg-secondary/20">
      <div class="container-narrow max-w-3xl">
        <h2 class="font-display text-2xl font-light mb-4">Material & Craftsmanship</h2>
        <p class="text-base leading-relaxed text-foreground/80">{detail.materialStory[locale]}</p>
      </div>
    </section>
  )}

  <!-- Section 2: Manufacturing Process -->
  {detail.process && (
    <section class="py-12 bg-background">
      <div class="container-narrow max-w-3xl">
        <h2 class="font-display text-2xl font-light mb-4">Manufacturing Process</h2>
        <p class="text-base leading-relaxed text-foreground/80 mb-6">{detail.process[locale]}</p>
        {detail.processSteps && (
          <ol class="space-y-3">
            {detail.processSteps.map((step, i) => (
              <li class="flex gap-4">
                <span class="flex-shrink-0 w-8 h-8 bg-primary text-primary-foreground rounded-full flex items-center justify-center font-display text-sm">{i + 1}</span>
                <span class="text-sm leading-relaxed pt-1">{step[locale]}</span>
              </li>
            ))}
          </ol>
        )}
      </div>
    </section>
  )}

  <!-- Section 3: Custom Service (6 bullets) -->
  {detail.customServiceBullets && (
    <section class="py-12 bg-secondary/20">
      <div class="container-narrow">
        <h2 class="font-display text-2xl font-light mb-6 text-center">{detail.customServiceTitle?.[locale] || 'Custom Manufacturing Service'}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {detail.customServiceBullets.map((b) => (
            <div class="bg-card border border-border rounded-lg p-5">
              <div class="flex items-start gap-3">
                <span class="text-brand-gold text-lg">✓</span>
                <span class="text-sm leading-relaxed">{b[locale]}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Section 4: Why Choose Us (6 USPs) -->
  {detail.whyChooseBullets && (
    <section class="py-12 bg-background">
      <div class="container-narrow">
        <h2 class="font-display text-2xl font-light mb-8 text-center">{detail.whyChooseTitle?.[locale] || 'Why Choose Our Factory'}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
