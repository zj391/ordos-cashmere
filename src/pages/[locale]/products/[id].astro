      onclick="var lb=document.getElementById('image-lightbox');var i=lb.dataset.idx||0;i=parseInt(i,10);i=(i-1+lb.dataset.total)%lb.dataset.total;lb.dataset.idx=i;document.getElementById('lightbox-img').src=lb.dataset.imgs.split('|')[i];"
      class="absolute left-2 md:left-4 top-1/2 -translate-y-1/2 z-10 text-white hover:text-brand-gold w-12 h-12 bg-white/10 hover:bg-white/20 rounded-full flex items-center justify-center text-2xl"
    >
