  itemListElement: products.slice(0, 20).map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.name,
    url: `${SITE_URL}/${locale}/products/${p.id}`,
  })),
};
---

<BaseLayout locale={locale} pageKey="products" path={`/products/${slug}`} title={t.title} description={t.description} keywords={t.keywords} schema="general">
  <Navigation slot="header" locale={locale} currentPath={`/${locale}/products/${slug}`} />

  <section class="bg-brand-ink text-white py-20 md:py-28">
    <div class="container-narrow">
      <span class="text-xs tracking-[0.4em] text-brand-gold uppercase">{CATEGORY_SLUGS_DEFS[catId].name}</span>
      <h1 class="font-display text-4xl md:text-5xl font-light mt-4 mb-6">{t.h1}</h1>
      <p class="text-lg md:text-xl max-w-3xl opacity-90">{t.intro}</p>
      <ul class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-2 max-w-3xl">
        {t.bullets.map((b) => (
          <li class="flex items-start gap-2 text-sm opacity-90">
            <span class="text-brand-gold mt-1">•</span>
            <span>{b}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-background">
    <div class="container-narrow">
      <h2 class="font-display text-3xl font-light mb-8">{t.h1} — {products.length} styles</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {products.map((p) => (
          <a
            href={`/${locale}/products/${p.id}`}
            class="group block border border-border rounded-lg overflow-hidden hover:border-primary transition-colors"
          >
            <div class="aspect-square bg-secondary/30 overflow-hidden">
              <img
                src={`/products/${catId === 'hats' || catId === 'accessories' ? 'hats' : catId === 'sweaters' ? 'sweaters' : catId}/${p.images[0]}`}
                alt={p.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                loading="lazy"
              />
            </div>
            <div class="p-3">
              <h3 class="text-xs font-medium leading-snug line-clamp-2 mb-1">{p.name}</h3>
              <p class="text-[10px] text-muted-foreground">USD {p.price} · MOQ {p.moq} pcs</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <SEOFaq faqs={t.faqs} title="Frequently Asked Questions" />

  <section class="py-16 bg-brand-ink text-white">
    <div class="container-narrow text-center">
      <h2 class="font-display text-3xl font-light mb-4">Ready to order {category.name}?</h2>
      <p class="opacity-90 mb-8 max-w-2xl mx-auto">Send your inquiry with target quantity, preferred specifications, and destination country. We reply within 24 hours with FOB/CIF pricing.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`/${locale}/contact`} class="inline-block px-8 py-3 bg-brand-gold text-brand-ink rounded-sm font-medium hover:bg-brand-gold/90">Request a Quote</a>
        <a href={`/${locale}/products`} class="inline-block px-8 py-3 border border-white/30 rounded-sm hover:bg-white/10">View All Products</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" locale={locale} />
  <FloatingChatButtons slot="footer" locale={locale} />
  <CookieConsent slot="footer" locale={locale} />
</BaseLayout>