const CATEGORY_SLUGS_DEFS = {
  hats: { id: 'hats', slug: 'hats-accessories', name: 'Cashmere Hats & Beanies' },
  scarves: { id: 'scarves', slug: 'scarves', name: 'Cashmere Scarves & Wraps' },
  sweaters: { id: 'sweaters', slug: 'garment-oem', name: 'Cashmere Sweaters & Knitwear' },
  accessories: { id: 'accessories', slug: 'hats-accessories', name: 'Cashmere Accessories' },
  yarn: { id: 'yarn', slug: 'yarn', name: 'Cashmere Yarn & Fiber' },
};

// 反向：URL slug → 类别 id
const SLUG_TO_CATEGORY_DEFS = {};
for (const catId of Object.keys(CATEGORY_SLUGS_DEFS)) {
  const m = CATEGORY_SLUGS_DEFS[catId];
  if (!SLUG_TO_CATEGORY_DEFS[m.slug]) SLUG_TO_CATEGORY_DEFS[m.slug] = catId;
}

export function getStaticPaths() {
  const paths = [];
    // Astro/Rollup hoists getStaticPaths before top-level consts.
  // Recreate the maps locally so the order is guaranteed.
  const CATEGORY_SLUGS = {
    hats: { id: 'hats', slug: 'hats-accessories', name: 'Cashmere Hats & Beanies' },
    scarves: { id: 'scarves', slug: 'scarves', name: 'Cashmere Scarves & Wraps' },
    sweaters: { id: 'sweaters', slug: 'garment-oem', name: 'Cashmere Sweaters & Knitwear' },
    accessories: { id: 'accessories', slug: 'hats-accessories', name: 'Cashmere Accessories' },
    yarn: { id: 'yarn', slug: 'yarn', name: 'Cashmere Yarn & Fiber' },
  };
  const slugs = Array.from(new Set(Object.values(CATEGORY_SLUGS).map((c) => c.slug)));
  for (const locale of LOCALES) {
    for (const slug of slugs) {
      paths.push({ params: { locale, category: slug } });
    }
  }
  return paths;
}

