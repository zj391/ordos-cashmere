---
/**
 * Yarn & Fabric 产品页
 */
export const prerender = true;
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import FloatingChatButtons from '@/components/FloatingChatButtons.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import SEOFaq from '@/components/SEOFaq.astro';
import YarnFabricInquiryForm from '@/components/islands/YarnFabricInquiryForm.tsx';
import { LOCALES, type Locale, isLocale, pickLocale } from '@/lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: rawLocale } = Astro.params;
const locale = pickLocale(rawLocale);

const t: Record<string, Record<string, string>> = {
  en: {
    tagline: '02 / YARN & FABRIC',
    title: 'Cashmere Yarn\n& Woven Fabric',
    subtitle: 'Premium counts · Custom colors · Worsted & woolen processes from our spinning mill.',
    yarnTitle: 'Cashmere Yarn',
    yarnSub: 'Spun at our facility in Ordos. Counts from 26/2 to 48/2. 100% cashmere or custom blends with wool, silk, or recycled fibers.',
    fabricTitle: 'Cashmere Woven Fabric',
    fabricSub: 'Woven on Italian looms. Plain, twill, and satin weaves. From 180 g/m² (lightweight) to 450 g/m² (heavy outerwear).',
    inquiryTitle: 'Request a quotation',
    inquirySub: 'Tell us your spec. We respond with sample swatches, pricing, and lead time within 24 hours.',
  },
  cn: {
    tagline: '02 / 纱线 / 面料',
    title: '羊绒纱线\n与羊绒面料',
    subtitle: '精纺/粗纺双工艺 · 定制颜色 · 源头工厂直供',
    yarnTitle: '羊绒纱线',
    yarnSub: '鄂尔多斯工厂纺纱，26/2 至 48/2 主流支数。100% 山羊绒或与羊毛、真丝、再生纤维定制混纺。',
    fabricTitle: '羊绒面料',
    fabricSub: '意大利进口织机，平纹/斜纹/缎纹，克重 180-450 g/m² 覆盖全场景。',
    inquiryTitle: '立即询盘',
    inquirySub: '告诉我们您的规格，24 小时内回复样品小样、报价和交期。',
  },
  de: { tagline: '02 / GARN & STOFF', title: 'Kaschmirgarn\n& Webstoff', subtitle: 'Premium-Feinheiten · Sonderfarben', yarnTitle: 'Kaschmirgarn', yarnSub: '26/2 bis 48/2. 100% Kaschmir oder Mischungen.', fabricTitle: 'Kaschmir-Webstoff', fabricSub: 'Italienische Webstühle. 180-450 g/m².', inquiryTitle: 'Angebot anfordern', inquirySub: 'Antwort innerhalb von 24 Stunden.' },
  fr: { tagline: '02 / FIL & TISSU', title: 'Fil & tissu\ncachemire', subtitle: 'Titres premium · Couleurs personnalisées', yarnTitle: 'Fil cachemire', yarnSub: 'Titres 26/2 à 48/2.', fabricTitle: 'Tissu cachemire', fabricSub: 'Métiers italiens. 180-450 g/m².', inquiryTitle: 'Demander un devis', inquirySub: 'Réponse sous 24h.' },
  ja: { tagline: '02 / 糸・生地', title: 'カシミア糸\n& 織物', subtitle: 'プレミアム番手・カスタムカラー', yarnTitle: 'カシミア糸', yarnSub: '26/2〜48/2番手。', fabricTitle: 'カシミア織物', fabricSub: 'イタリア製織機。180-450 g/m²。', inquiryTitle: '見積もり依頼', inquirySub: '24時間以内に返信。' },
  kr: { tagline: '02 / 원사·직물', title: '캐시미어 원사\n& 직물', subtitle: '프리미엄 번수 · 맞춤 색상', yarnTitle: '캐시미어 원사', yarnSub: '26/2~48/2 번수.', fabricTitle: '캐시미어 직물', fabricSub: '이탈리아 제직기. 180-450 g/m².', inquiryTitle: '견적 요청', inquirySub: '24시간 이내 회신.' },
};
const T = (k: string) => t[locale]?.[k] || t.en[k] || k;

const yarnSpecs = [
  { label: locale === 'cn' ? '支数' : 'Counts', value: '26/2 · 28/2', unit: '' },
  { label: locale === 'cn' ? '细支' : 'Fine', value: '36/2 · 48/2', unit: '' },
  { label: locale === 'cn' ? '成分' : 'Composition', value: locale === 'cn' ? '100%山羊绒' : '100% Cashmere', unit: '' },
  { label: locale === 'cn' ? '混纺' : 'Blends', value: locale === 'cn' ? '羊毛/真丝' : 'Wool / Silk', unit: '' },
  { label: locale === 'cn' ? '起订量' : 'MOQ', value: '50', unit: 'kg' },
  { label: locale === 'cn' ? '交期' : 'Lead Time', value: locale === 'cn' ? '20-30' : '20-30', unit: locale === 'cn' ? '天' : 'days' },
];

const fabricSpecs = [
  { label: locale === 'cn' ? '克重' : 'Weight', value: '180-450', unit: 'g/m²' },
  { label: locale === 'cn' ? '幅宽' : 'Width', value: '150', unit: 'cm' },
  { label: locale === 'cn' ? '成分' : 'Composition', value: locale === 'cn' ? '100%山羊绒' : '100% Cashmere', unit: '' },
  { label: locale === 'cn' ? '织法' : 'Weave', value: locale === 'cn' ? '平/斜/缎' : 'Plain/Twill/Satin', unit: '' },
  { label: locale === 'cn' ? '起订量' : 'MOQ', value: '200', unit: 'm' },
  { label: locale === 'cn' ? '交期' : 'Lead Time', value: locale === 'cn' ? '30-45' : '30-45', unit: locale === 'cn' ? '天' : 'days' },
];

const IMG = {
  hero: '/images/cashmere-fiber.jpg',
  knit: '/images/knit-shawl.jpg',
};
---

<BaseLayout locale={locale} pageKey="yarnFabric" path="/yarn-fabric">
  <Navigation slot="header" locale={locale} currentPath={`/${locale}/yarn-fabric`} />

  <section class="relative bg-brand-ink text-white overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[70vh]">
      <div class="flex items-center py-20 lg:py-0 px-6 lg:pl-12 order-2 lg:order-1">
        <div class="max-w-xl">
          <div class="flex items-center gap-3 mb-8">
            <span class="h-px w-12 bg-brand-gold"></span>
            <span class="text-xs tracking-[0.4em] text-brand-gold uppercase font-medium">{T('tagline')}</span>
          </div>
          <h1 class="font-serif text-5xl md:text-7xl font-light leading-[1.05] mb-8" set:html={T('title').replace(/\n/g, '<br/>')} />
          <p class="text-lg text-white/75 leading-relaxed max-w-md font-light">{T('subtitle')}</p>
        </div>
      </div>
      <div class="relative aspect-[4/3] lg:aspect-auto overflow-hidden order-1 lg:order-2">
        <img src={IMG.hero} alt="Cashmere fiber" class="absolute inset-0 w-full h-full object-cover opacity-80" />
        <div class="absolute inset-0 bg-gradient-to-l from-transparent to-brand-ink/60"></div>
      </div>
    </div>
  </section>

  <!-- Yarn 段 -->
  <section class="py-24 md:py-32 bg-background">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-16">
        <div class="lg:col-span-5">
          <div class="flex items-center gap-3 mb-4">
            <span class="h-px w-8 bg-brand-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-brand-camel">02A</span>
          </div>
          <h2 class="font-serif text-4xl md:text-5xl font-light leading-tight mb-4">{T('yarnTitle')}</h2>
        </div>
        <div class="lg:col-span-7 lg:pt-6">
          <p class="text-muted-foreground leading-relaxed text-lg">{T('yarnSub')}</p>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-px bg-border">
        {yarnSpecs.map((s, i) => (
          <div class="bg-background p-8 md:p-10">
            <div class="text-xs tracking-[0.2em] uppercase text-muted-foreground mb-4 flex items-baseline justify-between">
              <span>{s.label}</span>
              <span class="font-serif text-sm text-brand-gold/50">{String(i+1).padStart(2,'0')}</span>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="font-serif text-3xl md:text-4xl text-brand-chocolate font-light">{s.value}</span>
              {s.unit && <span class="text-sm text-muted-foreground">{s.unit}</span>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Fabric 段：大图 + 数据 -->
  <section class="py-24 md:py-32 bg-brand-cream/50">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <div class="flex items-center gap-3 mb-4">
            <span class="h-px w-8 bg-brand-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-brand-camel">02B</span>
          </div>
          <h2 class="font-serif text-4xl md:text-5xl font-light leading-tight mb-6">{T('fabricTitle')}</h2>
          <p class="text-muted-foreground leading-relaxed text-lg mb-8">{T('fabricSub')}</p>
          <div class="grid grid-cols-2 gap-px bg-border">
            {fabricSpecs.slice(0, 4).map((s, i) => (
              <div class="bg-brand-cream/50 p-5">
                <div class="text-xs tracking-[0.2em] uppercase text-muted-foreground mb-2">{s.label}</div>
                <div class="flex items-baseline gap-1">
                  <span class="font-serif text-2xl text-brand-chocolate font-light">{s.value}</span>
                  {s.unit && <span class="text-xs text-muted-foreground">{s.unit}</span>}
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="order-1 lg:order-2 aspect-[4/5] overflow-hidden">
          <img src={IMG.knit} alt="Cashmere woven fabric" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Inquiry -->
  <section class="py-24 md:py-32 bg-background">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="h-px w-8 bg-brand-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-brand-camel">{locale === 'cn' ? '询盘' : 'Inquiry'}</span>
          </div>
          <h2 class="font-serif text-4xl md:text-5xl font-light leading-tight mb-6">{T('inquiryTitle')}</h2>
          <p class="text-muted-foreground leading-relaxed mb-8">{T('inquirySub')}</p>
          <ul class="space-y-3 text-sm text-muted-foreground">
            <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-brand-gold"></span>{locale === 'cn' ? '免费色卡 + 纱线小样' : 'Free color card + yarn sample'}</li>
            <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-brand-gold"></span>{locale === 'cn' ? 'Pantone 定制颜色' : 'Pantone custom color matching'}</li>
            <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-brand-gold"></span>{locale === 'cn' ? '小单快反 7 天打样' : 'Quick sampling in 7 days'}</li>
          </ul>
        </div>
        <div>
          <YarnFabricInquiryForm client:load locale={locale} enableAttachments={true} />
        </div>
      </div>
    </div>
  </section>

  <SEOFaq faqs={[
    locale === 'cn'
      ? { q: '羊绒纱线支数是什么意思？', a: '支数表示纱线的细度，例如26/2表示双股26支纱线。数字越大纱线越细：26/2用于厚款毛衣，36/2-48/2用于薄款内衣和春夏针织。' }
      : { q: 'What do cashmere yarn count numbers mean?', a: 'Count indicates yarn fineness. 26/2 means 2-ply 26-count yarn. Higher numbers mean finer yarn: 26/2 for thick sweaters, 36/2-48/2 for lightweight knitwear and spring/summer garments.' },
    locale === 'cn'
      ? { q: '精纺和粗纺羊绒有什么区别？', a: '精纺纱线（26/2及以上）表面光滑，适合贴身穿的高级针织；粗纺纱线（14/2-20/2）表面有绒感，保暖性更强，适合外套和冬季毛衣。' }
      : { q: 'What is the difference between worsted and woolen cashmere?', a: 'Worsted yarn (26/2+) has smooth surface, ideal for next-to-skin luxury knitwear. Woolen yarn (14/2-20/2) has fuzzy texture with stronger warmth retention, ideal for outerwear and winter sweaters.' },
  ]} />

  <Footer slot="footer" locale={locale} />
  <FloatingChatButtons slot="floating" locale={locale} />
  <CookieConsent slot="cookie-consent" locale={locale} />
</BaseLayout>
