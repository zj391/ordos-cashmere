---
/**
 * 首页 - 6 国通用模板
 * 设计语言：奢侈羊绒 + 工艺感 + 来源可追溯
 *  - 大字衬线标题（Cormorant Garamond）
 *  - 真实场景图（Unsplash）+ 自绘 SVG 装饰
 *  - 不对称布局 / 留白有节奏
 *  - 6 国翻译文案
 */
export const prerender = true;
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import FloatingChatButtons from '@/components/FloatingChatButtons.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import SEOFaq from '@/components/SEOFaq.astro';
import { LOCALES, type Locale, isLocale, pickLocale } from '@/lib/i18n';
import { SEO, SITE_INFO } from '@/lib/seo';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: rawLocale } = Astro.params;
if (!isLocale(rawLocale)) {
  return Astro.redirect('/en/');
}
const locale = pickLocale(rawLocale);

// 拿该 locale 最新 3 篇博客（首页展示用）
const allPosts = await getCollection('blog', ({ id }) => id.startsWith(`${locale}/`));
const latestPosts = allPosts
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3)
  .map((p) => ({
    slug: p.id.replace(`${locale}/`, '').replace(/\.md$/, ''),
    title: p.data.title,
    excerpt: p.data.excerpt,
    date: p.data.publishDate.toISOString().slice(0, 10),
  }));

const heroContent: Record<string, {
  tagline: string;
  title: string;
  subtitle: string;
  cta: string;
  ctaSecondary: string;
  badge: string;
  metrics: Array<{ value: string; label: string }>;
  trustTitle: string;
}> = {
  en: {
    tagline: 'SOURCE FACTORY · ORDOS · SINCE 2002',
    title: 'Premium Cashmere,\nDirect from Ordos',
    subtitle: '23+ years manufacturing raw cashmere, yarn, fabric & OEM knitwear for global B2B brands. ISO certified. 50+ countries. 1,200+ tons annual capacity.',
    cta: 'Request a Quote',
    ctaSecondary: 'Download Catalog',
    badge: 'B2B Wholesale Only',
    metrics: [
      // TODO(user): 用工厂真实数据替换占位值。
      // 当前占位基于: 2002 年成立 + 中型 B2B 羊绒出口工厂
      // 提供真实数据后修改 value + label。
      { value: '23+', label: 'Years' },
      { value: '50+', label: 'Countries' },
      { value: '1,200t', label: 'Annual Capacity' },
      { value: 'ISO 9001', label: 'Certified' },
    ],
    trustTitle: 'Certifications & Compliance',
  },
  de: {
    tagline: 'QUELLFABRIK · ORDOS · SEIT 2002',
    title: 'Premium Kaschmir,\ndirekt aus Ordos',
    subtitle: '23+ Jahre Herstellung von Rohkaschmir, Garn, Stoff und OEM-Strickwaren für globale B2B-Marken. ISO-zertifiziert. 50+ Länder. 1.200+ Tonnen Jahreskapazität.',
    cta: 'Angebot anfordern',
    ctaSecondary: 'Katalog herunterladen',
    badge: 'Nur B2B-Großhandel',
    metrics: [
      { value: '23+', label: 'Jahre' },
      { value: '50+', label: 'Länder' },
      { value: '1.200t', label: 'Jahreskapazität' },
      { value: 'ISO 9001', label: 'Zertifiziert' },
    ],
    trustTitle: 'Zertifizierungen & Compliance',
  },
  fr: {
    tagline: 'USINE SOURCE · ORDOS · DEPUIS 2002',
    title: 'Cachemire Premium,\ndirectement d\'Ordos',
    subtitle: '23+ ans de fabrication de cachemire brut, fil, tissu et tricot OEM pour marques B2B. Certifié ISO. 50+ pays. 1 200+ tonnes de capacité annuelle.',
    cta: 'Demander un devis',
    ctaSecondary: 'Télécharger le catalogue',
    badge: 'B2B uniquement',
    metrics: [
      { value: '23+', label: 'Ans' },
      { value: '50+', label: 'Pays' },
      { value: '1 200t', label: 'Capacité' },
      { value: 'ISO 9001', label: 'Certifié' },
    ],
    trustTitle: 'Certifications & Conformité',
  },
  ja: {
    tagline: '源流工場 · オルドス · 2002年創業',
    title: 'プレミアム・カシミア、\nオルドスから直送',
    subtitle: '23年以上の実績。原料カシミア、糸、生地、OEMニットをグローバルB2Bブランドへ供給。ISO認証取得。50ヶ国以上。年間生産能力1,200トン超。',
    cta: '見積もり依頼',
    ctaSecondary: 'カタログダウンロード',
    badge: 'B2B専門',
    metrics: [
      { value: '23年+', label: '業界経験' },
      { value: '50+', label: '供給国' },
      { value: '1,200t', label: '年間生産' },
      { value: 'ISO 9001', label: '認証' },
    ],
    trustTitle: '認証 & コンプライアンス',
  },
  kr: {
    tagline: '소스 팩토리 · 오르도스 · 2002년 창업',
    title: '프리미엄 캐시미어,\n오르도스에서 직송',
    subtitle: '23년 이상의 제조 경험. 원료, 원사, 직물, OEM 니트웨어를 글로벌 B2B 브랜드에 공급. ISO 인증. 50개국 이상. 연간 생산 능력 1,200톤 이상.',
    cta: '견적 요청',
    ctaSecondary: '카탈로그 다운로드',
    badge: 'B2B 전문',
    metrics: [
      { value: '23+', label: '년 경험' },
      { value: '50+', label: '공급국' },
      { value: '1,200t', label: '연간 생산' },
      { value: 'ISO 9001', label: '인증' },
    ],
    trustTitle: '인증 & 규정 준수',
  },
  cn: {
    tagline: '源头工厂 · 鄂尔多斯 · 始于2002',
    title: '高端羊绒，\n鄂尔多斯源头直供',
    subtitle: '23年专注B2B羊绒出口。原料、纱线、面料、成衣代工全产业链。ISO 9001、OEKO-TEX、GCS 认证。供应全球50+国家。年产能1,200吨。',
    cta: '立即询盘',
    ctaSecondary: '下载目录',
    badge: 'B2B源头工厂',
    metrics: [
      { value: '23年+', label: '行业经验' },
      { value: '50+', label: '供应国家' },
      { value: '1,200吨', label: '年产能' },
      { value: 'ISO 9001', label: '认证' },
    ],
    trustTitle: '资质 & 合规',
  },
};

const t = (cn: string, en: string) => locale === 'cn' ? cn : en;
const t6 = (cn: string, en: string, de: string, fr: string, ja: string, kr: string) => {
  const m: Record<string, string> = { cn, en, de, fr, ja, kr };
  return m[locale] || en;
};

// 产品矩阵数据 (B2B 关键指标 — 让访客一眼看出这是真工厂)
const productData: Record<string, Array<{ tag: string; value: string }>> = {
  en: [
    [{ tag: 'SKUs', value: '78+' }, { tag: 'MOQ', value: '100 pcs' }, { tag: 'Stock', value: 'Ready' }],
    [{ tag: 'Counts', value: '26/2 – 36/2' }, { tag: 'MOQ', value: '50 kg' }, { tag: 'Lead', value: '15 d' }],
    [{ tag: 'SKUs', value: '591+' }, { tag: 'MOQ', value: '100 pcs' }, { tag: 'OEM', value: 'Yes' }],
  ],
  de: [
    [{ tag: 'SKUs', value: '78+' }, { tag: 'MOQ', value: '100 Stk' }, { tag: 'Lager', value: 'Verfügbar' }],
    [{ tag: 'Feinheit', value: '26/2 – 36/2' }, { tag: 'MOQ', value: '50 kg' }, { tag: 'Lieferzeit', value: '15 T' }],
    [{ tag: 'SKUs', value: '591+' }, { tag: 'MOQ', value: '100 Stk' }, { tag: 'OEM', value: 'Ja' }],
  ],
  fr: [
    [{ tag: 'SKUs', value: '78+' }, { tag: 'MOQ', value: '100 pcs' }, { tag: 'Stock', value: 'Prêt' }],
    [{ tag: 'Titres', value: '26/2 – 36/2' }, { tag: 'MOQ', value: '50 kg' }, { tag: 'Délai', value: '15 j' }],
    [{ tag: 'SKUs', value: '591+' }, { tag: 'MOQ', value: '100 pcs' }, { tag: 'OEM', value: 'Oui' }],
  ],
  ja: [
    [{ tag: 'SKU', value: '78+' }, { tag: 'MOQ', value: '100枚' }, { tag: '在庫', value: '即納' }],
    [{ tag: '番手', value: '26/2 – 36/2' }, { tag: 'MOQ', value: '50kg' }, { tag: '納期', value: '15日' }],
    [{ tag: 'SKU', value: '591+' }, { tag: 'MOQ', value: '100枚' }, { tag: 'OEM', value: '可' }],
  ],
  kr: [
    [{ tag: 'SKU', value: '78+' }, { tag: 'MOQ', value: '100pcs' }, { tag: '재고', value: '즉시' }],
    [{ tag: '실수', value: '26/2 – 36/2' }, { tag: 'MOQ', value: '50kg' }, { tag: '납기', value: '15일' }],
    [{ tag: 'SKU', value: '591+' }, { tag: 'MOQ', value: '100pcs' }, { tag: 'OEM', value: '가능' }],
  ],
  cn: [
    [{ tag: 'SKU 数', value: '78+' }, { tag: '起订', value: '100件' }, { tag: '现货', value: '有' }],
    [{ tag: '支数', value: '26/2 – 36/2' }, { tag: '起订', value: '50kg' }, { tag: '交期', value: '15天' }],
    [{ tag: 'SKU 数', value: '591+' }, { tag: '起订', value: '100件' }, { tag: 'OEM', value: '支持' }],
  ],
};

const c = heroContent[locale];
const seo = SEO[locale];
const prodMeta = productData[locale];

// 占位图说明 (2026-07 redesign P0 + 7-22 升级):
//   - 用 Wikimedia Commons CC BY-SA / 公共域图片作为占位
//   - 真实工厂照就绪后, 按 docs/design-images-credits.md 替换
//   - URL 直链作为 <img src>, 等真图就绪再迁到 public/images/
// 7-22 修正: Cashmere_Factory_Gobi_33 实际是毛衣店图, 换成 Otog Qianqi Ordos
//   真实沙漠风景 + Goat in Mongolia 01 真实蒙古山羊.
const IMG = {
  // 首页 hero (针织特写, 暖色)
  heroFiber: 'https://upload.wikimedia.org/wikipedia/commons/6/66/Cashmere_Sweater.jpg',
  // Origin Story: 鄂尔多斯沙漠风景 (内蒙古 Otog Qianqi)
  ordosLandscape: 'https://upload.wikimedia.org/wikipedia/commons/d/d3/Otog_Qianqi%2C_Ordos%2C_Inner_Mongolia%2C_China_-_panoramio_%289%29.jpg',
  // Why us #1 自有牧场: 蒙古山羊在草原 (真实梳绒标记)
  mongoliaGoat: 'https://upload.wikimedia.org/wikipedia/commons/b/b1/Goat_in_Mongolia_01.jpg',
  // Why us #4 成衣厂: 历史工厂外景 (黑白, 传承感)
  knittingMill: 'https://upload.wikimedia.org/wikipedia/commons/5/53/Strutwear_Knitting_Company_Factory_-_DPLA_-_ada8cf1c32797fd4fd2696eaa0b78489.jpg',
  // 工艺证据 - 手工艺披肩
  craftHand: 'https://upload.wikimedia.org/wikipedia/commons/6/6d/Handwoven-kashmir-pashmina.jpg',
  // 工艺证据 - 披肩产品
  shawlEmbroidered: 'https://upload.wikimedia.org/wikipedia/commons/2/27/Embroidered-pashmina-shawl.jpg',
  // 工艺证据 - 编织细节
  scarfDetail: 'https://upload.wikimedia.org/wikipedia/commons/9/95/Pashmina_scarf_with_woven_elephant_design_03.jpg',
  // 工艺证据 - 折叠围巾
  scarvesFolded: 'https://upload.wikimedia.org/wikipedia/commons/e/e4/Cashmere_Wool_Scarves.jpg',
};
---

<BaseLayout locale={locale} pageKey="home" path="/" schema="home">
  <Navigation slot="header" locale={locale} currentPath={`/${locale}/`} />

  <!-- ============ HERO ============ -->
  <section class="relative bg-brand-ink text-white overflow-hidden">
    <!-- 背景工厂图 + 暗化叠层 (Ken Burns 微动画 20s loop) -->
    <div class="absolute inset-0">
      <img src={IMG.heroFiber} alt="Cashmere knitwear detail" class="w-full h-full object-cover opacity-40 ken-burns" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-ink via-brand-ink/80 to-transparent"></div>
    </div>
    <!-- 羊绒纤维纹理 -->
    <svg class="absolute inset-0 w-full h-full opacity-[0.05] pointer-events-none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <defs>
        <pattern id="fibers" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M0 30 Q15 22, 30 30 T60 30" stroke="white" stroke-width="0.5" fill="none"/>
          <path d="M0 38 Q15 30, 30 38 T60 38" stroke="white" stroke-width="0.5" fill="none"/>
          <path d="M0 22 Q15 14, 30 22 T60 22" stroke="white" stroke-width="0.5" fill="none"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#fibers)"/>
    </svg>

    <div class="relative container-narrow min-h-[88vh] flex items-center py-24">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 mb-8">
          <span class="h-px w-12 bg-brand-gold"></span>
          <span class="text-xs tracking-[0.4em] text-brand-gold uppercase font-medium">{c.tagline}</span>
        </div>
        <h1 class="font-serif text-6xl md:text-8xl font-light leading-[1.02] mb-8" set:html={c.title.replace(/\n/g, '<br/>')} />
        <p class="text-lg md:text-xl text-white/75 mb-12 leading-relaxed max-w-xl font-light">
          {c.subtitle}
        </p>
        <div class="flex flex-wrap items-center gap-6">
          <a href={`/${locale}/contact`} class="group inline-flex items-center gap-3 px-10 py-5 bg-brand-gold text-brand-ink font-medium tracking-wider hover:bg-white transition-colors">
            {c.cta}
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href={`/${locale}/download`} class="group inline-flex items-center gap-2 text-white border-b border-white/40 pb-1 hover:border-brand-gold hover:text-brand-gold transition-colors">
            {c.ctaSecondary}
          </a>
        </div>
      </div>
    </div>

    <!-- 滚动指示 -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/40 text-xs tracking-widest uppercase animate-pulse">
      Scroll
    </div>
  </section>

  <!-- ============ METRICS BAR（细线分隔） ============ -->
  <section class="border-y border-border bg-background py-12">
    <div class="container-narrow">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-0 md:divide-x md:divide-border">
        {c.metrics.map((m, i) => (
          <div class={`md:px-10 first:md:pl-0 last:md:pr-0 text-center md:text-left reveal`} data-reveal-delay={i + 1}>
            <div class="font-serif text-4xl md:text-5xl text-brand-chocolate font-light leading-none mb-2">{m.value}</div>
            <div class="text-xs tracking-[0.2em] uppercase text-muted-foreground">{m.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 产地故事（不对称：大图 + 文字） ============ -->
  <section class="py-24 md:py-32 bg-background overflow-hidden">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- 左侧大图（占 7/12） -->
        <div class="lg:col-span-7 relative reveal-left">
          <div class="aspect-[5/6] overflow-hidden hover-zoom">
            <img src={IMG.ordosLandscape} alt="Ordos plateau landscape, Inner Mongolia" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <!-- 浮动小图（地理坐标装饰） -->
          <div class="hidden md:block absolute -bottom-12 -right-12 w-48 aspect-square overflow-hidden border-8 border-background shadow-2xl bg-gradient-to-br from-brand-camel to-brand-chocolate flex items-center justify-center">
            <div class="text-center text-white">
              <div class="font-serif text-4xl text-brand-gold font-light">2002</div>
              <div class="text-[10px] tracking-[0.3em] uppercase mt-1 opacity-80">Founded</div>
            </div>
          </div>
        </div>
        <!-- 右侧文字（占 5/12，错位下沉） -->
        <div class="lg:col-span-5 lg:pl-8 lg:pt-16 reveal-right" data-reveal-delay="1">
          <div class="flex items-center gap-3 mb-6">
            <span class="h-px w-8 bg-brand-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-brand-camel">
              {t('产地溯源', 'Origin Story')}
            </span>
          </div>
          <h2 class="font-serif text-4xl md:text-5xl font-light leading-tight mb-6 text-brand-ink" set:html={t6(
            '鄂尔多斯：<br/>世界顶级羊绒产区',
            'Ordos:<br/>The World\'s Premium Cashmere Region',
            'Ordos:<br/>Premium-Kaschmirregion',
            'Ordos :<br/>Région du cachemire premium',
            'オルドス：<br/>世界の最高級カシミア産地',
            '오르도스:<br/>세계 최고급 캐시미어 산지'
          )} />
          <p class="text-muted-foreground leading-relaxed mb-8">
            {t6(
              '鄂尔多斯位于内蒙古，北纬39度，海拔1300米，年均气温6℃。独特的高原大陆性气候孕育了阿尔巴斯白绒山羊——世界顶级羊绒品种，每根纤维细度仅14.5微米。',
              'Located in Inner Mongolia at 1,300m altitude, Ordos\'s unique continental plateau climate nurtures the Albus goat — the world\'s premium cashmere breed, with each fiber measuring just 14.5 microns.',
              'Ordos liegt in der Inneren Mongolei auf 1300m Höhe. Das einzigartige Hochlandklima bringt die Albus-Kaschmirziege hervor.',
              'Ordos, située à 1300m d\'altitude en Mongolie-Intérieure, abrite la chèvre Albus.',
              'オルドスは内モンゴル、標高1300mに位置。',
              '오르도스는 내몽골 해발 1300m에 위치.'
            )}
          </p>
          <div class="space-y-3 mb-8">
            <div class="flex items-center gap-3 text-sm">
              <span class="font-serif text-2xl text-brand-gold">39°N</span>
              <span class="text-muted-foreground">{t('黄金纬度带', 'Latitude')}</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="font-serif text-2xl text-brand-gold">1,300m</span>
              <span class="text-muted-foreground">{t('平均海拔', 'Altitude')}</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="font-serif text-2xl text-brand-gold">14.5μm</span>
              <span class="text-muted-foreground">{t('纤维细度', 'Fiber Fineness')}</span>
            </div>
          </div>
          <a href={`/${locale}/ordos-origin`} class="group inline-flex items-center gap-2 text-brand-chocolate font-medium border-b border-brand-chocolate pb-1 hover:border-brand-gold hover:text-brand-gold transition-colors">
            {t6('探索鄂尔多斯产地', 'Explore Ordos Origin', 'Ordos erkunden', 'Explorer Ordos', 'オルドスを探る', '오르도스 탐험')}
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Product Range（不对称 Bento 布局） ============ -->
  <section class="py-24 md:py-32 bg-brand-cream/50">
    <div class="container-narrow">
      <!-- 段头 -->
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 gap-6">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="h-px w-8 bg-brand-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-brand-camel">
              {t6('产品矩阵', 'Product Range', 'Produktpalette', 'Gamme', '製品範囲', '제품 범위')}
            </span>
          </div>
          <h2 class="font-serif text-4xl md:text-5xl font-light leading-tight max-w-2xl">
            {t6(
              '全产业链羊绒供应',
              'Complete Cashmere Supply Chain',
              'Komplette Kaschmir-Lieferkette',
              'Chaîne complète du cachemire',
              'カシミア全産業チェーン',
              '캐시미어 전산업체인'
            )}
          </h2>
        </div>
        <a href={`/${locale}/products`} class="group inline-flex items-center gap-2 text-sm text-brand-chocolate border-b border-brand-chocolate pb-1 hover:text-brand-gold hover:border-brand-gold transition-colors">
          {t6('查看全部产品', 'View all products', 'Alle ansehen', 'Voir tout', '全て見る', '전체 보기')}
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

