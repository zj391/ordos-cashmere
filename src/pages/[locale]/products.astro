/**
 * 产品列表页 - 6 国通用
 * 全部 591 个产品 + 5 个分类，筛选/搜索/排序/弹窗用 vanilla JS 增强
 * 不依赖 React 岛（避免 Astro 5 + React 19 hydration 不兼容）
 */
export const prerender = true;
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import FloatingChatButtons from '@/components/FloatingChatButtons.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import SEOFaq from '@/components/SEOFaq.astro';
import { LOCALES, type Locale, isLocale, pickLocale } from '@/lib/i18n';
import { SEO, SITE_INFO } from '@/lib/seo';
import { products as productsData } from '@/data/products';
import { getProductLabels } from '@/lib/product-labels';
import { tagAllProducts, PRODUCT_TAG_RULES } from '@/data/product-tags';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: rawLocale } = Astro.params;
if (!isLocale(rawLocale)) {
  return Astro.redirect('/en/');
}
const locale = pickLocale(rawLocale);

// 扁平化产品列表（附加 categoryId / categoryName），用于渲染卡片
const allProducts = productsData.categories.flatMap((cat) =>
  cat.products.map((p) => ({
    ...p,
    categoryId: cat.id,
    categoryName: cat.name,
  }))
);
const categories = productsData.categories;
const labels = getProductLabels(locale);

// Pre-tag every product once at build time so URL params (e.g. ?byStyle=beanies)
// from the mega menu can filter the product grid client-side.
const productTagsMap = tagAllProducts();

// Build a serializable tags index: { productId: ["byStyle=beanies", "byMaterial=100pct-cashmere", ...] }
const productTagsJson = JSON.stringify(
  Object.fromEntries(
    Array.from(productTagsMap.entries()).map(([id, tags]) => [id, Array.from(tags)])
  )
);

