---
/**
 * 产品列表页 - 6 国通用
 * 全部 591 个产品 + 5 个分类，筛选/搜索/排序/弹窗用 vanilla JS 增强
 * 不依赖 React 岛（避免 Astro 5 + React 19 hydration 不兼容）
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import FloatingChatButtons from '@/components/FloatingChatButtons.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import SEOFaq from '@/components/SEOFaq.astro';
import { LOCALES, type Locale, isLocale, pickLocale } from '@/lib/i18n';
import { SEO, SITE_INFO } from '@/lib/seo';
import { products as productsData } from '@/data/products';
import { getProductLabels } from '@/lib/product-labels';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: rawLocale } = Astro.params;
if (!isLocale(rawLocale)) {
  return Astro.redirect('/en/');
}
const locale = pickLocale(rawLocale);

// 扁平化产品列表（附加 categoryId / categoryName），用于渲染卡片
const allProducts = productsData.categories.flatMap((cat) =>
  cat.products.map((p) => ({
    ...p,
    categoryId: cat.id,
    categoryName: cat.name,
  }))
);
const categories = productsData.categories;
const labels = getProductLabels(locale);

// 各语言 TDK
const tdk: Record<string, { title: string; description: string; keywords: string[] }> = {
  en: {
    title: 'Cashmere Products - 591 Styles | Ordos Factory Direct | DONGXIAO®',
    description: 'Browse 591 cashmere products direct from our Ordos factory: hats, scarves, sweaters, accessories, yarn. OEM/ODM supported. Factory pricing, 100% pure cashmere, ISO certified. MOQ 100pcs.',
    keywords: ['cashmere products', 'cashmere catalog', 'B2B cashmere wholesale', 'OEM cashmere', 'Ordos cashmere factory', 'cashmere hats', 'cashmere scarves', 'cashmere sweaters'],
  },
  de: {
    title: 'Kaschmirprodukte - 591 Stile | Ordos Fabrik Direkt | DONGXIAO®',
    description: '591 Kaschmirprodukte direkt aus unserer Ordos-Fabrik: Mützen, Schals, Pullover, Accessoires, Garn. OEM/ODM. Fabrikpreise, 100% reines Kaschmir, ISO-zertifiziert. MOQ 100 Stk.',
    keywords: ['Kaschmirprodukte', 'Kaschmir Katalog', 'B2B Kaschmir Großhandel', 'OEM Kaschmir', 'Ordos Kaschmirfabrik'],
  },
  fr: {
    title: 'Produits cachemire - 591 styles | Usine directe Ordos | DONGXIAO®',
    description: '591 produits cachemire directement de notre usine Ordos: bonnets, echarpes, pulls, accessoires, fils. OEM/ODM. Prix usine, 100% cachemire pur, certifie ISO. MOQ 100pcs.',
    keywords: ['produits cachemire', 'catalogue cachemire', 'B2B cachemire gros', 'OEM cachemire', 'usine cachemire Ordos'],
  },
  ja: {
    title: 'カシミヤ製品 - 591スタイル | オルdos工場直販 | DONGXIAO®',
    description: 'オルdos工場直販カシミア製品591点:帽子、マフラー、セーター、アクセサリー、糸。OEM/ODM対応。工場価格、100%ピュアカシミア、ISO認証。MOQ 100個。',
    keywords: ['カシミア製品', 'カシミアカタログ', 'B2B カシミア卸売', 'OEM カシミア'],
  },
  kr: {
    title: '캐시미어 제품 - 591가지 스타일 | 어얼어스 공장 직송 | DONGXIAO®',
    description: '어얼어스 공장에서 직접 생산하는 캐시미어 제품 591종: 모자, 스카프, 스웨터, 액세서리, 원사. OEM/ODM 지원. 공장 가격, 100% 순수 캐시미어, ISO 인증. MOQ 100개.',
    keywords: ['캐시미어 제품', '캐시미어 카탈로그', 'B2B 캐시미어 도매', 'OEM 캐시미어'],
  },
  cn: {
    title: '羊绒产品 - 591款 | 鄂尔多斯工厂直供 | 东霄DONGXIAO®',
    description: '591款羊绒产品工厂直供：帽子、围巾、毛衫、配饰、纱线。支持OEM/ODM。工厂价格，100%纯羊绒，ISO认证。起订量100件。',
    keywords: ['羊绒产品', '羊绒目录', 'B2B羊绒批发', 'OEM羊绒代工', '鄂尔多斯羊绒工厂', '羊绒帽子', '羊绒围巾', '羊绒衫'],
  },
};

const seo = tdk[locale] || tdk.en;

// 一次性把 591 个产品序列化成 JSON，inline 到 <script id="products-data">
// 给前端 vanilla JS 用（筛选/搜索/弹窗）
const productsJson = JSON.stringify(allProducts);
const categoriesJson = JSON.stringify(categories);
const labelsJson = JSON.stringify(labels);
---

<BaseLayout
  locale={locale}
  pageKey="products"
  path="/products"
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  schema="products"
>
  <Navigation slot="header" locale={locale} currentPath={`/${locale}/products`} />

  <!-- Page header -->
  <section class="bg-background border-b border-border">
    <div class="container-narrow py-12 sm:py-16">
      <div class="flex items-center gap-3 mb-4"><span class="h-px w-8 bg-brand-gold"></span><span class="text-xs tracking-[0.3em] uppercase text-brand-camel">
        {locale === 'cn' ? '工厂直供 · 全品类' : 'Factory Direct · Full Catalog'}
      </span></div>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-brand-ink mb-4">
        {labels.title}
      </h1>
      <p class="text-muted-foreground max-w-3xl leading-relaxed">
        {labels.subtitle}
      </p>
      <div class="mt-8 flex flex-wrap gap-x-8 gap-y-3 text-sm text-muted-foreground">
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
          {locale === 'cn' ? '591款产品' : '591 Products'}
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 bg-amber-700 rounded-full"></span>
          {locale === 'cn' ? '5大品类' : '5 Categories'}
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 bg-amber-700 rounded-full"></span>
          {locale === 'cn' ? 'MOQ 100件' : 'MOQ 100pcs'}
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 bg-amber-700 rounded-full"></span>
          {locale === 'cn' ? 'OEM/ODM 支持' : 'OEM/ODM Supported'}
        </span>
      </div>
    </div>
  </section>

  <!-- Filter bar (静态渲染，按钮 + 搜索 + 排序) -->
  <section class="container-narrow py-8">
    <div class="flex flex-col lg:flex-row gap-4 mb-6 lg:items-center lg:justify-between">
      <div id="filter-buttons" class="flex flex-wrap gap-2">
        <button data-cat="all" class="filter-btn px-4 py-2 text-sm border bg-stone-900 text-white border-stone-900 transition-colors">
          {labels.filterAll} ({allProducts.length})
        </button>
        {categories.map((cat) => (
          <button data-cat={cat.id} class="filter-btn px-4 py-2 text-sm border bg-white text-stone-700 border-stone-300 hover:border-stone-900 transition-colors">
            {cat.name} ({cat.products.length})
          </button>
        ))}
      </div>
      <div class="flex flex-col sm:flex-row gap-2">
        <input
          id="search-input"
          type="text"
          placeholder={labels.searchPlaceholder}
          class="px-4 py-2 text-sm border border-stone-300 bg-white focus:outline-none focus:border-stone-900 min-w-[200px]"
        />
        <select
          id="sort-select"
          class="px-4 py-2 text-sm border border-stone-300 bg-white focus:outline-none focus:border-stone-900"
        >
          {labels.sortOptions.map((opt) => (
            <option value={opt.value}>{opt.label}</option>
          ))}
        </select>
      </div>
    </div>
    <p id="result-count" class="text-sm text-stone-600 mb-4"></p>

    <!-- 591 个产品卡片（全部静态渲染，初始只显示前 24 个，其余懒加载） -->
    <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {allProducts.slice(0, 24).map((p) => (
        <div
          class="product-card bg-white border border-stone-200 overflow-hidden hover:shadow-lg transition-shadow group"
          data-id={p.id}
          data-cat={p.categoryId}
          data-name={p.name.toLowerCase()}
          data-material={(p.material || '').toLowerCase()}
          data-price={p.price}
          data-moq={p.moq}
        >
          <div class="aspect-square bg-stone-100 cursor-pointer overflow-hidden product-img-wrap">
            {p.images && p.images[0] && (
              <img
                src={`/products/mic/${p.images[0]}`}
                alt={p.name}
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            )}
          </div>
          <div class="p-4">
            <p class="text-xs text-stone-500 uppercase tracking-wider mb-1">{p.categoryName}</p>
            <h3 class="product-name text-sm font-medium text-stone-900 mb-2 line-clamp-2 cursor-pointer hover:text-amber-700">
              {p.name}
            </h3>
            <div class="space-y-1 text-xs text-stone-600 mb-3">
              <div class="flex justify-between"><span>{labels.material}:</span><span class="font-medium">{p.material}</span></div>
              <div class="flex justify-between"><span>{labels.micron}:</span><span class="font-medium">{p.micron}</span></div>
              <div class="flex justify-between"><span>{labels.price}:</span><span class="font-medium text-amber-700">${p.price} {p.currency}</span></div>
              <div class="flex justify-between"><span>{labels.moq}:</span><span class="font-medium">{p.moq} pcs</span></div>
            </div>
            {(p.colors || []).length > 0 && (
              <div class="flex flex-wrap gap-1 mb-3">
                {(p.colors || []).slice(0, 4).map((c) => (
                  <span class="text-xs px-2 py-0.5 bg-stone-100 text-stone-700 rounded">{c}</span>
                ))}
              </div>
            )}
            <button class="view-detail-btn w-full px-3 py-2 bg-stone-900 text-white text-xs hover:bg-amber-700 transition-colors">
              {labels.requestQuote}
            </button>
          </div>
        </div>
      ))}
    </div>
    <!-- 分页控件（vanilla JS 控制） -->
    <div id="pagination-wrap" class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-stone-200 pt-6">
      <p id="page-info" class="text-sm text-stone-600"></p>
      <nav id="pagination" class="flex items-center gap-1" aria-label="Pagination"></nav>
    </div>
  </section>

  <!-- 弹窗：全屏遮罩 + 居中弹窗 -->
  <div id="product-modal" class="fixed inset-0 z-[200] hidden bg-black/75 overflow-y-auto" role="dialog" aria-modal="true">
    <div class="min-h-full flex items-center justify-center p-2 sm:p-4 md:p-8" id="modal-backdrop">
      <!-- 桌面：max-h-90vh；移动：h-100dvh 撑满（避免地址栏影响） -->
      <div class="bg-white w-full max-w-5xl md:max-h-[90vh] h-[100dvh] md:h-auto flex flex-col md:flex-row overflow-hidden shadow-2xl relative" id="modal-content">
        <!-- 内容由 JS 填充 -->
      </div>
    </div>
  </div>

  <!-- SEO Content Block -->
  <section class="bg-brand-cream/30 border-t border-border">
    <div class="container-narrow py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 text-sm">
        {categories.map((cat) => (
          <div class="bg-background p-6 border border-border hover:border-brand-gold transition-colors">
            <h3 class="font-serif text-lg text-brand-ink mb-2">{cat.name}</h3>
            <p class="text-muted-foreground text-xs leading-relaxed mb-3">{cat.description}</p>
            <p class="text-xs text-brand-gold font-medium tracking-wider">
              {cat.products.length} {locale === 'cn' ? '款产品' : 'products'}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <SEOFaq faqs={[
    locale === 'cn'
      ? { q: '591款产品都支持OEM定制吗？', a: '是的。所有591款产品均支持OEM贴牌（您的品牌标签、洗水标、包装）和ODM设计开发。最小起订量100件/款，可加您的品牌元素。' }
      : { q: 'Do all 591 products support OEM customization?', a: 'Yes. All 591 products support OEM private label (your brand labels, care labels, packaging) and ODM design development. MOQ 100pcs/style, your branding can be added.' },
    locale === 'cn'
      ? { q: '起订量100件能否再少？', a: '常规款起订量100件/款/颜色。试订单可谈，但低于100件单价比标准价高30-50%，建议按标准MOQ下单以获得最优价格。' }
      : { q: 'Can MOQ be less than 100pcs?', a: 'Standard MOQ is 100pcs/style/color. Trial orders can be negotiated, but unit price will be 30-50% higher than standard. We recommend standard MOQ for best pricing.' },
    locale === 'cn'
      ? { q: '羊绒原料产地在哪里？', a: '所有原料来自内蒙古阿尔巴斯白绒山羊，14.5-16.5μm细度，从牧场到成品全链路可追溯。ISO 9001 + OEKO-TEX + GCS 认证。' }
      : { q: 'Where is your cashmere sourced?', a: 'All raw material is sourced from Inner Mongolia Albus white cashmere goats, 14.5-16.5μm fineness. Full traceability from pasture to finished product. ISO 9001 + OEKO-TEX + GCS certified.' },
    locale === 'cn'
      ? { q: '交期多久？', a: '常规款现货7天内发货，OEM定制款30-35天。提供DDP/FOB/CIF等多种贸易方式。' }
      : { q: 'What is the lead time?', a: 'Stock products ship within 7 days. OEM custom orders 30-35 days. We offer DDP/FOB/CIF trade terms.' },
  ]} />

  <!-- 隐藏的 JSON 数据源（vanilla JS 用） -->
  <script id="products-data" type="application/json" set:html={productsJson}></script>
  <script id="categories-data" type="application/json" set:html={categoriesJson}></script>
  <script id="labels-data" type="application/json" set:html={labelsJson}></script>

  <!-- 交互逻辑：vanilla JS，零依赖 -->
  <script is:inline>
    (function() {
      const products = JSON.parse(document.getElementById('products-data').textContent);
      const categories = JSON.parse(document.getElementById('categories-data').textContent);
      const labels = JSON.parse(document.getElementById('labels-data').textContent);

      const PAGE_SIZE = 24;
      let activeCat = 'all';
      let searchQ = '';
      let sortBy = 'default';
      let currentPage = 1;

      // ---------- 筛选/搜索/排序 ----------
      const filterButtons = document.querySelectorAll('#filter-buttons .filter-btn');
      filterButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          activeCat = btn.getAttribute('data-cat');
          filterButtons.forEach((b) => {
            if (b === btn) {
              b.classList.add('bg-stone-900', 'text-white', 'border-stone-900');
              b.classList.remove('bg-white', 'text-stone-700', 'border-stone-300');
            } else {
              b.classList.remove('bg-stone-900', 'text-white', 'border-stone-900');
              b.classList.add('bg-white', 'text-stone-700', 'border-stone-300');
            }
          });
          currentPage = 1;
          render();
        });
      });

      document.getElementById('search-input').addEventListener('input', (e) => {
        searchQ = e.target.value.trim().toLowerCase();
        currentPage = 1;
        render();
      });

      document.getElementById('sort-select').addEventListener('change', (e) => {
        sortBy = e.target.value;
        currentPage = 1;
        render();
      });

      function getFiltered() {
        let result = products;
        if (activeCat !== 'all') result = result.filter((p) => p.categoryId === activeCat);
        if (searchQ) {
          result = result.filter((p) =>
            (p.name && p.name.toLowerCase().includes(searchQ)) ||
            (p.id && p.id.toLowerCase().includes(searchQ)) ||
            (p.material && p.material.toLowerCase().includes(searchQ))
          );
        }
        if (sortBy === 'price-asc') {
          result = [...result].sort((a, b) => parseFloat((a.price || '0').split('-')[0]) - parseFloat((b.price || '0').split('-')[0]));
        } else if (sortBy === 'price-desc') {
          result = [...result].sort((a, b) => parseFloat((b.price || '0').split('-')[0]) - parseFloat((a.price || '0').split('-')[0]));
        } else if (sortBy === 'moq-asc') {
          result = [...result].sort((a, b) => (a.moq || 0) - (b.moq || 0));
        }
        return result;
      }

      function render() {
        const filtered = getFiltered();
        document.getElementById('result-count').textContent =
          labels.showingProducts ? labels.showingProducts(filtered.length) : ('Showing ' + filtered.length + ' products');

        const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
        if (currentPage > totalPages) currentPage = totalPages;
        const start = (currentPage - 1) * PAGE_SIZE;
        const end = start + PAGE_SIZE;
        const slice = filtered.slice(start, end);

        const grid = document.getElementById('product-grid');
        grid.innerHTML = slice.map(cardHtml).join('');

        // 分页控件
        renderPagination(filtered.length, totalPages);

        bindCardEvents();

        // 切换筛选/页码后滚到网格顶部
        const gridEl = document.getElementById('product-grid');
        if (gridEl && currentPage > 1) {
          gridEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }

      function renderPagination(total, totalPages) {
        const info = document.getElementById('page-info');
        const start = (currentPage - 1) * PAGE_SIZE + 1;
        const end = Math.min(currentPage * PAGE_SIZE, total);
        info.textContent = total > 0
          ? ('Showing ' + start + '–' + end + ' of ' + total + ' products')
          : 'No products match your filters';

        const nav = document.getElementById('pagination');
        if (totalPages <= 1) { nav.innerHTML = ''; return; }

        // 页码：显示当前 ±2，加上首页/末页/prev/next
        const pages = new Set([1, totalPages, currentPage, currentPage - 1, currentPage - 2, currentPage + 1, currentPage + 2]);
        const visiblePages = [...pages].filter((p) => p >= 1 && p <= totalPages).sort((a, b) => a - b);

        let html = '';
        // Prev
        html += pageBtnHtml('‹', currentPage > 1 ? currentPage - 1 : null, currentPage === 1);

        let last = 0;
        for (const p of visiblePages) {
          if (p - last > 1) html += '<span class="px-2 text-stone-400">…</span>';
          html += pageBtnHtml(String(p), p, false, p === currentPage);
          last = p;
        }

        // Next
        html += pageBtnHtml('›', currentPage < totalPages ? currentPage + 1 : null, currentPage === totalPages);
        nav.innerHTML = html;

        // 绑定事件
        nav.querySelectorAll('button[data-page]').forEach((b) => {
          b.addEventListener('click', () => {
            const p = parseInt(b.getAttribute('data-page'));
            if (!isNaN(p) && p !== currentPage) {
              currentPage = p;
              render();
            }
          });
        });
      }

      function pageBtnHtml(label, page, disabled, active) {
        const baseCls = 'min-w-[40px] h-10 px-3 inline-flex items-center justify-center text-sm border transition-colors';
        if (disabled) {
          return '<button disabled class="' + baseCls + ' bg-stone-50 text-stone-300 border-stone-200 cursor-not-allowed">' + label + '</button>';
        }
        if (active) {
          return '<button data-page="' + page + '" class="' + baseCls + ' bg-stone-900 text-white border-stone-900">' + label + '</button>';
        }
        return '<button data-page="' + page + '" class="' + baseCls + ' bg-white text-stone-700 border-stone-300 hover:border-stone-900 hover:text-stone-900">' + label + '</button>';
      }

      function cardHtml(p) {
        const img = (p.images && p.images[0]) ? '/products/mic/' + p.images[0] : '';
        const colors = (p.colors || []).slice(0, 4).map((c) =>
          '<span class="text-xs px-2 py-0.5 bg-stone-100 text-stone-700 rounded">' + escapeHtml(c) + '</span>'
        ).join('');
        return (
          '<div class="product-card bg-white border border-stone-200 overflow-hidden hover:shadow-lg transition-shadow group" data-id="' + escapeHtml(p.id) + '">' +
            '<div class="aspect-square bg-stone-100 cursor-pointer overflow-hidden product-img-wrap">' +
              (img ? '<img src="' + img + '" alt="' + escapeHtml(p.name) + '" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />' : '') +
            '</div>' +
            '<div class="p-4">' +
              '<p class="text-xs text-stone-500 uppercase tracking-wider mb-1">' + escapeHtml(p.categoryName || '') + '</p>' +
              '<h3 class="product-name text-sm font-medium text-stone-900 mb-2 line-clamp-2 cursor-pointer hover:text-amber-700">' + escapeHtml(p.name) + '</h3>' +
              '<div class="space-y-1 text-xs text-stone-600 mb-3">' +
                '<div class="flex justify-between"><span>' + escapeHtml(labels.material) + ':</span><span class="font-medium">' + escapeHtml(p.material || '') + '</span></div>' +
                '<div class="flex justify-between"><span>' + escapeHtml(labels.micron) + ':</span><span class="font-medium">' + escapeHtml(p.micron || '') + '</span></div>' +
                '<div class="flex justify-between"><span>' + escapeHtml(labels.price) + ':</span><span class="font-medium text-amber-700">$' + escapeHtml(p.price || '') + ' ' + escapeHtml(p.currency || '') + '</span></div>' +
                '<div class="flex justify-between"><span>' + escapeHtml(labels.moq) + ':</span><span class="font-medium">' + (p.moq || 0) + ' pcs</span></div>' +
              '</div>' +
              (colors ? '<div class="flex flex-wrap gap-1 mb-3">' + colors + '</div>' : '') +
              '<button class="view-detail-btn w-full px-3 py-2 bg-stone-900 text-white text-xs hover:bg-amber-700 transition-colors">' + escapeHtml(labels.requestQuote) + '</button>' +
            '</div>' +
          '</div>'
        );
      }

      function escapeHtml(s) {
        if (s == null) return '';
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      // ---------- 弹窗 ----------
      const modal = document.getElementById('product-modal');
      const modalContent = document.getElementById('modal-content');
      const modalBackdrop = document.getElementById('modal-backdrop');

      function bindCardEvents() {
        document.querySelectorAll('.product-card .product-img-wrap, .product-card .product-name, .product-card .view-detail-btn').forEach((el) => {
          el.addEventListener('click', (e) => {
            const card = e.currentTarget.closest('.product-card');
            const id = card.getAttribute('data-id');
            const product = products.find((p) => p.id === id);
            if (product) openModal(product);
          });
        });
      }

      // 颜色名 → 大致色相（hash 后映射到一组固定颜色）；不命中走灰色
      // 仅用于「文字色名 + 圆色块」的视觉化兜底（products.json 颜色都是文字）
      const COLOR_PALETTE = [
        '#1f2937', // 黑
        '#f5f5f4', // 白
        '#7c2d12', // 棕
        '#9a3412', // 焦糖
        '#a16207', // 驼
        '#365314', // 墨绿
        '#1e3a8a', // 藏青
        '#7e22ce', // 紫
        '#9f1239', // 酒红
        '#b91c1c', // 红
        '#ca8a04', // 芥末
        '#52525b', // 灰
      ];
      const COLOR_KEYWORDS = [
        ['black', '黑'], ['white', '白', 'ivory', 'cream'], ['brown', '棕', 'chocolate'], ['tan', 'caramel', '焦糖', 'beige'],
        ['camel', '驼', 'khaki'], ['green', 'forest', '墨绿', 'olive'],
        ['navy', '藏青', 'blue'], ['purple', '紫', 'lavender'], ['burgundy', 'wine', '酒红', 'maroon'],
        ['red', '红', 'crimson'], ['mustard', 'yellow', '芥末', '黄', 'gold'], ['grey', 'gray', '灰', 'silver'],
      ];
      function colorNameToHex(name) {
        const s = (name || '').toLowerCase();
        for (let i = 0; i < COLOR_KEYWORDS.length; i++) {
          for (const kw of COLOR_KEYWORDS[i]) {
            if (s.includes(kw)) return COLOR_PALETTE[i];
          }
        }
        return null; // 命中不了（如「多种颜色可选」）走文字 fallback
      }
      function swatchHtml(name) {
        const hex = colorNameToHex(name);
        const isLight = hex === '#f5f5f4' || hex === '#ca8a04';
        const ring = isLight ? 'ring-1 ring-stone-300' : '';
        const chip = hex
          ? '<span class="inline-block w-4 h-4 rounded-full ' + ring + '" style="background:' + hex + '"></span>'
          : '<span class="inline-block w-4 h-4 rounded-full bg-stone-200 border border-dashed border-stone-400"></span>';
        return '<span class="inline-flex items-center gap-1.5 text-xs px-2.5 py-1 bg-stone-50 text-stone-700 border border-stone-200">' +
                 chip + '<span>' + escapeHtml(name) + '</span>' +
               '</span>';
      }

      // 内联 SVG 图标（specs 行首），零依赖
      function specIcon(kind) {
        const common = 'class="w-3.5 h-3.5 text-stone-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"';
        if (kind === 'material') return '<svg ' + common + '><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 6h16M4 12h16M4 18h10"/></svg>';
        if (kind === 'micron')   return '<svg ' + common + '><circle cx="12" cy="12" r="8" stroke-width="1.8"/><circle cx="12" cy="12" r="3" stroke-width="1.8" fill="currentColor"/></svg>';
        if (kind === 'lead')     return '<svg ' + common + '><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 8v4l3 2M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>';
        if (kind === 'sample')   return '<svg ' + common + '><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M20 7l-8 8-4-4M20 7v6h-6"/></svg>';
        if (kind === 'weight')   return '<svg ' + common + '><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 6h18l-2 13H5L3 6zM8 6V4a4 4 0 018 0v2"/></svg>';
        return '';
      }
      // 规格表行：图标 + label + value
      function specRowIcon(icon, label, value) {
        if (!value) return '';
        return '<div class="flex items-start gap-2 py-1.5">' +
                 specIcon(icon) +
                 '<div class="min-w-0 flex-1">' +
                   '<dt class="text-[11px] uppercase tracking-wider text-stone-500 leading-none mb-0.5">' + escapeHtml(label) + '</dt>' +
                   '<dd class="text-sm text-stone-900 font-medium leading-snug">' + escapeHtml(value) + '</dd>' +
                 '</div>' +
               '</div>';
      }

      function openModal(p) {
        const images = (p.images || []);
        const mainImg = images[0] ? '/products/mic/' + images[0] : '';

        // 缩略图：图片缩略 + 视频 / 360° 占位（灰显，无后端资源先做视觉占位）
        const imgThumbs = images.map((img, i) =>
          '<button class="modal-thumb group/thumb relative flex-shrink-0 w-16 h-16 border ' + (i === 0 ? 'border-amber-700 ring-1 ring-amber-700' : 'border-stone-200 hover:border-stone-900') + ' transition-colors overflow-hidden" data-i="' + i + '" title="' + escapeHtml(p.name) + ' #' + (i+1) + '">' +
            '<img src="/products/mic/' + img + '" alt="' + escapeHtml(p.name) + ' ' + (i+1) + '" class="w-full h-full object-cover" />' +
            '<span class="absolute bottom-0 right-0 px-1 text-[9px] leading-tight bg-black/60 text-white">' + (i+1) + '/' + images.length + '</span>' +
          '</button>'
        ).join('');
        // 视频/360° 占位（data-i="video" / "360"，点击不做事只视觉占位）
        const mediaSlots =
          '<button class="modal-media-slot flex-shrink-0 w-16 h-16 border border-dashed border-stone-300 bg-stone-50 flex flex-col items-center justify-center text-stone-500 hover:border-stone-500 hover:text-stone-700 transition-colors" data-kind="video" title="Product video (coming soon)">' +
            '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>' +
            '<span class="text-[9px] mt-0.5">Video</span>' +
          '</button>' +
          '<button class="modal-media-slot flex-shrink-0 w-16 h-16 border border-dashed border-stone-300 bg-stone-50 flex flex-col items-center justify-center text-stone-500 hover:border-stone-500 hover:text-stone-700 transition-colors" data-kind="360" title="360° view (coming soon)">' +
            '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 8c0-2 3.5-4 8-4s8 2 8 4-3.5 4-8 4-8-2-8-4zM4 8v8c0 2 3.5 4 8 4s8-2 8-4V8M12 12v8"/></svg>' +
            '<span class="text-[9px] mt-0.5">360°</span>' +
          '</button>';

        // 颜色：色块 + 文字（products.json 颜色字段是文字名）
        const colors = (p.colors || []).map(swatchHtml).join('');

        // 左栏：图片画廊（独立滚动）；右栏：产品信息（独立滚动）
        modalContent.innerHTML = (
          // 左栏 - 图片区（60% 宽：md:basis-3/5；移动端固定 240px 高度）
          '<div class="relative bg-stone-50 flex flex-col h-60 md:h-auto md:basis-3/5 md:flex-1 flex-shrink-0">' +
            // 关闭按钮：左上图层
            '<button id="modal-close" class="absolute top-3 right-3 z-10 w-9 h-9 inline-flex items-center justify-center bg-white/90 hover:bg-white text-stone-700 hover:text-stone-900 text-xl leading-none rounded-full shadow-md transition-colors" aria-label="' + escapeHtml(labels.closeButton) + '">×</button>' +
            // 主图
            '<div id="modal-main-img" class="flex-1 flex items-center justify-center p-6 md:p-8 min-h-[280px] cursor-zoom-in" data-zoom="open">' +
              (mainImg ? '<img src="' + mainImg + '" alt="' + escapeHtml(p.name) + '" class="max-w-full max-h-[55vh] object-contain" />' : '<div class="text-stone-300">No image</div>') +
            '</div>' +
            // 缩略图 + 媒体占位（横向滚动）
            '<div class="flex gap-2 px-4 pb-4 overflow-x-auto">' +
              imgThumbs + mediaSlots +
            '</div>' +
          '</div>' +

          // 右栏 - 信息（40% 宽：md:basis-2/5）
          '<div class="relative flex flex-col overflow-hidden min-h-0 md:basis-2/5 md:flex-1 md:min-h-0">' +
            // 内容区：占据中间所有空间，内部滚动
            // pb-40 给底部 CTA 留 160px 空间（避免文字被 CTA 盖住）
            '<div class="flex-1 overflow-y-auto p-6 sm:p-8 pb-40 min-h-0">' +
              // 分类 + 标题 + ID
              '<p class="text-xs text-stone-500 uppercase tracking-[0.2em] mb-2">' + escapeHtml(p.categoryName || '') + '</p>' +
              '<h2 class="text-xl sm:text-2xl font-serif text-stone-900 leading-tight mb-2">' + escapeHtml(p.name) + '</h2>' +
              '<p class="text-xs text-stone-500 mb-5">' + escapeHtml(labels.productIdLabel) + ': <span class="font-mono">' + escapeHtml(p.id) + '</span></p>' +

              // 价格 + MOQ 大字突出
              '<div class="flex items-baseline gap-4 mb-6 pb-5 border-b border-stone-200">' +
                '<div>' +
                  '<p class="text-xs text-stone-500 uppercase tracking-wider mb-1">' + escapeHtml(labels.price) + '</p>' +
                  '<p class="text-2xl font-serif text-amber-700">$' + escapeHtml(p.price || '') + '</p>' +
                '</div>' +
                '<div class="w-px h-10 bg-stone-200"></div>' +
                '<div>' +
                  '<p class="text-xs text-stone-500 uppercase tracking-wider mb-1">' + escapeHtml(labels.moq) + '</p>' +
                  '<p class="text-lg font-medium text-stone-900">' + (p.moq || 0) + ' <span class="text-xs text-stone-500">pcs</span></p>' +
                '</div>' +
              '</div>' +

              // 规格表：图标 + 标签 + 值（行式布局，更紧凑）
              '<div class="mb-5">' +
                '<h3 class="text-sm font-medium text-stone-900 mb-3">' + escapeHtml(labels.productSpecs) + '</h3>' +
                '<div class="divide-y divide-stone-100 border border-stone-200 rounded-md px-3 bg-white">' +
                  specRowIcon('material', labels.material, p.material) +
                  specRowIcon('micron',   labels.micron,   p.micron) +
                  specRowIcon('lead',     labels.leadTime,    p.lead) +
                  specRowIcon('sample',   labels.sampleTime,  p.sample_time) +
                  specRowIcon('weight',   'Weight',           p.weight) +
                '</div>' +
              '</div>' +

              // 颜色：色块 + 文字
              (colors ? '<div class="mb-5"><p class="text-xs text-stone-500 uppercase tracking-wider mb-2">' + escapeHtml(labels.colors) + '</p><div class="flex flex-wrap gap-2">' + colors + '</div></div>' : '') +

              // 描述
              (p.description ? '<div class="mb-6"><p class="text-sm text-stone-700 leading-relaxed">' + escapeHtml(p.description) + '</p></div>' : '') +
            '</div>' +

            // 底部 CTA：position absolute 浮在右栏底部，scroll 内容时不动
            // 高度 ≈ prev/next(28) + mb-3(12) + button(48) + mt-2(8) + p(16+16) + note(16) ≈ 144px；用 pb-40 留 160px 缓冲
            '<div class="absolute bottom-0 left-0 right-0 p-4 sm:p-6 border-t border-stone-200 bg-white shadow-[0_-4px_12px_-2px_rgba(0,0,0,0.06)] z-10">' +
              // 上一个/下一个 导航
              '<div class="flex items-center justify-between gap-3 mb-3">' +
                '<button id="modal-prev" class="flex items-center gap-1 text-xs text-stone-600 hover:text-stone-900 transition-colors disabled:opacity-30 disabled:cursor-not-allowed" aria-label="Previous product">' +
                  '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>' +
                  '<span>Previous</span>' +
                '</button>' +
                '<button id="modal-next" class="flex items-center gap-1 text-xs text-stone-600 hover:text-stone-900 transition-colors disabled:opacity-30 disabled:cursor-not-allowed" aria-label="Next product">' +
                  '<span>Next</span>' +
                  '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>' +
                '</button>' +
              '</div>' +
              '<button id="modal-inquiry" class="w-full px-6 py-3 bg-amber-700 text-white hover:bg-amber-800 transition-colors font-medium tracking-wide">' + escapeHtml(labels.requestInquiry) + '</button>' +
              '<p class="text-xs text-stone-500 text-center mt-2">' + escapeHtml(labels.inquiryNote) + '</p>' +
            '</div>' +
          '</div>'
        );

        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';

        // Close handlers
        document.getElementById('modal-close').addEventListener('click', closeModal);
        modalBackdrop.addEventListener('click', (e) => {
          if (e.target === modalBackdrop) closeModal();
        });

        // Thumbnails（图片缩略图）
        modalContent.querySelectorAll('.modal-thumb').forEach((t) => {
          t.addEventListener('click', () => {
            const i = parseInt(t.getAttribute('data-i'));
            const newImg = '/products/mic/' + images[i];
            const mainImgEl = modalContent.querySelector('#modal-main-img img');
            if (mainImgEl) mainImgEl.src = newImg;
            modalContent.querySelectorAll('.modal-thumb').forEach((tt, idx) => {
              const active = idx === i;
              tt.classList.toggle('border-amber-700', active);
              tt.classList.toggle('ring-1', active);
              tt.classList.toggle('ring-amber-700', active);
              tt.classList.toggle('border-stone-200', !active);
            });
          });
        });

        // 媒体占位点击：闪一下 toast 提示（不做事，等以后接视频/360°）
        modalContent.querySelectorAll('.modal-media-slot').forEach((s) => {
          s.addEventListener('click', () => {
            const kind = s.getAttribute('data-kind');
            const msg = kind === 'video' ? 'Product video coming soon' : '360° view coming soon';
            showToast(msg);
          });
        });

        // 主图点击 → 简版 lightbox（关弹窗前先关 lightbox）
        const mainImgWrap = modalContent.querySelector('#modal-main-img');
        if (mainImgWrap && mainImg) {
          mainImgWrap.addEventListener('click', () => {
            openLightbox(mainImg, p.name);
          });
        }

        // Inquiry → /contact?subject=...&body=...
        document.getElementById('modal-inquiry').addEventListener('click', () => {
          const subject = encodeURIComponent('Inquiry: ' + p.name + ' (' + p.id + ')');
          const body = encodeURIComponent(
            'Hi,\n\nI\'m interested in: ' + p.name + '\nProduct ID: ' + p.id + '\nCategory: ' + (p.categoryName || '') + '\nMaterial: ' + (p.material || '') + '\nMOQ: ' + (p.moq || 0) + ' pcs\n\nPlease send me more details, pricing, and lead time.\n\nThank you.'
          );
          window.location.href = '/contact?subject=' + subject + '&body=' + body;
        });

        // Prev / Next：在当前 filtered 列表里切换
        const filteredNow = getFiltered();
        const idx = filteredNow.findIndex((x) => x.id === p.id);
        const prevBtn = document.getElementById('modal-prev');
        const nextBtn = document.getElementById('modal-next');
        if (idx <= 0) prevBtn.disabled = true;
        if (idx >= filteredNow.length - 1) nextBtn.disabled = true;
        prevBtn.addEventListener('click', () => {
          if (idx > 0) openModal(filteredNow[idx - 1]);
        });
        nextBtn.addEventListener('click', () => {
          if (idx < filteredNow.length - 1) openModal(filteredNow[idx + 1]);
        });
      }

      function specRow(label, value) {
        if (!value) return '';
        return '<dt class="text-xs text-stone-500">' + escapeHtml(label) + '</dt>' +
               '<dd class="text-sm text-stone-900 font-medium">' + escapeHtml(value) + '</dd>';
      }

      function closeModal() {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
      }

      // ---------- Lightbox（主图点击放大）+ Toast ----------
      // Lightbox 节点 lazy 注入
      let lightboxEl = null;
      function openLightbox(src, alt) {
        if (!lightboxEl) {
          lightboxEl = document.createElement('div');
          lightboxEl.id = 'lightbox';
          lightboxEl.className = 'fixed inset-0 z-[300] bg-black/90 flex items-center justify-center p-4 cursor-zoom-out';
          lightboxEl.innerHTML = '<img class="max-w-full max-h-full object-contain" />';
          lightboxEl.addEventListener('click', closeLightbox);
          document.body.appendChild(lightboxEl);
        }
        lightboxEl.querySelector('img').src = src;
        lightboxEl.querySelector('img').alt = alt || '';
        lightboxEl.classList.remove('hidden');
        lightboxEl.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      }
      function closeLightbox() {
        if (!lightboxEl) return;
        lightboxEl.style.display = 'none';
        // 还原 modal 锁定的 scroll（如果 modal 仍开着）
        if (!modal.classList.contains('hidden')) {
          document.body.style.overflow = 'hidden';
        } else {
          document.body.style.overflow = '';
        }
      }

      // Toast 节点 lazy 注入
      let toastEl = null;
      let toastTimer = null;
      function showToast(msg) {
        if (!toastEl) {
          toastEl = document.createElement('div');
          toastEl.id = 'app-toast';
          toastEl.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-[400] px-4 py-2 bg-stone-900 text-white text-sm rounded-md shadow-lg transition-opacity duration-200 opacity-0 pointer-events-none';
          document.body.appendChild(toastEl);
        }
        toastEl.textContent = msg;
        // force reflow then fade in
        toastEl.style.opacity = '0';
        requestAnimationFrame(() => {
          toastEl.style.opacity = '1';
        });
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => {
          toastEl.style.opacity = '0';
        }, 1800);
      }

      // ESC 关闭，← → 切换产品
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          // 优先关 lightbox，再关 modal
          if (lightboxEl && lightboxEl.style.display !== 'none') { closeLightbox(); return; }
          if (!modal.classList.contains('hidden')) { closeModal(); return; }
          return;
        }
        if (modal.classList.contains('hidden')) return;
        const prevBtn = document.getElementById('modal-prev');
        const nextBtn = document.getElementById('modal-next');
        if (e.key === 'ArrowLeft' && prevBtn && !prevBtn.disabled) prevBtn.click();
        if (e.key === 'ArrowRight' && nextBtn && !nextBtn.disabled) nextBtn.click();
      });

      // 初次渲染：SSR 已渲染 24 张卡片 + 分页
      bindCardEvents(); // 绑定卡片 click → openModal
      (function initPagination() {
        const total = products.length;
        const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
        currentPage = 1;
        renderPagination(total, totalPages);
      })();
    })();
  </script>

  <Footer slot="footer" locale={locale} />
  <FloatingChatButtons slot="floating" locale={locale} />
  <CookieConsent slot="cookie-consent" locale={locale} />
</BaseLayout>
</content>
</invoke>