---
/**
 * 产品列表页 - 6 国通用
 * 全部 591 个产品 + 5 个分类，筛选/搜索/排序/弹窗用 vanilla JS 增强
 * 不依赖 React 岛（避免 Astro 5 + React 19 hydration 不兼容）
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import FloatingChatButtons from '@/components/FloatingChatButtons.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import SEOFaq from '@/components/SEOFaq.astro';
import { LOCALES, type Locale, isLocale, pickLocale } from '@/lib/i18n';
import { SEO, SITE_INFO } from '@/lib/seo';
import { products as productsData } from '@/data/products';
import { getProductLabels } from '@/lib/product-labels';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: rawLocale } = Astro.params;
if (!isLocale(rawLocale)) {
  return Astro.redirect('/en/');
}
const locale = pickLocale(rawLocale);

// 扁平化产品列表（附加 categoryId / categoryName），用于渲染卡片
const allProducts = productsData.categories.flatMap((cat) =>
  cat.products.map((p) => ({
    ...p,
    categoryId: cat.id,
    categoryName: cat.name,
  }))
);
const categories = productsData.categories;
const labels = getProductLabels(locale);

// 各语言 TDK
const tdk: Record<string, { title: string; description: string; keywords: string[] }> = {
  en: {
    title: 'Cashmere Products - 591 Styles | Ordos Factory Direct | DONGXIAO®',
    description: 'Browse 591 cashmere products direct from our Ordos factory: hats, scarves, sweaters, accessories, yarn. OEM/ODM supported. Factory pricing, 100% pure cashmere, ISO certified. MOQ 100pcs.',
    keywords: ['cashmere products', 'cashmere catalog', 'B2B cashmere wholesale', 'OEM cashmere', 'Ordos cashmere factory', 'cashmere hats', 'cashmere scarves', 'cashmere sweaters'],
  },
  de: {
    title: 'Kaschmirprodukte - 591 Stile | Ordos Fabrik Direkt | DONGXIAO®',
    description: '591 Kaschmirprodukte direkt aus unserer Ordos-Fabrik: Mützen, Schals, Pullover, Accessoires, Garn. OEM/ODM. Fabrikpreise, 100% reines Kaschmir, ISO-zertifiziert. MOQ 100 Stk.',
    keywords: ['Kaschmirprodukte', 'Kaschmir Katalog', 'B2B Kaschmir Großhandel', 'OEM Kaschmir', 'Ordos Kaschmirfabrik'],
  },
  fr: {
    title: 'Produits cachemire - 591 styles | Usine directe Ordos | DONGXIAO®',
    description: '591 produits cachemire directement de notre usine Ordos: bonnets, echarpes, pulls, accessoires, fils. OEM/ODM. Prix usine, 100% cachemire pur, certifie ISO. MOQ 100pcs.',
    keywords: ['produits cachemire', 'catalogue cachemire', 'B2B cachemire gros', 'OEM cachemire', 'usine cachemire Ordos'],
  },
  ja: {
    title: 'カシミヤ製品 - 591スタイル | オルdos工場直販 | DONGXIAO®',
    description: 'オルdos工場直販カシミア製品591点:帽子、マフラー、セーター、アクセサリー、糸。OEM/ODM対応。工場価格、100%ピュアカシミア、ISO認証。MOQ 100個。',
    keywords: ['カシミア製品', 'カシミアカタログ', 'B2B カシミア卸売', 'OEM カシミア'],
  },
  kr: {
    title: '캐시미어 제품 - 591가지 스타일 | 어얼어스 공장 직송 | DONGXIAO®',
    description: '어얼어스 공장에서 직접 생산하는 캐시미어 제품 591종: 모자, 스카프, 스웨터, 액세서리, 원사. OEM/ODM 지원. 공장 가격, 100% 순수 캐시미어, ISO 인증. MOQ 100개.',
    keywords: ['캐시미어 제품', '캐시미어 카탈로그', 'B2B 캐시미어 도매', 'OEM 캐시미어'],
  },
  cn: {
    title: '羊绒产品 - 591款 | 鄂尔多斯工厂直供 | 东霄DONGXIAO®',
    description: '591款羊绒产品工厂直供：帽子、围巾、毛衫、配饰、纱线。支持OEM/ODM。工厂价格，100%纯羊绒，ISO认证。起订量100件。',
    keywords: ['羊绒产品', '羊绒目录', 'B2B羊绒批发', 'OEM羊绒代工', '鄂尔多斯羊绒工厂', '羊绒帽子', '羊绒围巾', '羊绒衫'],
  },
};

const seo = tdk[locale] || tdk.en;

// 一次性把 591 个产品序列化成 JSON，inline 到 <script id="products-data">
// 给前端 vanilla JS 用（筛选/搜索/弹窗）
const productsJson = JSON.stringify(allProducts);
const categoriesJson = JSON.stringify(categories);
const labelsJson = JSON.stringify(labels);
---

<BaseLayout
  locale={locale}
  pageKey="products"
  path="/products"
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  schema="products"
>
  <Navigation slot="header" locale={locale} currentPath={`/${locale}/products`} />

  <!-- Page header -->
  <section class="bg-background border-b border-border">
    <div class="container-narrow py-12 sm:py-16">
      <div class="flex items-center gap-3 mb-4"><span class="h-px w-8 bg-brand-gold"></span><span class="text-xs tracking-[0.3em] uppercase text-brand-camel">
        {locale === 'cn' ? '工厂直供 · 全品类' : 'Factory Direct · Full Catalog'}
      </span></div>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-brand-ink mb-4">
        {labels.title}
      </h1>
      <p class="text-muted-foreground max-w-3xl leading-relaxed">
        {labels.subtitle}
      </p>
      <div class="mt-8 flex flex-wrap gap-x-8 gap-y-3 text-sm text-muted-foreground">
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
          {locale === 'cn' ? '591款产品' : '591 Products'}
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 bg-amber-700 rounded-full"></span>
          {locale === 'cn' ? '5大品类' : '5 Categories'}
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 bg-amber-700 rounded-full"></span>
          {locale === 'cn' ? 'MOQ 100件' : 'MOQ 100pcs'}
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 bg-amber-700 rounded-full"></span>
          {locale === 'cn' ? 'OEM/ODM 支持' : 'OEM/ODM Supported'}
        </span>
      </div>
    </div>
  </section>

  <!-- Filter bar (静态渲染，按钮 + 搜索 + 排序) -->
  <section class="container-narrow py-8">
    <div class="flex flex-col lg:flex-row gap-4 mb-6 lg:items-center lg:justify-between">
      <div id="filter-buttons" class="flex flex-wrap gap-2">
        <button data-cat="all" class="filter-btn px-4 py-2 text-sm border bg-stone-900 text-white border-stone-900 transition-colors">
          {labels.filterAll} ({allProducts.length})
        </button>
        {categories.map((cat) => (
          <button data-cat={cat.id} class="filter-btn px-4 py-2 text-sm border bg-white text-stone-700 border-stone-300 hover:border-stone-900 transition-colors">
            {cat.name} ({cat.products.length})
          </button>
        ))}
      </div>
      <div class="flex flex-col sm:flex-row gap-2">
        <input
          id="search-input"
          type="text"
          placeholder={labels.searchPlaceholder}
          class="px-4 py-2 text-sm border border-stone-300 bg-white focus:outline-none focus:border-stone-900 min-w-[200px]"
        />
        <select
          id="sort-select"
          class="px-4 py-2 text-sm border border-stone-300 bg-white focus:outline-none focus:border-stone-900"
        >
          {labels.sortOptions.map((opt) => (
            <option value={opt.value}>{opt.label}</option>
          ))}
        </select>
      </div>
    </div>
    <p id="result-count" class="text-sm text-stone-600 mb-4"></p>

    <!-- 591 个产品卡片（全部静态渲染，初始只显示前 24 个，其余懒加载） -->
    <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {allProducts.slice(0, 24).map((p) => (
        <div
          class="product-card bg-white border border-stone-200 overflow-hidden hover:shadow-lg transition-shadow group"
          data-id={p.id}
          data-cat={p.categoryId}
          data-name={p.name.toLowerCase()}
          data-material={(p.material || '').toLowerCase()}
          data-price={p.price}
          data-moq={p.moq}
        >
          <div class="aspect-square bg-stone-100 cursor-pointer overflow-hidden product-img-wrap">
            {p.images && p.images[0] && (
              <img
                src={`/products/mic/${p.images[0]}`}
                alt={p.name}
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            )}
          </div>
          <div class="p-4">
            <p class="text-xs text-stone-500 uppercase tracking-wider mb-1">{p.categoryName}</p>
            <h3 class="product-name text-sm font-medium text-stone-900 mb-2 line-clamp-2 cursor-pointer hover:text-amber-700">
              {p.name}
            </h3>
            <div class="space-y-1 text-xs text-stone-600 mb-3">
              <div class="flex justify-between"><span>{labels.material}:</span><span class="font-medium">{p.material}</span></div>
              <div class="flex justify-between"><span>{labels.micron}:</span><span class="font-medium">{p.micron}</span></div>
              <div class="flex justify-between"><span>{labels.price}:</span><span class="font-medium text-amber-700">${p.price} {p.currency}</span></div>
              <div class="flex justify-between"><span>{labels.moq}:</span><span class="font-medium">{p.moq} pcs</span></div>
            </div>
            {(p.colors || []).length > 0 && (
              <div class="flex flex-wrap gap-1 mb-3">
                {(p.colors || []).slice(0, 4).map((c) => (
                  <span class="text-xs px-2 py-0.5 bg-stone-100 text-stone-700 rounded">{c}</span>
                ))}
              </div>
            )}
            <button class="view-detail-btn w-full px-3 py-2 bg-stone-900 text-white text-xs hover:bg-amber-700 transition-colors">
              {labels.requestQuote}
            </button>
          </div>
        </div>
      ))}
    </div>
    <div id="load-more-wrap" class="text-center mt-8 hidden">
      <button id="load-more-btn" class="px-8 py-3 bg-stone-900 text-white hover:bg-amber-700 transition-colors text-sm">
        {labels.loadMore ? labels.loadMore + ' (...)' : 'Load More'}
      </button>
    </div>
  </section>

  <!-- 弹窗：默认隐藏，由 JS 控制 -->
  <div id="product-modal" class="fixed inset-0 z-[100] hidden bg-black/70 overflow-y-auto" role="dialog">
    <div class="min-h-full flex items-center justify-center p-4" id="modal-backdrop">
      <div class="bg-white max-w-4xl w-full max-h-[90vh] overflow-y-auto" id="modal-content">
        <!-- 内容由 JS 填充 -->
      </div>
    </div>
  </div>

  <!-- SEO Content Block -->
  <section class="bg-brand-cream/30 border-t border-border">
    <div class="container-narrow py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 text-sm">
        {categories.map((cat) => (
          <div class="bg-background p-6 border border-border hover:border-brand-gold transition-colors">
            <h3 class="font-serif text-lg text-brand-ink mb-2">{cat.name}</h3>
            <p class="text-muted-foreground text-xs leading-relaxed mb-3">{cat.description}</p>
            <p class="text-xs text-brand-gold font-medium tracking-wider">
              {cat.products.length} {locale === 'cn' ? '款产品' : 'products'}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <SEOFaq faqs={[
    locale === 'cn'
      ? { q: '591款产品都支持OEM定制吗？', a: '是的。所有591款产品均支持OEM贴牌（您的品牌标签、洗水标、包装）和ODM设计开发。最小起订量100件/款，可加您的品牌元素。' }
      : { q: 'Do all 591 products support OEM customization?', a: 'Yes. All 591 products support OEM private label (your brand labels, care labels, packaging) and ODM design development. MOQ 100pcs/style, your branding can be added.' },
    locale === 'cn'
      ? { q: '起订量100件能否再少？', a: '常规款起订量100件/款/颜色。试订单可谈，但低于100件单价比标准价高30-50%，建议按标准MOQ下单以获得最优价格。' }
      : { q: 'Can MOQ be less than 100pcs?', a: 'Standard MOQ is 100pcs/style/color. Trial orders can be negotiated, but unit price will be 30-50% higher than standard. We recommend standard MOQ for best pricing.' },
    locale === 'cn'
      ? { q: '羊绒原料产地在哪里？', a: '所有原料来自内蒙古阿尔巴斯白绒山羊，14.5-16.5μm细度，从牧场到成品全链路可追溯。ISO 9001 + OEKO-TEX + GCS 认证。' }
      : { q: 'Where is your cashmere sourced?', a: 'All raw material is sourced from Inner Mongolia Albus white cashmere goats, 14.5-16.5μm fineness. Full traceability from pasture to finished product. ISO 9001 + OEKO-TEX + GCS certified.' },
    locale === 'cn'
      ? { q: '交期多久？', a: '常规款现货7天内发货，OEM定制款30-35天。提供DDP/FOB/CIF等多种贸易方式。' }
      : { q: 'What is the lead time?', a: 'Stock products ship within 7 days. OEM custom orders 30-35 days. We offer DDP/FOB/CIF trade terms.' },
  ]} />

  <!-- 隐藏的 JSON 数据源（vanilla JS 用） -->
  <script id="products-data" type="application/json" set:html={productsJson}></script>
  <script id="categories-data" type="application/json" set:html={categoriesJson}></script>
  <script id="labels-data" type="application/json" set:html={labelsJson}></script>

  <!-- 交互逻辑：vanilla JS，零依赖 -->
  <script is:inline>
    (function() {
      const products = JSON.parse(document.getElementById('products-data').textContent);
      const categories = JSON.parse(document.getElementById('categories-data').textContent);
      const labels = JSON.parse(document.getElementById('labels-data').textContent);

      const PAGE_SIZE = 24;
      let activeCat = 'all';
      let searchQ = '';
      let sortBy = 'default';
      let visibleCount = PAGE_SIZE;

      // ---------- 筛选/搜索/排序 ----------
      const filterButtons = document.querySelectorAll('#filter-buttons .filter-btn');
      filterButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          activeCat = btn.getAttribute('data-cat');
          filterButtons.forEach((b) => {
            if (b === btn) {
              b.classList.add('bg-stone-900', 'text-white', 'border-stone-900');
              b.classList.remove('bg-white', 'text-stone-700', 'border-stone-300');
            } else {
              b.classList.remove('bg-stone-900', 'text-white', 'border-stone-900');
              b.classList.add('bg-white', 'text-stone-700', 'border-stone-300');
            }
          });
          visibleCount = PAGE_SIZE;
          render();
        });
      });

      document.getElementById('search-input').addEventListener('input', (e) => {
        searchQ = e.target.value.trim().toLowerCase();
        visibleCount = PAGE_SIZE;
        render();
      });

      document.getElementById('sort-select').addEventListener('change', (e) => {
        sortBy = e.target.value;
        render();
      });

      function getFiltered() {
        let result = products;
        if (activeCat !== 'all') result = result.filter((p) => p.categoryId === activeCat);
        if (searchQ) {
          result = result.filter((p) =>
            (p.name && p.name.toLowerCase().includes(searchQ)) ||
            (p.id && p.id.toLowerCase().includes(searchQ)) ||
            (p.material && p.material.toLowerCase().includes(searchQ))
          );
        }
        if (sortBy === 'price-asc') {
          result = [...result].sort((a, b) => parseFloat((a.price || '0').split('-')[0]) - parseFloat((b.price || '0').split('-')[0]));
        } else if (sortBy === 'price-desc') {
          result = [...result].sort((a, b) => parseFloat((b.price || '0').split('-')[0]) - parseFloat((a.price || '0').split('-')[0]));
        } else if (sortBy === 'moq-asc') {
          result = [...result].sort((a, b) => (a.moq || 0) - (b.moq || 0));
        }
        return result;
      }

      function render() {
        const filtered = getFiltered();
        document.getElementById('result-count').textContent =
          labels.showingProducts ? labels.showingProducts(filtered.length) : ('Showing ' + filtered.length + ' products');

        const grid = document.getElementById('product-grid');
        const slice = filtered.slice(0, visibleCount);
        grid.innerHTML = slice.map(cardHtml).join('');

        // Load More
        const wrap = document.getElementById('load-more-wrap');
        const btn = document.getElementById('load-more-btn');
        if (filtered.length > visibleCount) {
          wrap.classList.remove('hidden');
          btn.textContent = (labels.loadMore || 'Load More') + ' (' + (filtered.length - visibleCount) + ')';
          btn.onclick = () => {
            visibleCount += PAGE_SIZE;
            render();
          };
        } else {
          wrap.classList.add('hidden');
        }

        bindCardEvents();
      }

      function cardHtml(p) {
        const img = (p.images && p.images[0]) ? '/products/mic/' + p.images[0] : '';
        const colors = (p.colors || []).slice(0, 4).map((c) =>
          '<span class="text-xs px-2 py-0.5 bg-stone-100 text-stone-700 rounded">' + escapeHtml(c) + '</span>'
        ).join('');
        return (
          '<div class="product-card bg-white border border-stone-200 overflow-hidden hover:shadow-lg transition-shadow group" data-id="' + escapeHtml(p.id) + '">' +
            '<div class="aspect-square bg-stone-100 cursor-pointer overflow-hidden product-img-wrap">' +
              (img ? '<img src="' + img + '" alt="' + escapeHtml(p.name) + '" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />' : '') +
            '</div>' +
            '<div class="p-4">' +
              '<p class="text-xs text-stone-500 uppercase tracking-wider mb-1">' + escapeHtml(p.categoryName || '') + '</p>' +
              '<h3 class="product-name text-sm font-medium text-stone-900 mb-2 line-clamp-2 cursor-pointer hover:text-amber-700">' + escapeHtml(p.name) + '</h3>' +
              '<div class="space-y-1 text-xs text-stone-600 mb-3">' +
                '<div class="flex justify-between"><span>' + escapeHtml(labels.material) + ':</span><span class="font-medium">' + escapeHtml(p.material || '') + '</span></div>' +
                '<div class="flex justify-between"><span>' + escapeHtml(labels.micron) + ':</span><span class="font-medium">' + escapeHtml(p.micron || '') + '</span></div>' +
                '<div class="flex justify-between"><span>' + escapeHtml(labels.price) + ':</span><span class="font-medium text-amber-700">$' + escapeHtml(p.price || '') + ' ' + escapeHtml(p.currency || '') + '</span></div>' +
                '<div class="flex justify-between"><span>' + escapeHtml(labels.moq) + ':</span><span class="font-medium">' + (p.moq || 0) + ' pcs</span></div>' +
              '</div>' +
              (colors ? '<div class="flex flex-wrap gap-1 mb-3">' + colors + '</div>' : '') +
              '<button class="view-detail-btn w-full px-3 py-2 bg-stone-900 text-white text-xs hover:bg-amber-700 transition-colors">' + escapeHtml(labels.requestQuote) + '</button>' +
            '</div>' +
          '</div>'
        );
      }

      function escapeHtml(s) {
        if (s == null) return '';
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      // ---------- 弹窗 ----------
      const modal = document.getElementById('product-modal');
      const modalContent = document.getElementById('modal-content');
      const modalBackdrop = document.getElementById('modal-backdrop');

      function bindCardEvents() {
        document.querySelectorAll('.product-card .product-img-wrap, .product-card .product-name, .product-card .view-detail-btn').forEach((el) => {
          el.addEventListener('click', (e) => {
            const card = e.currentTarget.closest('.product-card');
            const id = card.getAttribute('data-id');
            const product = products.find((p) => p.id === id);
            if (product) openModal(product);
          });
        });
      }

      function openModal(p) {
        const images = (p.images || []);
        const mainImg = images[0] ? '/products/mic/' + images[0] : '';
        const thumbs = images.map((img, i) =>
          '<button class="modal-thumb flex-shrink-0 w-16 h-16 border-2 ' + (i === 0 ? 'border-amber-700' : 'border-stone-200') + '" data-i="' + i + '">' +
            '<img src="/products/mic/' + img + '" alt="' + escapeHtml(p.name) + ' ' + (i+1) + '" class="w-full h-full object-cover" />' +
          '</button>'
        ).join('');
        const colors = (p.colors || []).map((c) =>
          '<span class="text-xs px-3 py-1 bg-stone-100 text-stone-700 border border-stone-200">' + escapeHtml(c) + '</span>'
        ).join('');

        modalContent.innerHTML = (
          '<div class="p-4 sm:p-6">' +
            '<div class="flex justify-between items-start mb-4">' +
              '<div>' +
                '<p class="text-xs text-stone-500 uppercase tracking-wider mb-1">' + escapeHtml(p.categoryName || '') + '</p>' +
                '<h2 class="text-xl sm:text-2xl font-serif text-stone-900">' + escapeHtml(p.name) + '</h2>' +
                '<p class="text-xs text-stone-500 mt-1">' + escapeHtml(labels.productIdLabel) + ': ' + escapeHtml(p.id) + '</p>' +
              '</div>' +
              '<button id="modal-close" class="text-stone-500 hover:text-stone-900 text-2xl leading-none" aria-label="' + escapeHtml(labels.closeButton) + '">×</button>' +
            '</div>' +
            '<div id="modal-main-img" class="aspect-square bg-stone-100 mb-4 overflow-hidden">' +
              (mainImg ? '<img src="' + mainImg + '" alt="' + escapeHtml(p.name) + '" class="w-full h-full object-cover" />' : '') +
            '</div>' +
            (images.length > 1 ? '<div class="flex gap-2 mb-4 overflow-x-auto">' + thumbs + '</div>' : '') +
            '<div class="border-t border-stone-200 pt-4">' +
              '<h3 class="text-sm font-medium text-stone-900 mb-3">' + escapeHtml(labels.productSpecs) + '</h3>' +
              '<div class="grid grid-cols-2 gap-3 text-sm">' +
                '<div><p class="text-xs text-stone-500">' + escapeHtml(labels.material) + '</p><p class="font-medium">' + escapeHtml(p.material || '') + '</p></div>' +
                '<div><p class="text-xs text-stone-500">' + escapeHtml(labels.micron) + '</p><p class="font-medium">' + escapeHtml(p.micron || '') + '</p></div>' +
                '<div><p class="text-xs text-stone-500">' + escapeHtml(labels.price) + '</p><p class="font-medium text-amber-700">$' + escapeHtml(p.price || '') + ' ' + escapeHtml(p.currency || '') + '</p></div>' +
                '<div><p class="text-xs text-stone-500">' + escapeHtml(labels.moq) + '</p><p class="font-medium">' + (p.moq || 0) + ' pcs</p></div>' +
                '<div><p class="text-xs text-stone-500">' + escapeHtml(labels.leadTime) + '</p><p class="font-medium">' + escapeHtml(p.lead || '') + '</p></div>' +
                '<div><p class="text-xs text-stone-500">' + escapeHtml(labels.sampleTime) + '</p><p class="font-medium">' + escapeHtml(p.sample_time || '') + '</p></div>' +
                (p.weight ? '<div class="col-span-2"><p class="text-xs text-stone-500">Weight</p><p class="font-medium">' + escapeHtml(p.weight) + '</p></div>' : '') +
              '</div>' +
              (colors ? '<div class="mt-4"><p class="text-xs text-stone-500 mb-2">' + escapeHtml(labels.colors) + '</p><div class="flex flex-wrap gap-2">' + colors + '</div></div>' : '') +
              '<p class="mt-4 text-sm text-stone-700 leading-relaxed">' + escapeHtml(p.description || '') + '</p>' +
              '<button id="modal-inquiry" class="w-full mt-6 px-6 py-3 bg-amber-700 text-white hover:bg-amber-800 transition-colors">' + escapeHtml(labels.requestInquiry) + '</button>' +
              '<p class="text-xs text-stone-500 text-center mt-2">' + escapeHtml(labels.inquiryNote) + '</p>' +
            '</div>' +
          '</div>'
        );

        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';

        // Close handlers
        document.getElementById('modal-close').addEventListener('click', closeModal);
        modalBackdrop.addEventListener('click', (e) => {
          if (e.target === modalBackdrop) closeModal();
        });

        // Thumbnails
        modalContent.querySelectorAll('.modal-thumb').forEach((t) => {
          t.addEventListener('click', () => {
            const i = parseInt(t.getAttribute('data-i'));
            const newImg = '/products/mic/' + images[i];
            modalContent.querySelector('#modal-main-img img').src = newImg;
            modalContent.querySelectorAll('.modal-thumb').forEach((tt, idx) => {
              tt.classList.toggle('border-amber-700', idx === i);
              tt.classList.toggle('border-stone-200', idx !== i);
            });
          });
        });

        // Inquiry → mailto
        document.getElementById('modal-inquiry').addEventListener('click', () => {
          const subject = encodeURIComponent('Inquiry: ' + p.name + ' (' + p.id + ')');
          const body = encodeURIComponent(
            'Hi,\n\nI\'m interested in: ' + p.name + '\nProduct ID: ' + p.id + '\nCategory: ' + (p.categoryName || '') + '\nMaterial: ' + (p.material || '') + '\nMOQ: ' + (p.moq || 0) + ' pcs\n\nPlease send me more details, pricing, and lead time.\n\nThank you.'
          );
          window.location.href = '/contact?subject=' + subject + '&body=' + body;
        });
      }

      function closeModal() {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
      }

      // ESC 关闭
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
      });

      // 初次渲染（绑定卡片事件）
      bindCardEvents();

      // 初始结果数
      const rc = document.getElementById('result-count');
      rc.textContent = labels.showingProducts ? labels.showingProducts(products.length) : ('Showing ' + products.length + ' products');
    })();
  </script>

  <Footer slot="footer" locale={locale} />
  <FloatingChatButtons slot="floating" locale={locale} />
  <CookieConsent slot="cookie-consent" locale={locale} />
</BaseLayout>
</content>
</invoke>