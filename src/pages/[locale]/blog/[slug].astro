---
/**
 * Blog 详情页 - 从 src/content/blog/{locale}/{slug}.md 读取
 * 由 scripts/generate-blog.mjs + GitHub Actions 每日自动生成
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import FloatingChatButtons from '@/components/FloatingChatButtons.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import { LOCALES, pickLocale } from '@/lib/i18n';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('blog');
  return all.map((post) => {
    const [locale, ...rest] = post.id.split('/');
    const slug = rest.join('/').replace(/\.md$/, '');
    return {
      params: { locale, slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const locale = pickLocale(Astro.params.locale);
const { Content } = await render(post);

// Schema.org Article + BlogPosting for SEO
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.excerpt,
  datePublished: post.data.publishDate.toISOString(),
  dateModified: (post.data.updatedDate || post.data.publishDate).toISOString(),
  author: {
    '@type': 'Organization',
    name: post.data.author,
  },
  keywords: (post.data.targetKeywords || []).join(', '),
  inLanguage: locale,
  articleSection: 'B2B Cashmere Sourcing',
};

const t: Record<string, Record<string, string>> = {
  en: { backToBlog: '← Back to Blog', readTime: 'min read', publishedOn: 'Published', tags: 'Tags' },
  cn: { backToBlog: '← 返回博客', readTime: '分钟阅读', publishedOn: '发布于', tags: '标签' },
  de: { backToBlog: '← Zurück zum Blog', readTime: 'Min. Lesezeit', publishedOn: 'Veröffentlicht', tags: 'Schlagwörter' },
  fr: { backToBlog: '← Retour au blog', readTime: 'min de lecture', publishedOn: 'Publié le', tags: 'Mots-clés' },
  ja: { backToBlog: '← ブログに戻る', readTime: '分読む', publishedOn: '公開日', tags: 'タグ' },
  kr: { backToBlog: '← 블로그로', readTime: '분 소요', publishedOn: '게시일', tags: '태그' },
};
const T = (k: string) => t[locale]?.[k] || t.en[k] || k;

// 估算阅读时间（按 200 wpm）
const wordCount = post.body?.split(/\s+/).length || 0;
const readMin = Math.max(1, Math.round(wordCount / 200));
---

<BaseLayout
  locale={locale}
  pageKey="blog"
  path={`/blog/${Astro.params.slug}`}
  title={post.data.title}
  description={post.data.excerpt}
  ogType="article"
  schema="blog"
>
  <Fragment slot="head">
    <Fragment set:html={(() => {
      // Astro 5 限制：{} 表达式里不能 return JSX 元素数组（报 "Expected '>' but found 'class'"），
      // 所以用 set:html + 字符串拼接 + tag 转义
      const tagMetas = (post.data.tags || [])
        .map((t: string) => `<meta property="article:tag" content="${String(t).replace(/"/g, '&quot;')}" />`)
        .join('');
      return `
      <!-- Article-specific Open Graph meta (extends base OG) -->
      <meta property="article:published_time" content="${post.data.publishDate.toISOString()}" />
      <meta property="article:modified_time" content="${(post.data.updatedDate || post.data.publishDate).toISOString()}" />
      <meta property="article:author" content="${String(post.data.author || '').replace(/"/g, '&quot;')}" />
      <meta property="article:section" content="B2B Cashmere Sourcing" />
      ${tagMetas}
      <meta property="article:locale" content="${locale}" />

      <!-- Twitter: site + creator -->
      <meta name="twitter:site" content="@dongxiaocashmere" />
      <meta name="twitter:creator" content="@dongxiaocashmere" />

      <!-- BlogPosting JSON-LD (rich result in Google) -->
      <script type="application/ld+json">${JSON.stringify(articleSchema)}</script>
    `;
    })()} />
  </Fragment>

  <Navigation slot="header" locale={locale} currentPath={`/${locale}/blog/${Astro.params.slug}`} />

  <article class="pt-32 pb-16 container-narrow max-w-3xl">
    <a href={`/${locale}/blog`} class="text-sm text-muted-foreground hover:text-primary mb-8 inline-block">{T('backToBlog')}</a>

    <header class="mb-12">
      <h1 class="font-display text-4xl md:text-5xl font-light leading-tight mb-6">{post.data.title}</h1>
      <p class="text-xl text-muted-foreground leading-relaxed mb-6">{post.data.excerpt}</p>
      <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground border-y border-border py-4">
        <span><strong class="text-foreground">{T('publishedOn')}:</strong> {post.data.publishDate.toISOString().slice(0, 10)}</span>
        <span>·</span>
        <span>{readMin} {T('readTime')}</span>
        <span>·</span>
        <span><strong class="text-foreground">{post.data.author}</strong></span>
      </div>
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag) => (
            <span class="text-xs px-2 py-1 bg-muted text-muted-foreground rounded-full">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-border">
      <div class="bg-muted/50 border border-border rounded-lg p-6">
        <h3 class="font-display text-xl mb-2">{locale === 'cn' ? '需要报价？' : 'Need a quotation?'}</h3>
        <p class="text-muted-foreground mb-4">
          {locale === 'cn'
            ? '我们的 B2B 团队 24 小时内回复所有询盘。提供产品类型、数量、目的地港口即可。'
            : 'Our B2B team replies to all inquiries within 24 hours. Share product type, quantity, and destination port.'}
        </p>
        <a href={`/${locale}/contact`} class="inline-block px-6 py-3 bg-primary text-primary-foreground rounded-md font-medium hover:bg-primary/90 transition-colors">
          {locale === 'cn' ? '提交询盘 →' : 'Submit Inquiry →'}
        </a>
      </div>
    </footer>
  </article>

  <Footer slot="footer" locale={locale} />
  <FloatingChatButtons slot="floating" locale={locale} />
  <CookieConsent slot="cookie-consent" locale={locale} />
</BaseLayout>
