    sectionGeoP1: '鄂尔多斯位于内蒙古高原腹地，库布齐沙漠东缘。高海拔、干旱大陆性气候为羊绒山羊提供了理想的生长环境，孕育出最长、最细、最保暖的羊绒纤维。',
    sectionGeoP2: '巨大的年温差（冬季-28℃至夏季28℃）刺激山羊生长出最细的羊绒，平均细度14.5-16.5μm，远超其他产区。',
    sectionHeritage: '传承与溯源',
    sectionHeritageP: '4000多年羊绒采集历史。如今我们的2300+牧户合作社在85万公顷认证草原上保持可持续放牧——每包羊绒都可追溯到源头牧场。',
    sectionCert: '认证体系',
    sectionStats: '数据说话',
    statGoats: '阿尔巴斯白绒山羊',
    statHectares: '认证草原（公顷）',
    statHerder: '牧户合作社',
    statFineness: '平均细度',
    ctaTitle: '源头直采',
    ctaSubtitle: '与我们的羊绒专家洽谈鄂尔多斯源头直供方案',
  },
};

const t = (k: string) => i18n[locale]?.[k] || i18n.en[k] || k;

// 产区统计数据
const stats = [
  { value: '320,000+', label: t('statGoats') },
  { value: '850,000', label: t('statHectares') },
  { value: '2,300+', label: t('statHerder') },
  { value: '15.2μm', label: t('statFineness') },
];

// 认证
const certs = ['ISO 9001', 'OEKO-TEX®', 'GCS', 'BSCI', 'Sedex', 'SFA', 'The Good Cashmere Standard'];
---

<BaseLayout
  locale={locale}
  pageKey="ordosOrigin"
  path="/ordos-origin"
  schema="ordos-origin"
>
  <Navigation slot="header" locale={locale} currentPath={`/${locale}/ordos-origin`} />

  <!-- HERO：左文字 / 右真实图 -->
  <section class="relative bg-brand-ink text-white overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[70vh]">
      <div class="flex items-center py-20 lg:py-0 px-6 lg:pl-12 order-2 lg:order-1">
        <div class="max-w-xl">
          <div class="flex items-center gap-3 mb-8">
            <span class="h-px w-12 bg-brand-gold"></span>
            <span class="text-xs tracking-[0.4em] text-brand-gold uppercase font-medium">{t('heroTagline')}</span>
          </div>
          <h1 class="font-serif text-5xl md:text-7xl font-light leading-[1.05] mb-8 text-balance">
            {t('heroTitle')}
          </h1>
          <p class="text-lg text-white/75 leading-relaxed max-w-md font-light">
            {t('heroSubtitle')}
          </p>
        </div>
      </div>
      <div class="relative aspect-[4/3] lg:aspect-auto overflow-hidden order-1 lg:order-2">
        <img src="/images/ordos-landscape.jpg" alt="Ordos plateau" class="absolute inset-0 w-full h-full object-cover opacity-80" />
        <div class="absolute inset-0 bg-gradient-to-l from-transparent to-brand-ink/60"></div>
      </div>
    </div>
  </section>

  <!-- GEO Coordinate Cards -->
  <section class="py-12 bg-secondary/30 border-b border-border">
    <div class="container-narrow">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center md:text-left">
          <div class="text-xs uppercase tracking-wider text-muted-foreground mb-1">Latitude</div>
          <div class="font-serif text-3xl">39°36'N</div>
        </div>
        <div class="text-center md:text-left">
          <div class="text-xs uppercase tracking-wider text-muted-foreground mb-1">Longitude</div>
          <div class="font-serif text-3xl">109°46'E</div>
        </div>
        <div class="text-center md:text-left">
          <div class="text-xs uppercase tracking-wider text-muted-foreground mb-1">Elevation</div>
          <div class="font-serif text-3xl">1,300m</div>
        </div>
        <div class="text-center md:text-left">
          <div class="text-xs uppercase tracking-wider text-muted-foreground mb-1">Climate</div>
          <div class="font-serif text-3xl">Continental</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Geographic Advantage -->
  <section class="section-padding bg-background">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <div class="text-xs tracking-[0.3em] uppercase text-muted-foreground mb-3">01</div>
          <h2 class="font-serif text-4xl md:text-5xl font-light leading-tight mb-6">
            {t('sectionGeo')}
          </h2>
          <p class="text-muted-foreground leading-relaxed mb-4">{t('sectionGeoP1')}</p>
          <p class="text-muted-foreground leading-relaxed">{t('sectionGeoP2')}</p>
        </div>
        <div class="space-y-6">
          <!-- Google Maps embed - 鄂尔多斯 -->
          <div class="aspect-[4/3] rounded-lg overflow-hidden border border-border">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3755.789!2d109.7813!3d39.6086!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMznCsDM2JzMxLjAiTiAxMDnCsDQ2JzUyLjciRQ!5e0!3m2!1sen!2sus!4v1700000000000"
              width="100%" height="100%" style="border:0;" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
              title="Ordos, Inner Mongolia, China"
            ></iframe>
          </div>
          <!-- Baidu Maps for cn locale -->
          {locale === 'cn' && (
            <div class="aspect-[4/3] rounded-lg overflow-hidden border border-border">
              <iframe
                src="https://map.baidu.com/embed?coord=39.6086,109.7813&zoom=12&size=600|450&marker=鄂尔多斯"
                width="100%" height="100%" style="border:0;" loading="lazy"
                title="鄂尔多斯"
              ></iframe>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section-padding bg-primary text-primary-foreground">
    <div class="container-narrow">
      <div class="text-xs tracking-[0.3em] uppercase text-primary-foreground/70 mb-3">{t('sectionStats')}</div>
      <h2 class="font-serif text-4xl md:text-5xl font-light mb-12">Ordos by the Numbers</h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {stats.map((s) => (
          <div>
            <div class="font-serif text-5xl md:text-6xl font-light mb-2">{s.value}</div>
            <div class="text-sm text-primary-foreground/70 uppercase tracking-wider">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Heritage -->
  <section class="section-padding bg-background">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto text-center">
        <div class="text-xs tracking-[0.3em] uppercase text-muted-foreground mb-3">02</div>
        <h2 class="font-serif text-4xl md:text-5xl font-light leading-tight mb-6">
          {t('sectionHeritage')}
        </h2>
        <p class="text-muted-foreground leading-relaxed text-lg">
          {t('sectionHeritageP')}
        </p>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-16 bg-secondary/30 border-y border-border">
    <div class="container-narrow text-center">
      <div class="text-xs tracking-[0.3em] uppercase text-muted-foreground mb-3">03</div>
      <h2 class="font-serif text-3xl md:text-4xl font-light mb-8">{t('sectionCert')}</h2>
      <div class="flex flex-wrap justify-center gap-4">
        {certs.map((cert) => (
          <div class="px-4 py-2 bg-card border border-border rounded-md text-sm font-medium">{cert}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-background">
    <div class="container-narrow text-center">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="h-px w-8 bg-brand-gold"></span>
        <span class="text-xs tracking-[0.3em] uppercase text-brand-camel">{locale === 'cn' ? '下一步' : 'Next Step'}</span>
        <span class="h-px w-8 bg-brand-gold"></span>
      </div>
      <h2 class="font-serif text-4xl md:text-5xl font-light mb-4 text-balance">{t('ctaTitle')}</h2>
      <p class="text-muted-foreground mb-8 max-w-2xl mx-auto">{t('ctaSubtitle')}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`/${locale}/contact`} class="inline-flex items-center gap-2 px-8 py-4 bg-brand-gold text-brand-ink font-medium tracking-wider hover:bg-white transition-colors">
          {locale === 'cn' ? '联系源头' : 'Contact Source'}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href={`/${locale}/raw-material`} class="inline-flex items-center px-8 py-4 border border-brand-chocolate text-brand-chocolate font-medium hover:bg-brand-chocolate hover:text-white transition-colors">
          {locale === 'cn' ? '查看原料' : 'View Materials'}
        </a>
      </div>
    </div>
  </section>

  <SEOFaq title={locale === 'cn' ? '关于鄂尔多斯产地' : 'About Ordos Origin'} faqs={[
    locale === 'cn'
      ? { q: '为什么鄂尔多斯羊绒品质最好？', a: '鄂尔多斯位于北纬39度、海拔1300米的高原，年温差近60℃，独特气候让阿尔巴斯白绒山羊生长出最细（14.5-16.5μm）、最长（34-42mm）的羊绒纤维，是世界公认的顶级羊绒产区。' }
      : { q: 'Why is Ordos cashmere the finest in the world?', a: 'Ordos sits at 39°N latitude and 1,300m elevation on the Inner Mongolia plateau. The annual temperature swing of nearly 60°C (-28°C to 28°C) stimulates Albus white cashmere goats to grow the finest (14.5-16.5μm) and longest (34-42mm) cashmere fibers — globally recognized as the premium cashmere origin.' },
    locale === 'cn'
      ? { q: '什么是阿尔巴斯白绒山羊？', a: '阿尔巴斯白绒山羊是鄂尔多斯特有的珍稀品种，国家地理标志保护产品。其羊绒细度、长度、净绒率均优于普通山羊，是内蒙古白绒的代表品种。' }
      : { q: 'What is the Albus white cashmere goat?', a: 'Albus white cashmere goats are an indigenous rare breed from Ordos, protected as a National Geographic Indication product. Their cashmere surpasses ordinary goats in fineness, length, and yield ratio — representing the finest Inner Mongolia white cashmere.' },
    locale === 'cn'
      ? { q: '如何验证羊绒来自鄂尔多斯？', a: '正宗鄂尔多斯羊绒需具备：产地证明、阿尔巴斯山羊血统证书、分梳工厂产地溯源。我们的每包羊绒都可追溯到具体牧场和牧户。' }
      : { q: 'How to verify cashmere originates from Ordos?', a: 'Authentic Ordos cashmere requires: origin certificate, Albus goat pedigree certificate, dehairing factory traceability. Every bale we supply is traceable to specific pasture and herder family.' },
  ]} />

  <Footer slot="footer" locale={locale} />
  <FloatingChatButtons slot="floating" locale={locale} />
  <CookieConsent slot="cookie-consent" locale={locale} />
</BaseLayout>
