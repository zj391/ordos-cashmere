---
/**
 * Blog 列表 - 从 src/content/blog/{locale}/*.md 读取
 * 由 scripts/generate-blog.mjs + GitHub Actions 每日自动生成
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import FloatingChatButtons from '@/components/FloatingChatButtons.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import { LOCALES, type Locale, isLocale, pickLocale } from '@/lib/i18n';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: rawLocale } = Astro.params;
const locale = pickLocale(rawLocale);

const t: Record<string, Record<string, string>> = {
  en: { title: 'Cashmere Insights', subtitle: 'Industry guides and B2B sourcing tips' },
  cn: { title: '羊绒行业洞察', subtitle: '行业指南与 B2B 采购技巧' },
  de: { title: 'Kaschmir-Einblicke', subtitle: 'Branchenführer und B2B-Beschaffungstipps' },
  fr: { title: 'Aperçus cachemire', subtitle: 'Guides sectoriels et conseils B2B' },
  ja: { title: 'カシミアインサイト', subtitle: '業界ガイドと B2B 調達のヒント' },
  kr: { title: '캐시미어 인사이트', subtitle: '산업 가이드 및 B2B 소싱 팁' },
};
const T = (k: string) => t[locale]?.[k] || t.en[k] || k;

// 从 Content Collections 读取该 locale 的所有博客（按发布日期倒序）
const allPosts = await getCollection('blog', ({ id }) => id.startsWith(`${locale}/`));
const posts = allPosts
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .map((p) => ({
    slug: p.id.replace(`${locale}/`, '').replace(/\.md$/, ''),
    title: p.data.title,
    excerpt: p.data.excerpt,
    date: p.data.publishDate.toISOString().slice(0, 10),
    tags: p.data.tags,
  }));

// ItemList JSON-LD: 让 Google 把博客列表做成富结果
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: T('title'),
  description: T('subtitle'),
  numberOfItems: posts.length,
  itemListElement: posts.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://erdosdx.com/${locale}/blog/${p.slug}`,
    name: p.title,
  })),
};

// BreadcrumbList JSON-LD: 首页 > Blog
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `https://erdosdx.com/${locale}/` },
    { '@type': 'ListItem', position: 2, name: locale === 'cn' ? '博客' : 'Blog', item: `https://erdosdx.com/${locale}/blog` },
  ],
};

---

<BaseLayout locale={locale} pageKey="blog" path="/blog">
  <Fragment slot="head" set:html={(() => {
    // Astro 5 限制：{} 里不能 return JSX 数组，用 set:html + 字符串拼接
    const itemListJson = JSON.stringify(itemListSchema);
    const breadcrumbJson = JSON.stringify(breadcrumbSchema);
    return `
    <!-- Blog list ItemList + Breadcrumb JSON-LD -->
    <script type="application/ld+json">${itemListJson}</script>
    <script type="application/ld+json">${breadcrumbJson}</script>
  `;
  })()} />

  <Navigation slot="header" locale={locale} currentPath={`/${locale}/blog`} />

  <section class="relative bg-brand-ink text-white overflow-hidden">
    <div class="container-narrow py-24 md:py-32">
      <div class="flex items-center gap-3 mb-8">
        <span class="h-px w-12 bg-brand-gold"></span>
        <span class="text-xs tracking-[0.4em] text-brand-gold uppercase font-medium">{locale === 'cn' ? '博客' : 'Blog'}</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-light leading-[1.05] mb-8 text-balance">{T('title')}</h1>
      <p class="text-lg text-white/75 leading-relaxed max-w-xl font-light">{T('subtitle')}</p>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-background">
    <div class="container-narrow">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((p) => (
          <a href={`/${locale}/blog/${p.slug}`} class="group block border border-border p-8 hover:border-brand-gold hover:shadow-lg transition-all duration-300">
            <div class="text-xs text-muted-foreground tracking-wider mb-3 font-mono">{p.date}</div>
            <h3 class="font-serif text-2xl mb-3 group-hover:text-brand-chocolate transition-colors leading-tight">{p.title}</h3>
            <p class="text-muted-foreground leading-relaxed mb-6 text-sm">{p.excerpt}</p>
            <span class="inline-flex items-center gap-2 text-sm text-brand-chocolate font-medium border-b border-brand-chocolate pb-0.5 group-hover:border-brand-gold group-hover:text-brand-gold transition-colors">
              {locale === 'cn' ? '阅读全文' : 'Read more'}
              <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" locale={locale} />
  <FloatingChatButtons slot="floating" locale={locale} />
  <CookieConsent slot="cookie-consent" locale={locale} />
</BaseLayout>
