---
/**
 * Factory 工厂介绍页
 */
export const prerender = true;
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import FloatingChatButtons from '@/components/FloatingChatButtons.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import SEOFaq from '@/components/SEOFaq.astro';
import { LOCALES, type Locale, isLocale, pickLocale } from '@/lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: rawLocale } = Astro.params;
const locale = pickLocale(rawLocale);

const t: Record<string, Record<string, string>> = {
  en: {
    tagline: 'OUR FACTORY',
    title: 'Factory\nStrength',
    subtitle: '38,000 sqm · 500+ workers · 1,200t annual capacity · ISO certified source facility in Ordos.',
    scaleTitle: 'Scale & capacity',
    scaleSub: 'A vertically integrated facility, from dehairing to finished knitwear.',
    equipTitle: 'Equipment',
    equipSub: 'Italian, German, Japanese, Swiss machinery. Best-in-class for cashmere.',
    certTitle: 'Certifications',
    ctaTitle: 'Visit our factory',
    ctaSub: 'B2B clients welcome for on-site visits. 7-day advance notice.',
    cta: 'Schedule a visit',
  },
  cn: {
    tagline: '工厂实力',
    title: '工厂\n实力',
    subtitle: '38,000平米厂房 · 500+员工 · 年产能1,200吨 · ISO认证源头工厂',
    scaleTitle: '规模与产能',
    scaleSub: '全产业链垂直整合，从原料分梳到成衣出厂。',
    equipTitle: '生产设备',
    equipSub: '意大利、德国、日本、瑞士设备，全球顶级羊绒生产配置。',
    certTitle: '资质认证',
    ctaTitle: '预约考察',
    ctaSub: '欢迎 B2B 客户实地考察，提前 7 天预约。',
    cta: '预约参观',
  },
  de: { tagline: 'FABRIK', title: 'Fabrik-\nstärke', subtitle: '38.000 qm · 500+ Mitarbeiter · 1.200t Jahreskapazität', scaleTitle: 'Maßstab', scaleSub: 'Vertikal integriert.', equipTitle: 'Ausrüstung', equipSub: 'Italienische, deutsche, japanische, schweizer Maschinen.', certTitle: 'Zertifizierungen', ctaTitle: 'Werk besuchen', ctaSub: '7 Tage Vorlauf.', cta: 'Besuch planen' },
  fr: { tagline: 'USINE', title: 'Force de\nl\'usine', subtitle: '38 000 m² · 500+ · 1 200t capacité', scaleTitle: 'Échelle', scaleSub: 'Intégration verticale.', equipTitle: 'Équipement', equipSub: 'Machines italiennes, allemandes, japonaises, suisses.', certTitle: 'Certifications', ctaTitle: 'Visiter l\'usine', ctaSub: 'Préavis 7 jours.', cta: 'Planifier' },
  ja: { tagline: '工場', title: '工場の\n強み', subtitle: '38,000平米 · 500名+ · 年間1,200トン', scaleTitle: '規模・能力', scaleSub: '垂直統合。', equipTitle: '設備', equipSub: '伊・独・日・スイス製。', certTitle: '認証', ctaTitle: '工場見学', ctaSub: '7日前予約。', cta: '予約' },
  kr: { tagline: '공장', title: '공장\n강점', subtitle: '38,000 sqm · 500+ · 연 1,200톤', scaleTitle: '규모', scaleSub: '수직 통합.', equipTitle: '설비', equipSub: '이탈리아·독일·일본·스위스.', certTitle: '인증', ctaTitle: '공장 방문', ctaSub: '7일 사전 예약.', cta: '예약' },
};
const T = (k: string) => t[locale]?.[k] || t.en[k] || k;

const scale = [
  { value: '38,000', unit: 'm²', label: locale === 'cn' ? '厂房面积' : 'Factory Area' },
  { value: '500+', unit: '', label: locale === 'cn' ? '员工' : 'Employees' },
  { value: '1,200', unit: 't', label: locale === 'cn' ? '年产能' : 'Annual Capacity' },
  { value: '50+', unit: '', label: locale === 'cn' ? '出口国家' : 'Export Countries' },
  { value: '23+', unit: 'yrs', label: locale === 'cn' ? '行业经验' : 'Years of Excellence' },
  { value: '7', unit: '', label: locale === 'cn' ? '国际认证' : 'Certifications' },
];

const equipment = [
  { name: locale === 'cn' ? '意大利梳绒机' : 'Italian Dehairing Lines', spec: '12 lines' },
  { name: locale === 'cn' ? '日本岛精横机' : 'Shima Seiki Flatbed', spec: '48 machines' },
  { name: locale === 'cn' ? '德国斯托尔电脑横机' : 'Stoll CMS Knitting', spec: '24 machines' },
  { name: locale === 'cn' ? '意大利络筒机' : 'Italian Winding Lines', spec: '8 lines' },
  { name: locale === 'cn' ? '瑞士乌斯特检测仪' : 'Uster Tester', spec: '6 units' },
  { name: locale === 'cn' ? '全自动包装线' : 'Auto Packing Lines', spec: '4 lines' },
];

const certs = ['ISO 9001:2015', 'OEKO-TEX®', 'Good Cashmere Standard', 'BSCI', 'Sedex SMETA', 'WRAP', 'SFA'];
---

<BaseLayout locale={locale} pageKey="factory" path="/factory">
  <Navigation slot="header" locale={locale} currentPath={`/${locale}/factory`} />

  <!-- HERO -->
  <section class="relative bg-brand-ink text-white overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[60vh]">
      <div class="flex items-center py-20 lg:py-0 px-6 lg:pl-12 order-2 lg:order-1">
        <div class="max-w-xl">
          <div class="flex items-center gap-3 mb-8">
            <span class="h-px w-12 bg-brand-gold"></span>
            <span class="text-xs tracking-[0.4em] text-brand-gold uppercase font-medium">{T('tagline')}</span>
          </div>
          <h1 class="font-serif text-5xl md:text-7xl font-light leading-[1.05] mb-8" set:html={T('title').replace(/\n/g, '<br/>')} />
          <p class="text-lg text-white/75 leading-relaxed max-w-md font-light">{T('subtitle')}</p>
        </div>
      </div>
      <div class="relative aspect-[4/3] lg:aspect-auto overflow-hidden order-1 lg:order-2">
        <img src="/images/cashmere-fiber.jpg" alt="Cashmere fiber detail — 14.5μm micron dehaired underdown from Inner Mongolia Albus goat" class="absolute inset-0 w-full h-full object-cover opacity-80" />
        <div class="absolute inset-0 bg-gradient-to-l from-transparent to-brand-ink/60"></div>
      </div>
    </div>
  </section>

  <!-- Scale：6 数据块 -->
  <section class="py-24 md:py-32 bg-background">
    <div class="container-narrow">
      <div class="max-w-2xl mb-16">
        <div class="flex items-center gap-3 mb-4">
          <span class="h-px w-8 bg-brand-gold"></span>
          <span class="text-xs tracking-[0.3em] uppercase text-brand-camel">01 / {T('scaleTitle')}</span>
        </div>
        <h2 class="font-serif text-4xl md:text-5xl font-light leading-tight mb-4">{T('scaleTitle')}</h2>
        <p class="text-muted-foreground leading-relaxed">{T('scaleSub')}</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-px bg-border">
        {scale.map((s, i) => (
          <div class="bg-background p-8 md:p-10 hover:bg-brand-cream/30 transition-colors group">
            <div class="text-xs tracking-[0.2em] uppercase text-muted-foreground mb-4 flex items-baseline justify-between">
              <span>{s.label}</span>
              <span class="font-serif text-sm text-brand-gold/50">{String(i+1).padStart(2,'0')}</span>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="font-serif text-4xl md:text-5xl text-brand-chocolate font-light group-hover:text-brand-gold transition-colors">{s.value}</span>
              {s.unit && <span class="text-sm text-muted-foreground">{s.unit}</span>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Equipment -->
  <section class="py-24 md:py-32 bg-brand-cream/50 border-y border-border">
    <div class="container-narrow">
      <div class="max-w-2xl mb-16">
        <div class="flex items-center gap-3 mb-4">
          <span class="h-px w-8 bg-brand-gold"></span>
          <span class="text-xs tracking-[0.3em] uppercase text-brand-camel">02 / {T('equipTitle')}</span>
        </div>
        <h2 class="font-serif text-4xl md:text-5xl font-light leading-tight mb-4">{T('equipTitle')}</h2>
        <p class="text-muted-foreground leading-relaxed">{T('equipSub')}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border">
        {equipment.map((e, i) => (
          <div class="bg-brand-cream/30 p-6 md:p-8 flex justify-between items-center group hover:bg-background transition-colors">
            <div class="flex items-baseline gap-3">
              <span class="font-serif text-sm text-brand-gold/50">{String(i+1).padStart(2,'0')}</span>
              <span class="font-serif text-xl group-hover:text-brand-chocolate transition-colors">{e.name}</span>
            </div>
            <span class="text-sm text-muted-foreground">{e.spec}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-24 md:py-32 bg-background">
    <div class="container-narrow">
      <div class="max-w-2xl mb-16">
        <div class="flex items-center gap-3 mb-4">
          <span class="h-px w-8 bg-brand-gold"></span>
          <span class="text-xs tracking-[0.3em] uppercase text-brand-camel">03 / {T('certTitle')}</span>
        </div>
        <h2 class="font-serif text-4xl md:text-5xl font-light leading-tight">{T('certTitle')}</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-6">
        {certs.map((cert) => (
          <div class="aspect-square rounded-full border border-brand-gold/40 flex items-center justify-center hover:border-brand-gold hover:bg-brand-gold/5 transition-all group">
            <span class="font-serif text-sm text-brand-gold tracking-wider text-center px-2 leading-tight">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32 bg-brand-chocolate text-white">
    <div class="container-narrow text-center">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="h-px w-8 bg-brand-gold"></span>
        <span class="text-xs tracking-[0.3em] uppercase text-brand-gold">{locale === 'cn' ? '下一步' : 'Next Step'}</span>
        <span class="h-px w-8 bg-brand-gold"></span>
      </div>
      <h2 class="font-serif text-4xl md:text-5xl font-light mb-4 text-balance">{T('ctaTitle')}</h2>
      <p class="text-white/75 mb-8 max-w-2xl mx-auto">{T('ctaSub')}</p>
      <a href={`/${locale}/contact?type=visit`} class="inline-flex items-center gap-2 px-10 py-5 bg-brand-gold text-brand-ink font-medium tracking-wider hover:bg-white transition-colors">
        {T('cta')}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

  <SEOFaq faqs={[
    locale === 'cn'
      ? { q: '能否预约到工厂参观？', a: '可以。我们接受B2B客户的工厂参观预约，提前7天联系即可。参观内容包括原料分梳车间、纺纱车间、针织车间、成品检验线、仓库等。' }
      : { q: 'Can I visit the factory?', a: 'Yes, we accept B2B client factory visit appointments with 7-day advance notice. The visit covers raw material dehairing workshop, spinning workshop, knitting workshop, finished product QC line, and warehouse.' },
    locale === 'cn'
      ? { q: '工厂有哪些国际认证？', a: 'ISO 9001:2015 质量管理体系、OEKO-TEX Standard 100、Good Cashmere Standard (GCS)、BSCI 社会责任审核、Sedex SMETA、WRAP、SFA。可在下载中心下载证书PDF。' }
      : { q: 'What international certifications does the factory have?', a: 'ISO 9001:2015 Quality Management, OEKO-TEX Standard 100, Good Cashmere Standard (GCS), BSCI social compliance, Sedex SMETA, WRAP, SFA. Certificate PDFs available in Download Center.' },
  ]} />

  <Footer slot="footer" locale={locale} />
  <FloatingChatButtons slot="floating" locale={locale} />
  <CookieConsent slot="cookie-consent" locale={locale} />
</BaseLayout>
