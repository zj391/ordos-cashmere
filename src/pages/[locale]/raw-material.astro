---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import FloatingChatButtons from '@/components/FloatingChatButtons.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import SEOFaq from '@/components/SEOFaq.astro';
import RawMaterialInquiryForm from '@/components/islands/RawMaterialInquiryForm.tsx';
import { LOCALES, type Locale, isLocale, pickLocale } from '@/lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: rawLocale } = Astro.params;
const locale = pickLocale(rawLocale);

const t: Record<string, Record<string, string>> = {
  en: {
    heroTagline: 'RAW CASHMERE',
    heroTitle: 'Premium Raw Cashmere Fiber',
    heroSubtitle: 'White, brown, purple cashmere direct from Ordos. 14.5-16.5μm. Dehaired, ready for spinning.',
    sectionSpecs: 'Specifications',
    sectionGrades: 'Cashmere Grades',
    sectionInquiry: 'Request Quotation',
  },
  cn: {
    heroTagline: '羊绒原料',
    heroTitle: '高端羊绒原料',
    heroSubtitle: '白绒/青绒/紫绒，鄂尔多斯源头直供。细度14.5-16.5μm，分梳后可直接纺纱。',
    sectionSpecs: '规格参数',
    sectionGrades: '羊绒分级',
    sectionInquiry: '立即询盘',
  },
  de: { heroTagline: 'ROHKASCHMIR', heroTitle: 'Premium Rohkaschmir', heroSubtitle: 'Weiß, Braun, Lila Kaschmir. 14.5-16.5μm.', sectionSpecs: 'Spezifikationen', sectionGrades: 'Kaschmir-Qualitäten', sectionInquiry: 'Angebot anfordern' },
  fr: { heroTagline: 'CACHEMIRE BRUT', heroTitle: 'Cachemire brut premium', heroSubtitle: 'Cachemire blanc, brun, violet. 14.5-16.5μm.', sectionSpecs: 'Spécifications', sectionGrades: 'Grades de cachemire', sectionInquiry: 'Demander un devis' },
  ja: { heroTagline: '原料カシミア', heroTitle: 'プレミアム原料カシミア', heroSubtitle: '白・青・紫カシミア。14.5-16.5μm。', sectionSpecs: '仕様', sectionGrades: 'カシミア等級', sectionInquiry: '見積もり依頼' },
  kr: { heroTagline: '원료 캐시미어', heroTitle: '프리미엄 원료 캐시미어', heroSubtitle: '백색, 청색, 자색 캐시미어. 14.5-16.5μm.', sectionSpecs: '사양', sectionGrades: '캐시미어 등급', sectionInquiry: '견적 요청' },
};
const T = (k: string) => t[locale]?.[k] || t.en[k] || k;

const grades = [
  {
    name: locale === 'cn' ? '白绒' : 'White Cashmere',
    desc: locale === 'cn' ? '阿尔巴斯白山羊，细度14.5-15.5μm，最高级别' : 'Albus white goat, 14.5-15.5μm, finest grade',
    color: 'bg-brand-cream',
  },
  {
    name: locale === 'cn' ? '青绒' : 'Brown Cashmere',
    desc: locale === 'cn' ? '细度15.5-16.5μm，性价比高' : '15.5-16.5μm, great value',
    color: 'bg-brand-sand',
  },
  {
    name: locale === 'cn' ? '紫绒' : 'Purple Cashmere',
    desc: locale === 'cn' ? '紫山羊，深色，适合混色产品' : 'Purple goat, deep tones, for blends',
    color: 'bg-brand-camel',
  },
];

const specs = [
  { label: locale === 'cn' ? '细度' : 'Fineness', value: '14.5-16.5μm' },
  { label: locale === 'cn' ? '长度' : 'Length', value: '34-42mm' },
  { label: locale === 'cn' ? '净绒率' : 'Yield', value: '≥45%' },
  { label: locale === 'cn' ? '含杂率' : 'Impurity', value: '≤0.3%' },
  { label: locale === 'cn' ? '最短起订量' : 'MOQ', value: '100kg' },
  { label: locale === 'cn' ? '交货期' : 'Lead Time', value: locale === 'cn' ? '15-25天' : '15-25 days' },
];
---

<BaseLayout locale={locale} pageKey="rawMaterial" path="/raw-material">
  <Navigation slot="header" locale={locale} currentPath={`/${locale}/raw-material`} />

  <section class="pt-24 pb-12 bg-gradient-to-br from-brand-ink via-brand-chocolate to-brand-camel text-white">
    <div class="container-narrow relative z-10">
      <div class="text-xs tracking-[0.3em] uppercase mb-4 text-white/70">{T('heroTagline')}</div>
      <h1 class="font-display text-5xl md:text-6xl font-light leading-tight mb-6 max-w-3xl">{T('heroTitle')}</h1>
      <p class="text-xl text-white/80 max-w-2xl">{T('heroSubtitle')}</p>
    </div>
  </section>

  <section class="section-padding bg-background">
    <div class="container-narrow">
      <h2 class="font-display text-3xl md:text-4xl font-light mb-12">{T('sectionGrades')}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        {grades.map((g) => (
          <div class={`aspect-[4/5] rounded-lg ${g.color} relative overflow-hidden group`}>
            <div class="absolute inset-0 flex flex-col justify-end p-8 text-white">
              <h3 class="font-display text-3xl mb-2">{g.name}</h3>
              <p class="text-sm opacity-80">{g.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <h2 class="font-display text-3xl md:text-4xl font-light mb-12">{T('sectionSpecs')}</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-12">
        {specs.map((s) => (
          <div class="border border-border rounded-lg p-6">
            <div class="text-xs uppercase tracking-wider text-muted-foreground mb-2">{s.label}</div>
            <div class="font-display text-2xl">{s.value}</div>
          </div>
        ))}
      </div>

      <div class="mt-16">
        <RawMaterialInquiryForm client:load locale={locale} />
      </div>
    </div>
  </section>

  <SEOFaq faqs={[
    locale === 'cn'
      ? { q: '羊绒原料如何分级？', a: '主要按细度分级：14.5μm以下为顶级（Baby Cashmere），14.5-15.5μm为白绒精品，15.5-16.5μm为标准白绒。同时按色泽分白绒、青绒、紫绒三个品种，白绒品质最高。' }
      : { q: 'How is cashmere raw material graded?', a: 'Cashmere is graded primarily by fiber fineness: <14.5μm is premium (Baby Cashmere), 14.5-15.5μm is white cashmere top grade, 15.5-16.5μm is standard white. Also classified by color into white, brown, and purple varieties.' },
    locale === 'cn'
      ? { q: '白绒和青绒的区别？', a: '白绒产自阿尔巴斯白绒山羊（白色），纤维白净，可染任意颜色，最高等级。青绒产自青色山羊，纤维本身带浅灰/青色，适合混色或深色产品，性价比高。' }
      : { q: 'What\'s the difference between white and brown cashmere?', a: 'White cashmere comes from Albus white goats - pure white fiber that can be dyed any color, top grade. Brown cashmere comes from grey/brown goats with naturally colored fiber, ideal for blends or dark products, offering better value.' },
  ]} />

  <Footer slot="footer" locale={locale} />
  <FloatingChatButtons slot="floating" locale={locale} />
  <CookieConsent slot="cookie-consent" locale={locale} />
</BaseLayout>
