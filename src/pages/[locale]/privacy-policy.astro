---
/**
 * Privacy Policy - 6 国通用
 */
export const prerender = true;
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import FloatingChatButtons from '@/components/FloatingChatButtons.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import { LOCALES, type Locale, isLocale, pickLocale } from '@/lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: rawLocale } = Astro.params;
const locale = pickLocale(rawLocale);

const privacyPolicy: Record<string, { title: string; sections: Array<{ h: string; p: string }> }> = {
  en: {
    title: 'Privacy Policy',
    sections: [
      { h: '1. Information We Collect', p: 'We collect personal information you voluntarily provide, including name, email, phone, company, country, and product interests. We also collect browsing data via Google Analytics.' },
      { h: '2. How We Use Your Information', p: 'Your information is used to respond to inquiries, provide quotations, and improve our services. We do not sell your data to third parties.' },
      { h: '3. Cookies', p: 'We use essential cookies for site functionality and analytics cookies (Google Analytics) to understand user behavior. You may decline analytics cookies via our cookie banner.' },
      { h: '4. Data Sharing', p: 'We share data with: (a) WhatsApp/WeChat when you contact us; (b) our CRM/email service providers; (c) Google Analytics. We require all processors to comply with GDPR.' },
      { h: '5. Your Rights (GDPR)', p: 'You have the right to access, rectify, delete, or restrict processing of your personal data. Contact us at dongxiaocashmere@erdosdx.com.' },
      { h: '6. Data Retention', p: 'Inquiry data is retained for 3 years for business purposes. Analytics data is retained for 14 months per Google Analytics default.' },
      { h: '7. Contact', p: 'For privacy inquiries: dongxiaocashmere@erdosdx.com' },
    ],
  },
  cn: {
    title: '隐私政策',
    sections: [
      { h: '1. 信息收集', p: '我们收集您主动提供的个人信息（姓名、邮箱、电话、公司、国家、产品兴趣），以及通过 Google Analytics 收集的浏览数据。' },
      { h: '2. 信息用途', p: '用于回复询盘、提供报价、改善服务。我们不会向第三方出售您的数据。' },
      { h: '3. Cookie', p: '我们使用必要 Cookie 维持网站功能，使用 Google Analytics 分析用户行为。您可通过 Cookie 横幅拒绝分析 Cookie。' },
      { h: '4. 数据共享', p: '数据共享对象：WhatsApp/微信、CRM/邮件服务商、Google Analytics。我们要求所有处理方遵守 GDPR。' },
      { h: '5. 您的权利（GDPR）', p: '您有权访问、更正、删除或限制处理您的个人数据。请联系 dongxiaocashmere@erdosdx.com。' },
      { h: '6. 数据保留', p: '询盘数据保留 3 年，分析数据按 Google Analytics 默认保留 14 个月。' },
      { h: '7. 联系', p: '隐私相关咨询：dongxiaocashmere@erdosdx.com' },
    ],
  },
  de: {
    title: 'Datenschutzerklärung',
    sections: [
      { h: '1. Erhobene Informationen', p: 'Wir erheben freiwillig bereitgestellte personenbezogene Daten (Name, E-Mail, Telefon, Firma, Land, Produktinteressen) sowie Browserdaten über Google Analytics.' },
      { h: '2. Verwendung', p: 'Ihre Daten werden zur Beantwortung von Anfragen, Angebotserstellung und Serviceverbesserung verwendet. Wir verkaufen Ihre Daten nicht an Dritte.' },
      { h: '3. Cookies', p: 'Wir verwenden notwendige Cookies für die Website-Funktionalität und Analyse-Cookies (Google Analytics). Sie können Analyse-Cookies über unser Banner ablehnen.' },
      { h: '4. Datenweitergabe', p: 'Datenweitergabe an: WhatsApp/WeChat, CRM/E-Mail-Dienste, Google Analytics. Alle Auftragsverarbeiter sind DSGVO-konform.' },
      { h: '5. Ihre Rechte (DSGVO)', p: 'Sie haben das Recht auf Auskunft, Berichtigung, Löschung oder Einschränkung Ihrer personenbezogenen Daten. Kontakt: dongxiaocashmere@erdosdx.com.' },
      { h: '6. Speicherdauer', p: 'Anfragedaten 3 Jahre; Analysedaten 14 Monate gemäß Google Analytics Standard.' },
      { h: '7. Kontakt', p: 'Datenschutzanfragen: dongxiaocashmere@erdosdx.com' },
    ],
  },
  fr: {
    title: 'Politique de confidentialité',
    sections: [
      { h: '1. Informations collectées', p: 'Nous collectons les informations personnelles fournies volontairement (nom, e-mail, téléphone, société, pays, intérêts produits) ainsi que les données de navigation via Google Analytics.' },
      { h: '2. Utilisation', p: 'Vos informations servent à répondre aux demandes, établir des devis et améliorer nos services. Nous ne vendons pas vos données à des tiers.' },
      { h: '3. Cookies', p: 'Nous utilisons des cookies essentiels et des cookies analytiques (Google Analytics). Vous pouvez refuser les cookies analytiques via notre bannière.' },
      { h: '4. Partage des données', p: 'Partage avec : WhatsApp/WeChat, CRM/e-mail, Google Analytics. Tous les sous-traitants sont conformes au RGPD.' },
      { h: '5. Vos droits (RGPD)', p: 'Vous avez le droit d\'accéder, rectifier, supprimer ou limiter le traitement de vos données. Contact : dongxiaocashmere@erdosdx.com.' },
      { h: '6. Conservation', p: 'Données de demande : 3 ans. Données analytiques : 14 mois (Google Analytics par défaut).' },
      { h: '7. Contact', p: 'Pour toute question : dongxiaocashmere@erdosdx.com' },
    ],
  },
  ja: {
    title: 'プライバシーポリシー',
    sections: [
      { h: '1. 収集する情報', p: 'お名前、メールアドレス、電話番号、会社、国、製品関心など、お客様が提供された情報と、Google Analytics による閲覧データを収集します。' },
      { h: '2. 利用目的', p: 'お問い合わせへの回答、お見積もり、サービス改善に使用します。第三者に販売することはありません。' },
      { h: '3. Cookie', p: 'サイト機能に必要な Cookie と、Google Analytics の分析 Cookie を使用します。Cookie バナーで分析 Cookie を拒否できます。' },
      { h: '4. データ共有', p: 'WhatsApp/WeChat、CRM/メールサービス、Google Analytics と共有します。すべて GDPR 準拠です。' },
      { h: '5. お客様の権利 (GDPR)', p: '個人データへのアクセス、訂正、削除、処理制限の権利があります。dongxiaocashmere@erdosdx.com までご連絡ください。' },
      { h: '6. 保持期間', p: 'お問い合わせデータ 3 年。分析データ 14 ヶ月（Google Analytics デフォルト）。' },
      { h: '7. お問い合わせ', p: 'プライバシー関連：dongxiaocashmere@erdosdx.com' },
    ],
  },
  kr: {
    title: '개인정보 처리방침',
    sections: [
      { h: '1. 수집 정보', p: '이름, 이메일, 전화번호, 회사, 국가, 제품 관심사 등 자발적으로 제공된 정보와 Google Analytics 浏览 데이터를 수집합니다.' },
      { h: '2. 이용 목적', p: '문의 응답, 견적 제공, 서비스 개선에 사용됩니다. 제3자에게 판매하지 않습니다.' },
      { h: '3. Cookie', p: '사이트 기능에 필수적인 Cookie와 Google Analytics 분석 Cookie를 사용합니다. Cookie 배너에서 분석 Cookie를 거부할 수 있습니다.' },
      { h: '4. 데이터 공유', p: 'WhatsApp/WeChat, CRM/이메일 서비스, Google Analytics와 공유. 모든 처리자는 GDPR 준수.' },
      { h: '5. 귀하의 권리 (GDPR)', p: '개인 데이터에 대한 접근, 정정, 삭제, 처리 제한 권리가 있습니다. dongxiaocashmere@erdosdx.com으로 연락.' },
      { h: '6. 보관 기간', p: '문의 데이터 3년, 분석 데이터 14개월(Google Analytics 기본).' },
      { h: '7. 연락처', p: '개인정보 관련 문의: dongxiaocashmere@erdosdx.com' },
    ],
  },
};

const policy = privacyPolicy[locale] || privacyPolicy.en;
---

<BaseLayout locale={locale} pageKey="privacy" path="/privacy-policy">
  <Navigation slot="header" locale={locale} currentPath={`/${locale}/privacy-policy`} />

  <section class="relative bg-brand-ink text-white overflow-hidden">
    <div class="container-narrow py-24 md:py-32">
      <div class="flex items-center gap-3 mb-8">
        <span class="h-px w-12 bg-brand-gold"></span>
        <span class="text-xs tracking-[0.4em] text-brand-gold uppercase font-medium">LEGAL</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-light leading-[1.05] mb-8 text-balance">{policy.title}</h1>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-background">
    <div class="container-narrow max-w-3xl">
      <div class="space-y-12">
        {policy.sections.map((s, i) => (
          <div>
            <div class="flex items-baseline gap-3 mb-4">
              <span class="font-serif text-sm text-brand-gold/50">{String(i+1).padStart(2,'0')}</span>
              <h2 class="font-serif text-2xl text-brand-ink">{s.h}</h2>
            </div>
            <p class="text-muted-foreground leading-relaxed pl-8">{s.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" locale={locale} />
  <FloatingChatButtons slot="floating" locale={locale} />
  <CookieConsent slot="cookie-consent" locale={locale} />
</BaseLayout>
