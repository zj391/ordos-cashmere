---
// Admin inquiry detail
// /admin/inquiries/[id]
// - Show all fields
// - Form to update status, lead_grade, notes
// - Submit POSTs to /api/admin/inquiries/?id=…

export const prerender = false;
const { id } = Astro.params;
const SUPABASE_URL = process.env.PUBLIC_SUPABASE_URL || process.env.SUPABASE_URL || '';
const SUPABASE_KEY = process.env.SUPABASE_SERVICE_KEY || '';

let inquiry: any = null;
let lead: any = null;
let error = '';

if (SUPABASE_URL && SUPABASE_KEY) {
  try {
    const r1 = await fetch(`${SUPABASE_URL}/rest/v1/inquiries?id=eq.${id}&limit=1`, {
      headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY },
    });
    if (r1.ok) {
      const arr = await r1.json();
      inquiry = arr[0] || null;
    } else {
      error = `Supabase ${r1.status}`;
    }

    // Try to find matching lead (by email)
    if (inquiry?.email) {
      const r2 = await fetch(`${SUPABASE_URL}/rest/v1/leads?email=eq.${encodeURIComponent(inquiry.email)}&limit=1`, {
        headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY },
      });
      if (r2.ok) {
        const arr2 = await r2.json();
        lead = arr2[0] || null;
      }
    }
  } catch (e) {
    error = e.message;
  }
}

function fmtDate(iso: string) {
  if (!iso) return '—';
  return new Date(iso).toISOString().slice(0, 19).replace('T', ' ');
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inquiry #{id} — DONGXIAO Cashmere Admin</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #fafaf9; color: #1c1917; padding: 1.5rem; }
    .container { max-width: 900px; margin: 0 auto; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    h1 { font-size: 1.25rem; font-weight: 600; }
    .actions { display: flex; gap: 0.5rem; }
    a, button { font: inherit; cursor: pointer; padding: 0.5rem 1rem; border-radius: 0.375rem; border: 1px solid #d6d3d1; background: white; color: #1c1917; text-decoration: none; font-size: 0.875rem; }
    a:hover, button:hover { background: #f5f5f4; }
    .primary { background: #1c1917; color: white; border-color: #1c1917; }
    .primary:hover { background: #44403c; }
    .card { background: white; padding: 1.5rem; border-radius: 0.5rem; border: 1px solid #e7e5e4; margin-bottom: 1rem; }
    .card h2 { font-size: 1rem; margin-bottom: 1rem; color: #57534e; text-transform: uppercase; letter-spacing: 0.025em; }
    dl { display: grid; grid-template-columns: max-content 1fr; gap: 0.5rem 1.5rem; font-size: 0.875rem; }
    dt { color: #78716c; }
    dd { color: #1c1917; word-break: break-word; }
    .message { background: #f5f5f4; padding: 1rem; border-radius: 0.375rem; font-size: 0.875rem; white-space: pre-wrap; }
    label { display: block; font-size: 0.75rem; color: #57534e; text-transform: uppercase; margin-bottom: 0.25rem; font-weight: 600; }
    select, textarea, input[type="text"] { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d6d3d1; border-radius: 0.375rem; font: inherit; font-size: 0.875rem; margin-bottom: 1rem; }
    textarea { resize: vertical; min-height: 100px; }
    .err { background: #fee2e2; color: #991b1b; padding: 0.75rem 1rem; border-radius: 0.5rem; margin-bottom: 1rem; }
    .b { display: inline-block; padding: 0.125rem 0.5rem; border-radius: 0.25rem; font-size: 0.75rem; font-weight: 600; }
    .b-a { background: #d1fae5; color: #065f46; }
    .b-b { background: #fef3c7; color: #92400e; }
    .b-c { background: #dbeafe; color: #1e40af; }
    .b-grey { background: #e7e5e4; color: #57534e; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Inquiry #{id}</h1>
      <div class="actions">
        <a href="/admin/inquiries/">← Back to list</a>
        <a href="/api/admin/auth?action=logout">Logout</a>
      </div>
    </div>

    {error && <div class="err">Error: {error}</div>}

    {!inquiry ? (
      <div class="card">Not found.</div>
    ) : (
      <>
        <div class="card">
          <h2>Contact</h2>
          <dl>
            <dt>Name</dt><dd>{inquiry.contact_name}</dd>
            <dt>Company</dt><dd>{inquiry.company_name}</dd>
            <dt>Email</dt><dd><a href={`mailto:${inquiry.email}`}>{inquiry.email}</a></dd>
            <dt>Phone</dt><dd>{inquiry.phone || '—'}</dd>
            <dt>Country</dt><dd>{inquiry.country}</dd>
            <dt>Locale</dt><dd>{inquiry.locale}</dd>
          </dl>
        </div>

        <div class="card">
          <h2>Inquiry</h2>
          <dl>
            <dt>Type</dt><dd>{inquiry.inquiry_type}</dd>
            <dt>Product</dt><dd>{inquiry.product_interest || '—'}</dd>
            <dt>Quantity kg</dt><dd>{inquiry.quantity_kg || '—'}</dd>
            <dt>Quantity m</dt><dd>{inquiry.quantity_m || '—'}</dd>
            <dt>Quantity pcs</dt><dd>{inquiry.quantity_pcs || '—'}</dd>
            <dt>Created</dt><dd>{fmtDate(inquiry.created_at)}</dd>
          </dl>
          {inquiry.message && (
            <>
              <label style="margin-top: 1rem;">Message</label>
              <div class="message">{inquiry.message}</div>
            </>
          )}
        </div>

        {lead && (
          <div class="card">
            <h2>Linked Lead #{lead.id}</h2>
            <dl>
              <dt>Grade</dt><dd><span class={`b b-${(lead.lead_grade || 'grey').toLowerCase()}`}>{lead.lead_grade || 'ungraded'}</span></dd>
              <dt>Score</dt><dd>{lead.lead_score || 0}</dd>
              <dt>Status</dt><dd>{lead.status}</dd>
              <dt>Source</dt><dd>{lead.source}</dd>
              <dt>Email step</dt><dd>{lead.email_sequence_step} / 8</dd>
              <dt>Last email</dt><dd>{fmtDate(lead.email_last_sent_at)}</dd>
              <dt>Notes</dt><dd>{lead.notes || '—'}</dd>
            </dl>
          </div>
        )}

        <div class="card">
          <h2>Update</h2>
          <form method="POST" action={`/api/admin/inquiries/?id=${id}`}>
            <label for="status">Status</label>
            <select name="status" id="status">
              <option value="new" selected={inquiry.status === 'new'}>new</option>
              <option value="contacted" selected={inquiry.status === 'contacted'}>contacted</option>
              <option value="qualified" selected={inquiry.status === 'qualified'}>qualified</option>
              <option value="won" selected={inquiry.status === 'won'}>won</option>
              <option value="lost" selected={inquiry.status === 'lost'}>lost</option>
            </select>

            <label for="lead_grade">Lead grade</label>
            <select name="lead_grade" id="lead_grade">
              <option value="" selected={!inquiry.lead_grade}>—</option>
              <option value="A" selected={inquiry.lead_grade === 'A'}>A</option>
              <option value="B" selected={inquiry.lead_grade === 'B'}>B</option>
              <option value="C" selected={inquiry.lead_grade === 'C'}>C</option>
              <option value="D" selected={inquiry.lead_grade === 'D'}>D</option>
            </select>

            {lead && (
              <>
                <label for="notes">Notes (saved to lead)</label>
                <textarea name="notes" id="notes">{lead.notes || ''}</textarea>
              </>
            )}

            <button type="submit" class="primary">Save changes</button>
          </form>
        </div>

        <div class="card">
          <h2>Tracking</h2>
          <dl>
            <dt>UTM source</dt><dd>{inquiry.utm_source || '—'}</dd>
            <dt>UTM medium</dt><dd>{inquiry.utm_medium || '—'}</dd>
            <dt>UTM campaign</dt><dd>{inquiry.utm_campaign || '—'}</dd>
            <dt>Referrer</dt><dd>{inquiry.referrer || '—'}</dd>
            <dt>IP</dt><dd>{inquiry.ip_address || '—'}</dd>
            <dt>User agent</dt><dd style="font-family: monospace; font-size: 0.75rem;">{inquiry.user_agent || '—'}</dd>
          </dl>
        </div>
      </>
    )}
  </div>
</body>
</html>
