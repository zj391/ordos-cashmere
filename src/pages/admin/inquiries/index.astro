---
// Admin inquiries list
// /admin/inquiries
// - Table of all inquiries, filterable by grade/status/country
// - Link to /admin/inquiries/[id] for detail
// - CSV export link

export const prerender = false;

const SUPABASE_URL = process.env.PUBLIC_SUPABASE_URL || process.env.SUPABASE_URL || '';
const SUPABASE_KEY = process.env.SUPABASE_SERVICE_KEY || '';

const url = new URL(Astro.request.url);
const grade = url.searchParams.get('grade') || '';
const status = url.searchParams.get('status') || '';
const country = url.searchParams.get('country') || '';
const search = url.searchParams.get('q') || '';

let inquiries: any[] = [];
let error = '';

if (SUPABASE_URL && SUPABASE_KEY) {
  try {
    let q = '/rest/v1/inquiries?order=created_at.desc&limit=200&select=id,created_at,contact_name,company_name,country,email,phone,inquiry_type,locale,product_interest,quantity_kg,quantity_m,quantity_pcs,lead_grade,status,message';
    const filters: string[] = [];
    if (grade) filters.push(`lead_grade=eq.${grade}`);
    if (status) filters.push(`status=eq.${status}`);
    if (country) filters.push(`country=eq.${country}`);
    if (search) filters.push(`or=(contact_name.ilike.*${search}*,company_name.ilike.*${search}*,email.ilike.*${search}*)`);
    if (filters.length) q += '&' + filters.join('&');

    const res = await fetch(SUPABASE_URL + q, {
      headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY },
    });
    if (res.ok) {
      inquiries = await res.json();
    } else {
      error = `Supabase ${res.status}: ${(await res.text()).slice(0, 200)}`;
    }
  } catch (e) {
    error = e.message;
  }
}

// Summary stats
const byGrade: Record<string, number> = {};
const byStatus: Record<string, number> = {};
inquiries.forEach(i => {
  const g = i.lead_grade || 'ungraded';
  byGrade[g] = (byGrade[g] || 0) + 1;
  const s = i.status || 'unknown';
  byStatus[s] = (byStatus[s] || 0) + 1;
});

function fmtDate(iso: string) {
  if (!iso) return '';
  return new Date(iso).toISOString().slice(0, 16).replace('T', ' ');
}

function badgeGrade(g: string | null) {
  if (!g) return '<span class="b b-grey">—</span>';
  return `<span class="b b-${g.toLowerCase()}">${g}</span>`;
}

function badgeStatus(s: string | null) {
  if (!s) return '<span class="b b-grey">—</span>';
  const colors: Record<string, string> = {
    new: 'blue', contacted: 'amber', qualified: 'green', won: 'emerald', lost: 'red',
  };
  return `<span class="b b-${colors[s] || 'grey'}">${s}</span>`;
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inquiries — DONGXIAO Cashmere Admin</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #fafaf9; color: #1c1917; padding: 1.5rem; }
    .header { max-width: 1400px; margin: 0 auto 1.5rem; display: flex; justify-content: space-between; align-items: center; }
    h1 { font-size: 1.5rem; font-weight: 600; }
    .actions { display: flex; gap: 0.5rem; }
    a, button { font: inherit; cursor: pointer; padding: 0.5rem 1rem; border-radius: 0.375rem; border: 1px solid #d6d3d1; background: white; color: #1c1917; text-decoration: none; font-size: 0.875rem; }
    a:hover, button:hover { background: #f5f5f4; }
    .primary { background: #1c1917; color: white; border-color: #1c1917; }
    .primary:hover { background: #44403c; }
    .stats { max-width: 1400px; margin: 0 auto 1rem; display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .stat { background: white; padding: 0.75rem 1rem; border-radius: 0.5rem; border: 1px solid #e7e5e4; }
    .stat-label { font-size: 0.75rem; color: #78716c; text-transform: uppercase; }
    .stat-value { font-size: 1.25rem; font-weight: 600; }
    .filters { max-width: 1400px; margin: 0 auto 1rem; background: white; padding: 1rem; border-radius: 0.5rem; border: 1px solid #e7e5e4; display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: end; }
    .filter { display: flex; flex-direction: column; }
    .filter label { font-size: 0.75rem; color: #57534e; margin-bottom: 0.25rem; }
    .filter select, .filter input { padding: 0.4rem 0.6rem; border: 1px solid #d6d3d1; border-radius: 0.25rem; font: inherit; font-size: 0.875rem; }
    table { width: 100%; max-width: 1400px; margin: 0 auto; background: white; border-collapse: collapse; border: 1px solid #e7e5e4; border-radius: 0.5rem; overflow: hidden; }
    th { background: #f5f5f4; text-align: left; padding: 0.625rem 0.75rem; font-size: 0.75rem; text-transform: uppercase; color: #57534e; font-weight: 600; }
    td { padding: 0.625rem 0.75rem; font-size: 0.875rem; border-top: 1px solid #f5f5f4; }
    tr:hover { background: #fafaf9; }
    tr a { color: #1c1917; font-weight: 500; border: none; padding: 0; background: none; }
    tr a:hover { text-decoration: underline; }
    .b { display: inline-block; padding: 0.125rem 0.5rem; border-radius: 0.25rem; font-size: 0.75rem; font-weight: 600; }
    .b-a { background: #d1fae5; color: #065f46; }
    .b-b { background: #fef3c7; color: #92400e; }
    .b-c { background: #dbeafe; color: #1e40af; }
    .b-d { background: #fee2e2; color: #991b1b; }
    .b-ungraded, .b-grey { background: #e7e5e4; color: #57534e; }
    .b-new { background: #dbeafe; color: #1e40af; }
    .b-contacted { background: #fef3c7; color: #92400e; }
    .b-qualified { background: #d1fae5; color: #065f46; }
    .b-won { background: #a7f3d0; color: #047857; }
    .b-lost { background: #fee2e2; color: #991b1b; }
    .err { background: #fee2e2; color: #991b1b; padding: 0.75rem 1rem; border-radius: 0.5rem; max-width: 1400px; margin: 0 auto 1rem; }
    .empty { padding: 3rem; text-align: center; color: #78716c; }
  </style>
</head>
<body>
  <div class="header">
    <h1>Inquiries</h1>
    <div class="actions">
      <a href="/api/admin/inquiries/export?{url.searchParams.toString()}" class="primary">Export CSV</a>
      <a href="/api/admin/logout">Logout</a>
    </div>
  </div>

  {error && <div class="err">Error: {error}</div>}

  <div class="stats">
    <div class="stat"><div class="stat-label">Total</div><div class="stat-value">{inquiries.length}</div></div>
    <div class="stat"><div class="stat-label">A-grade</div><div class="stat-value">{byGrade['A'] || 0}</div></div>
    <div class="stat"><div class="stat-label">B-grade</div><div class="stat-value">{byGrade['B'] || 0}</div></div>
    <div class="stat"><div class="stat-label">C-grade</div><div class="stat-value">{byGrade['C'] || 0}</div></div>
    <div class="stat"><div class="stat-label">Uncontacted</div><div class="stat-value">{byStatus['new'] || 0}</div></div>
    <div class="stat"><div class="stat-label">Qualified</div><div class="stat-value">{byStatus['qualified'] || 0}</div></div>
  </div>

  <form class="filters" method="GET">
    <div class="filter">
      <label>Search</label>
      <input type="text" name="q" value={search} placeholder="name / company / email">
    </div>
    <div class="filter">
      <label>Grade</label>
      <select name="grade">
        <option value="">All</option>
        <option value="A" selected={grade === 'A'}>A</option>
        <option value="B" selected={grade === 'B'}>B</option>
        <option value="C" selected={grade === 'C'}>C</option>
        <option value="D" selected={grade === 'D'}>D</option>
      </select>
    </div>
    <div class="filter">
      <label>Status</label>
      <select name="status">
        <option value="">All</option>
        <option value="new" selected={status === 'new'}>new</option>
        <option value="contacted" selected={status === 'contacted'}>contacted</option>
        <option value="qualified" selected={status === 'qualified'}>qualified</option>
        <option value="won" selected={status === 'won'}>won</option>
        <option value="lost" selected={status === 'lost'}>lost</option>
      </select>
    </div>
    <div class="filter">
      <label>Country</label>
      <input type="text" name="country" value={country} placeholder="US / IT / DE...">
    </div>
    <button type="submit">Filter</button>
    <a href="/admin/inquiries">Clear</a>
  </form>

  {inquiries.length === 0 ? (
    <table><tr><td class="empty">No inquiries match these filters.</td></tr></table>
  ) : (
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Contact</th>
          <th>Company</th>
          <th>Country</th>
          <th>Type</th>
          <th>Product</th>
          <th>Qty</th>
          <th>Grade</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        {inquiries.map((i) => (
          <tr>
            <td>{fmtDate(i.created_at)}</td>
            <td><a href={`/admin/inquiries/${i.id}`}>{i.contact_name}</a></td>
            <td>{i.company_name}</td>
            <td>{i.country}</td>
            <td>{i.inquiry_type}</td>
            <td>{i.product_interest || '—'}</td>
            <td>{i.quantity_kg || i.quantity_m || i.quantity_pcs || '—'}</td>
            <td set:html={badgeGrade(i.lead_grade)} />
            <td set:html={badgeStatus(i.status)} />
          </tr>
        ))}
      </tbody>
    </table>
  )}
</body>
</html>
